	f.Font = Enum.Font.GothamBlack
	f.TextSize = 12
	f.TextColor3 = T.Text
	f.AutoButtonColor = false
	f.BorderSizePixel = 0
	Corner(f, 8)

	f.MouseEnter:Connect(function() Tw(f, nil, {BackgroundTransparency = 0}) end)
	f.MouseLeave:Connect(function() Tw(f, nil, {BackgroundTransparency = 0.15}) end)
	f.MouseButton1Click:Connect(function()
		Tw(f, TweenInfo.new(0.1), {Size = UDim2.new(1, -4, 0, 30)}):Play()
