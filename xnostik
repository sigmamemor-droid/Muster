local function CreateTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.Parent = TabContainer

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn

    local btnIcon = Instance.new("TextLabel")
    btnIcon.Size = UDim2.new(0, 24, 1, 0)
    btnIcon.Position = UDim2.new(0, 10, 0, 0)
    btnIcon.BackgroundTransparency = 1
    btnIcon.Text = icon or "•"
    btnIcon.TextSize = 16
    btnIcon.Font = Enum.Font.GothamBold
    btnIcon.TextColor3 = Config.UI.SubTextColor
    btnIcon.Parent = btn

    local btnText = Instance.new("TextLabel")
    btnText.Size = UDim2.new(1, -45, 1, 0)
    btnText.Position = UDim2.new(0, 40, 0, 0)
    btnText.BackgroundTransparency = 1
    btnText.Text = name
    btnText.Font = Enum.Font.GothamSemibold
    btnText.TextSize = 13
    btnText.TextColor3 = Config.UI.SubTextColor
    btnText.TextXAlignment = Enum.TextXAlignment.Left
    btnText.Parent = btn

    local activeBar = Instance.new("Frame")
    activeBar.Size = UDim2.new(0, 3, 0, 20)
    activeBar.Position = UDim2.new(0, 0, 0.5, -10)
    activeBar.BackgroundColor3 = Config.UI.AccentColor
    activeBar.BorderSizePixel = 0
    activeBar.Visible = false
    activeBar.Parent = btn

    local activeBarCorner = Instance.new("UICorner")
    activeBarCorner.CornerRadius = UDim.new(1, 0)
    activeBarCorner.Parent = activeBar

    TabButtons[name] = {btn = btn, icon = btnIcon, text = btnText, bar = activeBar}

    btn.MouseButton1Click:Connect(function()
        Ripple(btn)
        if ActiveTab == name then return end

        -- Сбросить все
        for tabName, data in pairs(TabButtons) do
            Tween(data.btn, {BackgroundColor3 = Color3.fromRGB(30, 30, 42)}, 0.2)
            data.text.TextColor3 = Config.UI.SubTextColor
            data.icon.TextColor3 = Config.UI.SubTextColor
            data.bar.Visible = false
            if Pages[tabName] then Pages[tabName].Visible = false end
        end

        -- Активировать выбранный
        Tween(btn, {BackgroundColor3 = Color3.fromRGB(40, 20, 65)}, 0.2)
        btnText.TextColor3 = Color3.fromRGB(255,255,255)
        btnIcon.TextColor3 = Config.UI.AccentColor
        activeBar.Visible = true
        PageTitle.Text = name

        if Pages[name] then Pages[name].Visible = true end
        ActiveTab = name
    end)

    btn.MouseEnter:Connect(function()
        if ActiveTab ~= name then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(35, 25, 50)}, 0.15)
        end
    end)

    btn.MouseLeave:Connect(function()
        if ActiveTab ~= name then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(30, 30, 42)}, 0.15)
        end
    end)

    return btn
end

