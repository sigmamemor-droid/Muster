local function Toggle(parent, text, key, callback)
	local f = Instance.new("Frame")
	f.Parent = parent
	f.Size = UDim2.new(1, 0, 0, 44)
	f.BackgroundColor3 = T.BG3
	f.BackgroundTransparency = 0.2
	f.BorderSizePixel = 0
	Corner(f, 10)
	Stroke(f, T.BG4, 1)

	local l = Instance.new("TextLabel")
	l.Parent = f
	l.Size = UDim2.new(1, -80, 1, 0)
	l.Position = UDim2.new(0, 16, 0, 0)
	l.BackgroundTransparency = 1
	l.Text = text
	l.Font = Enum.Font.GothamBold
	l.TextSize = 13
	l.TextColor3 = T.Text
	l.TextXAlignment = Enum.TextXAlignment.Left

	local bg = Instance.new("Frame")
	bg.Parent = f
	bg.Size = UDim2.new(0, 44, 0, 22)
	bg.Position = UDim2.new(1, -60, 0.5, -11)
	bg.BackgroundColor3 = State[key] and T.Accent or T.BG4
	bg.BorderSizePixel = 0
	Corner(bg, 11)

	local knob = Instance.new("Frame")
	knob.Parent = bg
	knob.Size = UDim2.new(0, 18, 0, 18)
	knob.Position = State[key] and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
	knob.BackgroundColor3 = T.White
	knob.BorderSizePixel = 0
	Corner(knob, 9)

	local glow = Instance.new("ImageLabel")
	glow.Parent = knob
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.Position = UDim2.new(0.5, 0, 0.5, 0)
	glow.Size = UDim2.new(1.6, 0, 1.6, 0)
	glow.BackgroundTransparency = 1
	glow.Image = "rbxassetid://5028857084"
	glow.ImageColor3 = T.Accent
	glow.ImageTransparency = State[key] and 0.7 or 1
	glow.ZIndex = 0

	local val = State[key]
	local function Set(v, silent)
		val = v
		State[key] = v
		Tw(bg, nil, {BackgroundColor3 = v and T.Accent or T.BG4})
		Tw(knob, nil, {Position = v and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)})
		Tw(glow, nil, {ImageTransparency = v and 0.7 or 1})
		if not silent and callback then pcall(callback, v) end
	end

	local hit = Instance.new("TextButton")
	hit.Parent = f
	hit.Size = UDim2.new(1, 0, 1, 0)
	hit.BackgroundTransparency = 1
	hit.Text = ""
	hit.MouseButton1Click:Connect(function() Set(not val) end)

	f.MouseEnter:Connect(function() Tw(f, nil, {BackgroundTransparency = 0}) end)
	f.MouseLeave:Connect(function() Tw(f, nil, {BackgroundTransparency = 0.2}) end)

	return {Set = Set, Value = val}
end

local function Slider(parent, text, min, max, key, suffix, callback)
	local f = Instance.new("Frame")
	f.Parent = parent
	f.Size = UDim2.new(1, 0, 0, 60)
	f.BackgroundColor3 = T.BG3
	f.BackgroundTransparency = 0.2
	f.BorderSizePixel = 0
	Corner(f, 10)
	Stroke(f, T.BG4, 1)

	local l = Instance.new("TextLabel")
	l.Parent = f
	l.Size = UDim2.new(0.6, 0, 0, 26)
	l.Position = UDim2.new(0, 16, 0, 4)
	l.BackgroundTransparency = 1
	l.Text = text
	l.Font = Enum.Font.GothamBold
	l.TextSize = 13
	l.TextColor3 = T.Text
	l.TextXAlignment = Enum.TextXAlignment.Left

	local vl = Instance.new("TextLabel")
	vl.Parent = f
	vl.Size = UDim2.new(0.4, -16, 0, 26)
	vl.Position = UDim2.new(0.6, 0, 0, 4)
	vl.BackgroundTransparency = 1
	vl.Text = tostring(State[key]) .. (suffix or "")
	vl.Font = Enum.Font.GothamBold
	vl.TextSize = 12
	vl.TextColor3 = T.Accent
	vl.TextXAlignment = Enum.TextXAlignment.Right

	local track = Instance.new("Frame")
	track.Parent = f
	track.Size = UDim2.new(1, -32, 0, 4)
	track.Position = UDim2.new(0, 16, 0, 40)
	track.BackgroundColor3 = T.BG4
	track.BorderSizePixel = 0
	Corner(track, 2)

	local fill = Instance.new("Frame")
	fill.Parent = track
	fill.Size = UDim2.new(math.clamp((State[key]-min)/(max-min), 0, 1), 0, 1, 0)
	fill.BackgroundColor3 = T.Accent
	fill.BorderSizePixel = 0
	Corner(fill, 2)

	local knob = Instance.new("Frame")
	knob.Parent = fill
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(1, 0, 0.5, 0)
	knob.BackgroundColor3 = T.White
	knob.BorderSizePixel = 0
	Corner(knob, 7)

	local dragging = false
	local function Update(input)
		local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local nval = math.floor(min + (max - min) * rel + 0.5)
		State[key] = nval
		vl.Text = tostring(nval) .. (suffix or "")
		fill.Size = UDim2.new(rel, 0, 1, 0)
		if callback then pcall(callback, nval) end
	end

	track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(i) end end)
	track.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

	f.MouseEnter:Connect(function() Tw(f, nil, {BackgroundTransparency = 0}) end)
	f.MouseLeave:Connect(function() Tw(f, nil, {BackgroundTransparency = 0.2}) end)
end

