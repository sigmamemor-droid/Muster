    Corner(switch, 11); Stroke(switch, C.Divider, 1.5)
    
    local knob = Instance.new("Frame")
    knob.Parent = switch
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = State[key] and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Corner(knob, 8)
    
    local btn = Instance.new("TextButton")
    btn.Parent = holder
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.MouseButton1Click:Connect(function()
        State[key] = not State[key]
        Tw(switch, TweenInfo.new(0.2), {BackgroundColor3 = State[key] and C.Accent or C.BG})
        Tw(knob, TweenInfo.new(0.2), {Position = State[key] and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)})
        if callback then callback(State[key]) end
    end)
end

function Library:Slider(parent, text, min, max, key, suffix, callback)
    local holder = Instance.new("Frame")
    holder.Parent = parent
    holder.Size = UDim2.new(1, 0, 0, 65)
    holder.BackgroundColor3 = C.Element
    holder.BackgroundTransparency = C.Element_Trans
    Corner(holder, 8); Stroke(holder)
    
    local label = Instance.new("TextLabel")
    label.Parent = holder
    label.Size = UDim2.new(0.7, 0, 0, 30)
    label.Position = UDim2.new(0, 15, 0, 0)
    label.Text = text
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 14
    label.TextColor3 = C.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = holder
    valueLabel.Size = UDim2.new(0.3, -15, 0, 30)
    valueLabel.Position = UDim2.new(0.7, 0, 0, 0)
    valueLabel.Text = tostring(State[key]) .. (suffix or "")
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 13
    valueLabel.TextColor3 = C.Accent
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.BackgroundTransparency = 1
    
    local track = Instance.new("Frame")
    track.Parent = holder
    track.Size = UDim2.new(1, -30, 0, 6)
    track.Position = UDim2.new(0, 15, 0, 40)
    track.BackgroundColor3 = C.BG
    Corner(track, 3)
    
    local fill = Instance.new("Frame")
    fill.Parent = track
    fill.Size = UDim2.new(math.clamp((State[key]-min)/(max-min),0,1), 0, 1, 0)
    fill.BackgroundColor3 = C.Accent
    Corner(fill, 3)
    
    local knob = Instance.new("Frame")
    knob.Parent = fill
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(1, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Corner(knob, 7)
    
    local dragging = false
    local function Update(input)
        local relX = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local newValue = math.floor(min + (max-min) * relX + 0.5)
        State[key] = newValue
        fill.Size = UDim2.new(relX, 0, 1, 0)
        valueLabel.Text = tostring(newValue) .. (suffix or "")
        if callback then callback(newValue) end
    end
    
    track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(i) end end)
    track.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end

function Library:Button(parent, text, callback)
    local holder = Instance.new("TextButton")
    holder.Parent = parent
    holder.Size = UDim2.new(1, 0, 0, 38)
    holder.Text = text
