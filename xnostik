    Callback = function(Value)
        WalkSpeedTgl = Value
        if not Value then local h = GetHum(); if h then h.WalkSpeed = 16 end end
    end
})

local CFrameSpeed = false
MovementTab:AddToggle({
    Name = "CFrame Speed (Обход Античита)", Default = false,
    Callback = function(Value) CFrameSpeed = Value end
})

local Bhop = false
local BhopPower = 50
MovementTab:AddToggle({ Name = "BunnyHop (Авто-прыжок)", Default = false, Callback = function(Value) Bhop = Value end })
MovementTab:AddSlider({ Name = "Bhop Power", Min = 30, Max = 120, Default = 50, Color = Color3.fromRGB(255,255,255), Increment = 1, ValueName = "Jump", Callback = function(Value) BhopPower = Value end })

RunService.Heartbeat:Connect(function()
    local h = GetHum(); local r = GetRoot()
    if h and r then
        if WalkSpeedTgl then h.WalkSpeed = customSpeed end
        if CFrameSpeed and h.MoveDirection.Magnitude > 0 then
            r.CFrame = r.CFrame + (h.MoveDirection * (customSpeed/50))
        end
        if Bhop and h.MoveDirection.Magnitude > 0 and h.FloorMaterial ~= Enum.Material.Air then
            r.AssemblyLinearVelocity = Vector3.new(r.AssemblyLinearVelocity.X, BhopPower, r.AssemblyLinearVelocity.Z)
        end
    end
end)

