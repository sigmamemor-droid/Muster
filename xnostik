-- ЛОГИКА ЧИТА

-- ESP
local espActive = false
local roleEspActive = false
local espConnection = nil

local function createHighlight(player, color, name)
    if player.Character and not player.Character:FindFirstChild(name) then
        local h = Instance.new("Highlight")
        h.Name = name
        h.FillColor = color
        h.OutlineColor = Color3.fromRGB(255, 255, 255)
        h.FillTransparency = 0.5
        h.OutlineTransparency = 0
        h.Parent = player.Character
    end
end

local function removeHighlight(player, name)
    if player.Character then
        local h = player.Character:FindFirstChild(name)
        if h then h:Destroy() end
    end
end

-- X-Ray
local xrayActive = false
local originalTransparencies = {}

local function toggleXRay(strength)
    xrayActive = (strength > 0)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) then
            if xrayActive then
                if not originalTransparencies[obj] then
                    originalTransparencies[obj] = obj.Transparency
                end
                obj.Transparency = math.clamp(strength / 100, 0, 0.9)
            else
                if originalTransparencies[obj] then
                    obj.Transparency = originalTransparencies[obj]
                    originalTransparencies[obj] = nil
                end
            end
        end
    end
end

