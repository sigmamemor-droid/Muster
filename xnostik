local function PlaySnd(id, vol)
    if curSound then pcall(function() curSound:Stop(); curSound:Destroy() end); curSound = nil end
    local r = GetRoot(); if not r then return false end
    local nid = tonumber(id); if not nid then return false end
    local v = math.clamp(tonumber(vol) or 2, 0, 5)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. nid
    s.Volume = v; s.Looped = true; s.Parent = r; s:Play()
    curSound = s; sndPlaying = true; lastAID = id; lastVol = vol
    return true
end

local function StopSnd()
    if curSound then pcall(function() curSound:Stop(); curSound:Destroy() end); curSound = nil end
    sndPlaying = false
end

