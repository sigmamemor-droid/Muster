-- Bunnyhop and Strafe System
local StrafeTouchPanel = nil
local TouchJoystickFrame = nil
local TouchJoystickInner = nil
local IsStrafing = false
local StrafeFactorX, StrafeFactorY = 0, 0

local function checkInsideStrafeBounds(pos)
    if not StrafeTouchPanel then return false end
    local boundsPos = StrafeTouchPanel.AbsolutePosition
    local boundsSize = StrafeTouchPanel.AbsoluteSize
    local target = Vector2.new(pos.X, pos.Y)
    return (target.X >= boundsPos.X) and (target.X <= (boundsPos.X + boundsSize.X)) and (target.Y >= boundsPos.Y) and (target.Y <= (boundsPos.Y + boundsSize.Y))
end

local function handleStrafeJoyMove(pos)
    if not TouchJoystickFrame or not TouchJoystickInner then return end
    local origin = TouchJoystickFrame.AbsolutePosition + (TouchJoystickFrame.AbsoluteSize / 2)
    local targetVec = Vector2.new(pos.X, pos.Y) - origin
    local limit = (TouchJoystickFrame.AbsoluteSize.X / 2) - 10
    
    if targetVec.Magnitude > limit then
        targetVec = targetVec.Unit * limit
    end
    
    TouchJoystickInner.Position = UDim2.new(0, (targetVec.X + (TouchJoystickFrame.AbsoluteSize.X / 2)) - 15, 0, (targetVec.Y + (TouchJoystickFrame.AbsoluteSize.Y / 2)) - 15)
    
    if targetVec.Magnitude > 0 then
        local ratio = math.clamp(targetVec.Magnitude / 35, 0, 1)
        StrafeFactorX = math.clamp((targetVec.X / targetVec.Magnitude) * ratio, -1, 1)
        StrafeFactorY = math.clamp((-targetVec.Y / targetVec.Magnitude) * ratio, -1, 1)
    else
        StrafeFactorX, StrafeFactorY = 0, 0
    end
end

local function executeStrafeTick()
    if not Config.BunnyHopStrafe or not IsStrafing then return end
    if math.abs(StrafeFactorX) < 0.05 and math.abs(StrafeFactorY) < 0.05 then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local lookVec = Vector3.new(Camera.CFrame.LookVector.X, 0, Camera.CFrame.LookVector.Z)
    lookVec = lookVec.Magnitude > 0 and lookVec.Unit or Vector3.new(0, 0, -1)
    
    local rightVec = Vector3.new(Camera.CFrame.RightVector.X, 0, Camera.CFrame.RightVector.Z)
    rightVec = rightVec.Magnitude > 0 and rightVec.Unit or Vector3.new(1, 0, 0)
    
    local moveDir = (lookVec * StrafeFactorY) + (rightVec * StrafeFactorX)
    local moveMag = math.sqrt((StrafeFactorX * StrafeFactorX) + (StrafeFactorY * StrafeFactorY))
    local velocitySpeed = 0.5 + (moveMag * 1.5)
    
    hrp.CFrame = hrp.CFrame + (moveDir * velocitySpeed * 0.5)
end

