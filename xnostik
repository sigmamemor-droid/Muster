-- ESP Main Loop
RunService.RenderStepped:Connect(function()
    -- Игроки
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
            RemovePlayerESP(plr)
            continue
        end

        if not ESPObjects[plr] then
            CreatePlayerESP(plr)
        end

        local data = ESPObjects[plr]
        if not data then continue end

        local role, color = GetRole(plr)
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local dist = myRoot and math.floor((myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude) or 0
        local hum = plr.Character:FindFirstChild("Humanoid")
        local hp = hum and math.floor(hum.Health) or 0
        local maxhp = hum and math.floor(hum.MaxHealth) or 100

        local shouldShow = Config.ESP.Enabled and (
            (role == "MURDERER" and Config.ESP.Murderer) or
            (role == "SHERIFF" and Config.ESP.Sheriff) or
            (role == "INNOCENT" and Config.ESP.Innocent)
        )

        data.Billboard.Enabled = shouldShow
        data.Highlight.Enabled = shouldShow

        if shouldShow then
            data.Billboard.Adornee = plr.Character.HumanoidRootPart
            data.Billboard.Parent = plr.Character

            data.Highlight.Parent = plr.Character
            data.Highlight.FillColor = color
            data.Highlight.OutlineColor = color

            data.Name.Text = "👤 " .. plr.Name
            data.Role.Text = role
            data.Role.TextColor3 = color
            data.Role.TextStrokeColor3 = color

            local infoStr = ""
            if Config.ESP.ShowHealth then infoStr = infoStr .. string.format("❤ %d/%d  ", hp, maxhp) end
            if Config.ESP.ShowDistance then infoStr = infoStr .. string.format("📏 %dst", dist) end
            data.Info.Text = infoStr
        end
    end

    -- Объекты
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Gun" and Config.ESP.GunESP and not GunESPObjects[obj] then
            CreateObjectESP(obj, Color3.fromRGB(255, 200, 0), "🔫  GUN")
        elseif obj.Name == "Knife" and Config.ESP.KnifeESP and not GunESPObjects[obj] then
            CreateObjectESP(obj, Color3.fromRGB(255, 50, 50), "🔪  KNIFE")
        elseif obj.Name == "Coin" and Config.ESP.CoinESP and not GunESPObjects[obj] then
            CreateObjectESP(obj, Color3.fromRGB(0, 255, 200), "🪙  COIN")
        end
    end

    -- Видимость Gun/Knife/Coin ESP
    for obj, data in pairs(GunESPObjects) do
        if not obj.Parent then
            data.Highlight:Destroy()
            data.Billboard:Destroy()
            GunESPObjects[obj] = nil
        else
            local isGun = obj.Name == "Gun"
            local isKnife = obj.Name == "Knife"
            local isCoin = obj.Name == "Coin"
            data.Highlight.Enabled = (isGun and Config.ESP.GunESP) or (isKnife and Config.ESP.KnifeESP) or (isCoin and Config.ESP.CoinESP)
            data.Billboard.Enabled = data.Highlight.Enabled
        end
    end
end)

