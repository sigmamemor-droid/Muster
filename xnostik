CreateToggle(TabCombat, "Aimbot (Smooth)", false, function(state)
    if state then
        IDK.Connections["Aim"] = RunService.RenderStepped:Connect(function()
            local t = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and GetRole(p) == "Murderer" and p.Character and p.Character:FindFirstChild("Head") then 
                    t = p.Character.Head 
                    break 
                end
            end
            if t then camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, t.Position), 0.2) end
        end)
    else
        if IDK.Connections["Aim"] then IDK.Connections["Aim"]:Disconnect() end
    end
end)

CreateButton(TabCombat, "⚡ KILL ALL (Stand Still)", function()
    local char = player.Character
    if not char then return end

    -- Поиск экипированного оружия
    local weapon = nil
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then weapon = v break end
    end

    if not weapon then 
        warn("IDK: Возьми оружие в руки!") 
        return 
    end

    local isMurderer = weapon:FindFirstChild("KnifeServer") or weapon:FindFirstChild("Slash") or weapon.Name:lower():find("knife")
    local myRole = GetRole(player)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local targetRole = GetRole(p)
            
            -- Логика: Убийца режет всех кроме себя, Шериф стреляет только в Убийцу
            if (isMurderer and targetRole ~= "Murderer") or (not isMurderer and myRole == "Sheriff" and targetRole == "Murderer") then
                
                if isMurderer then
                    -- Метод 1: Симуляция касания (firetouchinterest)
                    local handle = weapon:FindFirstChild("Handle")
                    local targetPart = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Torso")
                    
                    if handle and targetPart and firetouchinterest then
                        firetouchinterest(handle, targetPart, 0)
                        task.wait(0.01)
                        firetouchinterest(handle, targetPart, 1)
                    else
                        -- Резервный спам ремутом, если эксплойт слабый
                        local remote = weapon:FindFirstChild("Slash") or weapon:FindFirstChildOfClass("RemoteEvent", true)
                        if remote then remote:FireServer(1) end
                    end
                else
                    -- Метод 2: Выстрел шерифа без движения
                    local remote = weapon:FindFirstChild("Shoot") or weapon:FindFirstChildOfClass("RemoteEvent", true)
                    if remote then
                        remote:FireServer(1, p.Character.HumanoidRootPart.Position, "ah")
                    end
                end
            end
        end
    end
end)

