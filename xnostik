CreateToggle(TabCombat, "Aimbot (Smooth)", false, function(state)
    if state then
        IDK.Connections["Aimbot"] = RunService.RenderStepped:Connect(function()
            local targetHead = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and GetRole(p) == "Murderer" and p.Character and p.Character:FindFirstChild("Head") then
                    targetHead = p.Character.Head
                    break
                end
            end
