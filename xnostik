-- УТИЛИТЫ MM2
---------------------------------------------------------
local function GetRole(p)
    if not p.Character then return "Innocent" end
    local hasKnife, hasGun = false, false
    local function check(c)
        for _, v in ipairs(c:GetChildren()) do
            if v:IsA("Tool") then
                if v.Name:lower():find("knife") or v:FindFirstChild("KnifeServer") then hasKnife = true end
                if v.Name:lower():find("gun") or v.Name:lower():find("revolver") or v:FindFirstChild("GunScript") then hasGun = true end
            end
        end
    end
    check(p.Backpack)
    check(p.Character)
    if hasKnife then return "Murderer" end
    if hasGun then return "Sheriff" end
    return "Innocent"
end

