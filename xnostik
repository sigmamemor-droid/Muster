---------------------------------------------------------
-- THEME CONTROLLER & GRADIENTS (with smooth tweening)
---------------------------------------------------------
local themedBg, themedSurface, themedAccent, themedGradients = {}, {}, {}, {}

local function ApplyTheme(themeName)
    local theme = Themes[themeName]
    if not theme then return end
    currentThemeName = themeName
    
    -- Tween all color changes for smooth transition
    local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    
    C.bg = theme.bg; C.surface = theme.surface; C.accent = theme.accent; C.accentLight = theme.accentLight
    
    for _, item in ipairs(themedBg) do 
        if item.Parent then 
            TweenService:Create(item, tweenInfo, {BackgroundColor3 = C.bg}):Play()
            if item.Name == "Hub" or item.Name == "Sidebar" or item.Name == "TopBar" then
                item.BackgroundTransparency = menuTransparency
            end
        end 
    end
    for _, item in ipairs(themedSurface) do 
        if item.Parent then 
            TweenService:Create(item, tweenInfo, {BackgroundColor3 = C.surface}):Play()
            if item.Name == "TopBar" then
                item.BackgroundTransparency = menuTransparency
            end
        end 
    end
    for _, item in ipairs(themedAccent) do 
        if item.Parent then
            if item:IsA("Frame") or item:IsA("TextButton") then
                TweenService:Create(item, tweenInfo, {BackgroundColor3 = C.accent}):Play()
            elseif item:IsA("TextLabel") then
                TweenService:Create(item, tweenInfo, {TextColor3 = C.accentLight}):Play()
            elseif item:IsA("UIStroke") then
                TweenService:Create(item, tweenInfo, {Color = C.accent}):Play()
            end
        end
    end
    for _, grad in ipairs(themedGradients) do
        if grad.Parent then
            TweenService:Create(grad, tweenInfo, {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, theme.accent),
                    ColorSequenceKeypoint.new(1, theme.gradient[2])
                })
            }):Play()
        end
    end
end

