local navBtns = {}
local function CreateNavBtn(key, sectionFrame)
    local btn = Instance.new("TextButton"); btn.Size = UDim2.new(0.31, 0, 1, 0); btn.BackgroundColor3 = C.elevated; btn.Text = L[currentLang][key] or key; btn.TextColor3 = C.textDim; btn.TextSize = 9; btn.Font = Enum.Font.GothamBold; btn.Parent = SettingsNav; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5); updateableLabels[btn] = key; table.insert(globalTextObjects, btn)
    -- Hover
    btn.MouseEnter:Connect(function() if not (btn.BackgroundColor3 == C.accent) then TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(30, 24, 45)}):Play() end end)
    btn.MouseLeave:Connect(function() if not (btn.BackgroundColor3 == C.accent) then TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = C.elevated}):Play() end end)
    btn.MouseButton1Click:Connect(function()
        Section_UI.Visible = false; Section_Theme.Visible = false; Section_Showcase.Visible = false
        for _, b in ipairs(navBtns) do TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = C.elevated, TextColor3 = C.textDim}):Play() end
        sectionFrame.Visible = true
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = C.accent, TextColor3 = C.white}):Play()
    end)
    table.insert(navBtns, btn)
end
