local ESPManager = { PlayerCache = {}, ItemCache = {} }

function ESPManager:GetRole(player)
    if not player.Character then return "INNOCENT", C.Green end
    local char, pack = player.Character, player.Backpack
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "MURDERER", C.Red end
            if tool.Name == "Gun" then return "SHERIFF", C.Accent end
        end
    end
    for _, tool in ipairs(pack:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "MURDERER", C.Red end
            if tool.Name == "Gun" then return "SHERIFF", C.Accent end
        end
    end
    return "INNOCENT", C.Green
end

function ESPManager:Create(obj, type, text, color)
    if not obj or not obj.Parent or self.ItemCache[obj] or self.PlayerCache[obj] then return end
    
    local data = { Type = type }
    data.HL = Instance.new("Highlight")
    data.HL.Parent = obj
    data.HL.FillColor = color
    data.HL.OutlineColor = color
    data.HL.FillTransparency = 0.6
    data.HL.OutlineTransparency = 0.1
    data.HL.Enabled = false
    
    data.Bill = Instance.new("BillboardGui")
    data.Bill.Parent = obj
    data.Bill.AlwaysOnTop = true
    data.Bill.Size = UDim2.new(0, 120, 0, 20)
    data.Bill.StudsOffset = Vector3.new(0, 2.5, 0)
    data.Bill.Enabled = false
    
    data.Label = Instance.new("TextLabel")
    data.Label.Parent = data.Bill
    data.Label.Size = UDim2.new(1, 0, 1, 0)
    data.Label.Text = text
    data.Label.Font = Enum.Font.GothamSemibold
    data.Label.TextSize = 14
    data.Label.TextColor3 = color
    data.Label.TextStrokeTransparency = 0.5
    data.Label.BackgroundTransparency = 1
    
    if type == "Player" then
        self.PlayerCache[obj] = data
    else
        self.ItemCache[obj] = data
    end
    
    obj.AncestryChanged:Connect(function(_, parent)
        if not parent then self:Destroy(obj) end
    end)
end

function ESPManager:Destroy(obj)
    local cache = self.PlayerCache[obj] and self.PlayerCache or self.ItemCache[obj] and self.ItemCache
    if cache and cache[obj] then
        pcall(function() cache[obj].HL:Destroy() end)
        pcall(function() cache[obj].Bill:Destroy() end)
        cache[obj] = nil
    end
end

local function onChildAdded(child)
    if child:IsA("Tool") and (child.Name == "Gun" or child.Name == "Knife") then
        local itemName = child.Name
        local itemText = (itemName == "Gun" and "🔫 Gun" or "🔪 Knife")
        local itemColor = (itemName == "Gun" and C.Gold or C.Red)
        ESPManager:Create(child, itemName, itemText, itemColor)
    elseif child.Name == "Coin" and child:IsA("BasePart") then
        ESPManager:Create(child, "Coin", "🪙 Coin", C.Accent)
    end
end
