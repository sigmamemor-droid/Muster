-- IRONCLAD ANTI-FLING (CLIENT-SIDE DETECTOR & COLLISION DISABLER)
local antiFlingActive = false
local getAF
getAF = MkToggle("Home", "antifling", false, function(active)
    antiFlingActive = active
    ClearConn("ironclad_af")
    if active then
        Conn("ironclad_af", RunService.Stepped:Connect(function()
            if not antiFlingActive then return end
            
            local character = player.Character
            if not character then return end
            
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Neutralize sudden extreme momentum injected into client character
                if root.AssemblyLinearVelocity.Magnitude > 100 or root.AssemblyAngularVelocity.Magnitude > 100 then
                    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
            end
            
            -- Disable collisions with other players completely (removes physical interaction)
            for _, otherPlayer in ipairs(Players:GetPlayers()) do
                if otherPlayer ~= player and otherPlayer.Character then
                    for _, part in ipairs(otherPlayer.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                            
                            -- Neutralize physical forces of other players near us locally
                            if part.AssemblyLinearVelocity.Magnitude > 120 or part.AssemblyAngularVelocity.Magnitude > 120 then
                                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                            end
                        end
                    end
                end
            end
            
            -- Ensure limbs have CanCollide off, preventing lever-arms physics interactions
            for _, limb in ipairs(character:GetChildren()) do
                if limb:IsA("BasePart") and limb.Name ~= "HumanoidRootPart" then
                    limb.CanCollide = false
                end
            end
        end))
        Notify("Anti-Fling", "Ironclad Protection Active", C.green, 2.5)
    else
        Notify("Anti-Fling", "Deactivated", C.red, 1.5)
    end
end)

