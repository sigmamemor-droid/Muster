local function CreateDynRow(labelKey, initialValue, valueColor)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 23); row.BackgroundColor3 = C.cardBg; row.BorderSizePixel = 0; row.LayoutOrder = NO("Info"); row.Parent = InfoContainer
