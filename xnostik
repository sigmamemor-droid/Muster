    Instance.new("UICorner", ToggleCircle).CornerRadius = UDim.new(1, 0)

    local function UpdateVisual()
        local targetBg = active and Colors.greenDark or Colors.elevated
        local targetInd = active and Colors.green or Colors.textMuted
        local targetToggleBg = active and Colors.green or Colors.textMuted
        local targetCirclePos = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        local targetStrokeColor = active and Colors.green or Colors.elevated
        local targetStrokeTrans = active and 0.5 or 1

        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = targetBg}):Play()
        TweenService:Create(Indicator, TweenInfo.new(0.2), {BackgroundColor3 = targetInd}):Play()
        TweenService:Create(ToggleBG, TweenInfo.new(0.2), {BackgroundColor3 = targetToggleBg}):Play()
        TweenService:Create(ToggleCircle, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Position = targetCirclePos}):Play()
        TweenService:Create(BtnStroke, TweenInfo.new(0.2), {Color = targetStrokeColor, Transparency = targetStrokeTrans}):Play()
    end

    -- Hover
    Btn.MouseEnter:Connect(function()
        if not active then
            TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = Colors.card}):Play()
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not active then
            TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = Colors.elevated}):Play()
        end
    end)

    Btn.MouseButton1Click:Connect(function()
        active = not active
        UpdateVisual()
        callback(active, Btn)
    end)

    return function() return active end, function(state)
        active = state
        UpdateVisual()
    end
end

