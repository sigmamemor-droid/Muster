-- Target Fling
local targetFlingActive = false
MkButton("Troll", "fling_btn", C.accent, function()
    if not selectedPlayer or not selectedPlayer.Character then Notify("linbergz", "Select target first!", C.red, 2); return end
    local r = GetRoot(); local h = GetHum()
    local tR = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
    local tH = selectedPlayer.Character:FindFirstChildOfClass("Humanoid")
    if r and tR and h and tH and tH.Health > 0 then
        if targetFlingActive then return end
        targetFlingActive = true
        local savedPos = r.CFrame
        Notify("linbergz", "Target locked: Flinging " .. selectedPlayer.DisplayName, C.accent, 2.5)
        local stored = {}
        for _, p in ipairs(GetChar():GetDescendants()) do if p:IsA("BasePart") then stored[p] = {p.CanCollide, p.Massless}; p.CanCollide = false; p.Massless = true end end
        r.CanCollide = true
        local bav = Instance.new("BodyAngularVelocity"); bav.MaxTorque = Vector3.new(1e9,1e9,1e9); bav.AngularVelocity = Vector3.new(256,256,256); bav.Parent = r
        h:ChangeState(Enum.HumanoidStateType.Physics)
        local startTime = tick()
        while tick() - startTime < 3.5 do
            if not tR or not tR.Parent or tH.Health <= 0 then break end
            pcall(function()
                r.CFrame = tR.CFrame * CFrame.new(0, -1.3, 0)
                r.AssemblyLinearVelocity = tR.CFrame.LookVector * 300
            end)
            task.wait(0.01)
        end
        pcall(function()
            bav:Destroy()
            r.AssemblyLinearVelocity = Vector3.zero; r.AssemblyAngularVelocity = Vector3.zero
            r.CFrame = savedPos; h:ChangeState(Enum.HumanoidStateType.GettingUp)
        end)
        for p, d in pairs(stored) do if p.Parent then p.CanCollide = d[1]; p.Massless = d[2] end end
        targetFlingActive = false
        Notify("linbergz", "Fling sequence completed", C.green, 2)
    else
        Notify("linbergz", "Target unavailable", C.red, 2)
    end
end)

