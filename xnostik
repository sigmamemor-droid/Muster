-- GUN ESP (CollectionService)
local function CreateGunESP(tool)
	if not tool:IsA("Tool") then return end
	local n = tool.Name:lower(); if not (n:find("gun") or n:find("revolver")) then return end
	if IsPlayerOwned(tool) then return end
	if ActiveGunEsp[tool] then return end
	
	local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart"); if not handle then return end
	local bb = Instance.new("BillboardGui"); bb.Name = GUN_TAG; bb.Adornee = handle; bb.Size = UDim2.new(0,120,0,40); bb.StudsOffset = Vector3.new(0,3.5,0); bb.AlwaysOnTop = true; bb.Parent = handle
	CollectionService:AddTag(bb, GUN_TAG)
	local fr = Instance.new("Frame", bb); fr.Size=UDim2.new(1,0,1,0); fr.BackgroundColor3=C.black; fr.BackgroundTransparency=0.4; fr.BorderSizePixel=0; Instance.new("UICorner", fr).CornerRadius=UDim.new(0,6)
	Instance.new("UIStroke", fr).Color = C.gold; Instance.new("UIStroke", fr).Thickness = 1.5
	local lbl = Instance.new("TextLabel", fr); lbl.Size=UDim2.new(1,-10,0.6,0); lbl.Position=UDim2.new(0,5,0,0); lbl.BackgroundTransparency=1; lbl.Text="> "..tool.Name; lbl.TextColor3=C.gold; lbl.TextSize=13; lbl.Font=Enum.Font.GothamBold; lbl.TextXAlignment=Enum.TextXAlignment.Left
	local dl = Instance.new("TextLabel", fr); dl.Name="Dist"; dl.Size=UDim2.new(1,-10,0.4,0); dl.Position=UDim2.new(0,5,0.6,0); dl.BackgroundTransparency=1; dl.Text="-- studs"; dl.TextColor3=C.textSec; dl.TextSize=10; dl.Font=Enum.Font.Gotham; dl.TextXAlignment=Enum.TextXAlignment.Left
	ActiveGunEsp[tool] = bb; GunEspMaid:Give(bb)
	tool.AncestryChanged:Once(function(_, p) if not p or not p:IsDescendantOf(workspace) then ActiveGunEsp[tool]=nil; if bb then bb:Destroy() end end end)
end

local function ToggleGunESP(state)
	States.ESP_Guns = state
	if state then
		for _, obj in ipairs(workspace:GetDescendants()) do if obj:IsA("Tool") then CreateGunESP(obj) end end
		GunEspMaid:Give(workspace.DescendantAdded:Connect(function(obj) if obj:IsA("Tool") then task.wait(0.1); CreateGunESP(obj) end end))
		GunEspMaid:Give(RunService.Heartbeat:Connect(function() local root=GetRoot(); if not root then return end for tool, bb in pairs(ActiveGunEsp) do if bb and bb.Parent and bb.Adornee then local dist=math.floor((root.Position-bb.Adornee.Position).Magnitude); local dl=bb:FindFirstChild("Frame"):FindFirstChild("Dist"); if dl then dl.Text=dist.." studs" end else ActiveGunEsp[tool]=nil end end end))
		Notify("Gun ESP", "Tracking Dropped Guns", C.gold, 2)
	else GunEspMaid:Clean(); ActiveGunEsp={}; for _, g in ipairs(CollectionService:GetTagged(GUN_TAG)) do g:Destroy() end; Notify("Gun ESP", "Off", C.textDim, 1) end
end

