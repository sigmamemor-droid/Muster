local currentSound = nil

local function StopSound()
    if currentSound then
        pcall(function() currentSound:Stop() end)
        pcall(function() currentSound:Destroy() end)
        currentSound       = nil
        State.soundPlaying = false
    end
end

local function PlaySound(id, vol)
    StopSound()
    local root = GetRoot()
    if not root then return false end
    local numId = tonumber(id)
    if not numId then return false end
    local v = math.clamp(tonumber(vol) or 2, 0, 5)
    local snd      = Instance.new("Sound")
    snd.SoundId    = "rbxassetid://" .. math.floor(numId)
    snd.Volume     = v
    snd.Looped     = true
    snd.Parent     = root
    snd:Play()
    currentSound       = snd
    State.soundPlaying = true
    State.boomboxId    = id
    State.boomboxVol   = vol
    return true
end

