local function DoLoad()
    Logo.Size = UDim2.new(0, 0, 0, 0)
    Logo.Position = UDim2.new(0.5, 0, 0, 110)
    TweenService:Create(Glow, TweenInfo.new(0.6), {ImageTransparency = 0.5}):Play()
    task.wait(0.2)
    TweenService:Create(Logo, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 80, 0, 80), Position = UDim2.new(0.5, -40, 0, 70)
    }):Play()

    task.spawn(function()
        while Logo.Parent and LS.Parent do
            TweenService:Create(LStr, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0}):Play()
            task.wait(0.7)
            TweenService:Create(LStr, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.5}):Play()
            task.wait(0.7)
        end
    end)

    task.wait(0.4)
    TweenService:Create(LTitle, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.12)
    TweenService:Create(LSub, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.1)
    TweenService:Create(LStat, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LPct, TweenInfo.new(0.3), {TextTransparency = 0}):Play()

    local stages = {
        {0.12, "Core engine...", 0.18},
        {0.25, "UI framework...", 0.16},
        {0.40, "Sidebar + tabs...", 0.18},
        {0.55, "ESP module...", 0.14},
        {0.68, "Combat system...", 0.16},
        {0.80, "Boombox engine...", 0.14},
        {0.90, "Anti-detection...", 0.18},
        {1.00, "> Ready", 0.12},
    }

    for _, s in ipairs(stages) do
        TweenService:Create(PF, TweenInfo.new(s[3], Enum.EasingStyle.Quad), {
            Size = UDim2.new(s[1], 0, 1, 0)
        }):Play()
        LStat.Text = s[2]
        LPct.Text = math.floor(s[1] * 100) .. "%"
        task.wait(s[3] + 0.03)
    end

    LStat.TextColor3 = C.green; LPct.TextColor3 = C.green
    task.wait(0.35)

    for _, ch in ipairs(LC:GetDescendants()) do
        if ch:IsA("TextLabel") then TweenService:Create(ch, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        elseif ch:IsA("Frame") then
            TweenService:Create(ch, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
            local st = ch:FindFirstChildOfClass("UIStroke")
            if st then TweenService:Create(st, TweenInfo.new(0.3), {Transparency = 1}):Play() end
        elseif ch:IsA("ImageLabel") then TweenService:Create(ch, TweenInfo.new(0.3), {ImageTransparency = 1}):Play() end
    end
    TweenService:Create(LS, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
    task.wait(0.5)
    LS:Destroy()
end

DoLoad()

