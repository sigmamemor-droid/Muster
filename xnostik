RunService.RenderStepped:Connect(function()
    for obj, data in pairs(ESPManager.PlayerCache) do
        if not obj or not obj.Character or not obj.Character.Head then
            data.HL.Enabled, data.Bill.Enabled = false, false
            continue
        end
        local role, color = ESPManager:GetRole(obj)
        local show = State.PlayerESP and ((role=="MURDERER" and State.MurdererESP) or (role=="SHERIFF" and State.SheriffESP) or (role=="INNOCENT" and State.InnocentESP))
        data.HL.Enabled, data.Bill.Enabled = show, show
        if show then
            data.Bill.Adornee = obj.Character.Head
            data.HL.Parent = obj.Character
            data.Label.TextColor3 = color
        end
    end
    for item, data in pairs(ESPManager.ItemCache) do
        if item and data then
            local show = (data.Type == "Gun" and State.GunESP) or (data.Type == "Coin" and State.CoinESP)
            data.HL.Enabled, data.Bill.Enabled = show, show
        end
    end
    if FOV_Circle then
        FOV_Circle.Visible = State.SilentAim and State.ShowFOV
        if FOV_Circle.Visible then
            FOV_Circle.Radius = State.FOV
            FOV_Circle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        end
    end
    if State.Noclip and LP.Character then
        for _, part in ipairs(LP.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end
    if State.Fly and LP.Character and LP.Character.HumanoidRootPart then
        local root, hum = LP.Character.HumanoidRootPart, LP.Character.Humanoid
        hum.PlatformStand = true
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.yAxis end
        if dir.Magnitude > 0 then root.CFrame = root.CFrame + dir.Unit * State.FlySpeed / 10 end
    end
    if State.Chams then
        for p, data in pairs(ESPManager.PlayerCache) do
            if p.Character then
                for _, part in ipairs(p.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        pcall(function() part.Color = Color3.fromHSV((tick()/5)%1, 1, 1) end)
                    end
                end
            end
        end
    end
end)

