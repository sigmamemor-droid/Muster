    local tBG = Instance.new("Frame")
    tBG.Size            = UDim2.new(0, 36, 0, 18)
    tBG.Position        = UDim2.new(1, -48, 0.5, -9)
    tBG.BackgroundColor3 = active and C.green or C.textMuted
    tBG.BorderSizePixel = 0
    tBG.Parent          = btn
    Instance.new("UICorner", tBG).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame")
    circle.Size            = UDim2.new(0, 14, 0, 14)
    circle.Position        = active and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
    circle.BackgroundColor3 = C.white
    circle.BorderSizePixel = 0
    circle.Parent          = tBG
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local function Refresh()
        QuickTween(btn,     0.2, {BackgroundColor3 = active and C.greenDark or C.elevated}):Play()
        QuickTween(ind,     0.2, {BackgroundColor3 = active and C.green or C.textMuted}):Play()
        QuickTween(tBG,     0.2, {BackgroundColor3 = active and C.green or C.textMuted}):Play()
        TweenService:Create(circle, TweenInfo.new(0.2, Enum.EasingStyle.Back), {
            Position = active and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
        }):Play()
        QuickTween(bStroke, 0.2, {
            Color = active and C.green or C.elevated,
            Transparency = active and 0.5 or 1
        }):Play()
    end

    btn.MouseEnter:Connect(function()
        if not active then QuickTween(btn, 0.15, {BackgroundColor3 = C.card}):Play() end
    end)
    btn.MouseLeave:Connect(function()
        if not active then QuickTween(btn, 0.15, {BackgroundColor3 = C.elevated}):Play() end
    end)

    btn.MouseButton1Click:Connect(function()
        active = not active
        Refresh()
        callback(active, btn)
    end)

    return
        function() return active end,
        function(s) if active == s then return end; active = s; Refresh() end
end

