--// Функции ESP
local function CreateESP(player)
    local bill = Instance.new("BillboardGui")
    bill.Name = "MM2ESP"
    bill.AlwaysOnTop = true
    bill.Size = UDim2.new(0, 220, 0, 80)
    bill.StudsOffset = Vector3.new(0, 5, 0)
    bill.Adornee = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    local text = Instance.new("TextLabel", bill)
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.TextStrokeTransparency = 0.4
    text.RichText = true

    local highlight = Instance.new("Highlight", player.Character)
    highlight.FillTransparency = 0.65
    highlight.OutlineTransparency = 0.1

    return {Billboard = bill, Text = text, Highlight = highlight}
end

local function GetRole(plr)
    if not plr.Character then return "Unknown", Color3.fromRGB(200,200,200) end
    local char, bp = plr.Character, plr.Backpack
    if char:FindFirstChild("Knife") or bp:FindFirstChild("Knife") then
        return "🔪 Murderer", Color3.fromRGB(255, 0, 0)
    elseif char:FindFirstChild("Gun") or bp:FindFirstChild("Gun") then
        return "🔫 Sheriff", Color3.fromRGB(0, 125, 255)
    end
    return "Innocent", Color3.fromRGB(0, 255, 100)
end

-- Основной ESP Loop
RunService.RenderStepped:Connect(function()
    if not ESPSettings.Enabled then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then continue end

        if not Connections[plr] then
            Connections[plr] = CreateESP(plr)
        end

        local data = Connections[plr]
        local role, color = GetRole(plr)
        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - plr.Character.HumanoidRootPart.Position).Magnitude

        local shouldShow = (role:find("Murderer") and ESPSettings.Murderer) or 
                          (role:find("Sheriff") and ESPSettings.Sheriff) or 
                          (role:find("Innocent") and ESPSettings.Innocent)

        data.Billboard.Enabled = shouldShow
        data.Highlight.Enabled = shouldShow

        if shouldShow then
            data.Text.TextColor3 = color
            data.Highlight.FillColor = color
            data.Highlight.OutlineColor = color
            data.Text.Text = string.format("%s\n<b>%s</b>\n%.0f studs", plr.Name, role, dist)
        end
    end
end)

-- Gun + Coin ESP
RunService.Heartbeat:Connect(function()
    if not ESPSettings.Guns and not ESPSettings.Coins then return end

    for _, obj in pairs(Workspace:GetDescendants()) do
        if (obj.Name == "Gun" or obj.Name == "Coin") and not GunESPTable[obj] then
            local color = obj.Name == "Gun" and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(0, 255, 255)
            local highlight = Instance.new("Highlight")
            highlight.FillColor = color
            highlight.OutlineColor = color
            highlight.FillTransparency = 0.5
            highlight.Parent = obj

            local bill = Instance.new("BillboardGui", obj)
            bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0, 140, 0, 50)

            local label = Instance.new("TextLabel", bill)
            label.Size = UDim2.new(1,0,1,0)
            label.BackgroundTransparency = 1
            label.Text = obj.Name == "Gun" and "🔫 GUN" or "🪙 COIN"
            label.TextColor3 = color
            label.TextStrokeTransparency = 0
            label.Font = Enum.Font.GothamBold
            label.TextScaled = true

            GunESPTable[obj] = true
        end
    end
end)

-- Silent Aim с предикшеном
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if CombatSettings.SilentAim and method == "FireServer" and (self.Name == "ShootGun" or self.Name:find("Gun")) then
        local target = nil
        local closestDist = CombatSettings.FOV
        local mousePos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
                local pos, onScreen = Camera:WorldToViewportPoint(plr.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        target = plr
                    end
                end
            end
        end

        if target and target.Character and target.Character:FindFirstChild("Head") then
            local head = target.Character.Head
            args[2] = head.Position + (head.Velocity * CombatSettings.Prediction)
            return OldNamecall(self, unpack(args))
        end
    end
    return OldNamecall(self, ...)
end)

-- Kill All (Aura)
task.spawn(function()
    while wait(0.15) do
        if CombatSettings.KillAll and LocalPlayer.Character and LocalPlayer.Backpack:FindFirstChild("Knife") or 
           (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Knife")) then
            
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local myRoot = LocalPlayer.Character.HumanoidRootPart
                    local theirRoot = plr.Character.HumanoidRootPart
                    
                    if (myRoot.Position - theirRoot.Position).Magnitude <= CombatSettings.KillAuraRange then
                        game.ReplicatedStorage.Remotes.Gameplay.KnifeHit:FireServer(plr.Character)
                    end
                end
            end
        end
    end
end)

-- Movement (Speed, Fly, Noclip)
local flyVelocity = Vector3.new(0,0,0)
RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = LocalPlayer.Character.HumanoidRootPart
    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")

    if MovementSettings.Speed > 16 and hum then
        hum.WalkSpeed = MovementSettings.Speed
    end
    if MovementSettings.JumpPower > 50 and hum then
        hum.JumpPower = MovementSettings.JumpPower
    end

    if MovementSettings.Fly then
        flyVelocity = Vector3.new(0,0,0)
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then flyVelocity = flyVelocity + Camera.CFrame.LookVector end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then flyVelocity = flyVelocity - Camera.CFrame.LookVector end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then flyVelocity = flyVelocity - Camera.CFrame.RightVector end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then flyVelocity = flyVelocity + Camera.CFrame.RightVector end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then flyVelocity = flyVelocity + Vector3.new(0,1,0) end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftControl) then flyVelocity = flyVelocity - Vector3.new(0,1,0) end
        
        root.Velocity = flyVelocity * 50
    end
end)

-- Noclip
local noclipConn
local function toggleNoclip(state)
    if state then
        noclipConn = RunService.Stepped:Connect(function()
            if LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if noclipConn then noclipConn:Disconnect() end
    end
end

