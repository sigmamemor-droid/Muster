-- 1. Smooth Aimbot with FOV & Lerp
local aimbotActive = false
local aimSmoothing = 0.15
local aimFOV = 120

MkToggle(Hub, L[currentLang].aimbot, false, function(a)
    aimbotActive = a
    ClearConn("aimbot")
    if a then
        Conn("aimbot", RunService.RenderStepped:Connect(function()
            local root = GetRoot()
            if not root then return end
            
            local closestHead, closestDist = nil, aimFOV
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and IsMurderer(p) then
                    local head = p.Character:FindFirstChild("Head")
                    if head then
                        local screenPos, onScreen = camera:WorldToScreenPoint(head.Position)
                        if onScreen then
                            local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)).Magnitude
                            if dist < closestDist then
                                closestHead = head
                                closestDist = dist
                            end
                        end
                    end
                end
            end
            
            if closestHead then
                local targetCF = CFrame.new(camera.CFrame.Position, closestHead.Position)
                camera.CFrame = camera.CFrame:Lerp(targetCF, aimSmoothing)
            end
        end))
    end
end)

-- 2. Advanced ESP (Highlight + Billboard Name/Distance)
local espActive = false
local espObjects = {}

local function ClearESP()
    for _, obj in pairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
end

local function ApplyESP(p)
    if p == player or not p.Character then return end
    local char = p.Character
    
    -- Highlight
    local hl = Instance.new("Highlight")
    hl.FillColor = IsMurderer(p) and Color3.fromRGB(255, 50, 50) or (IsSheriff(p) and Color3.fromRGB(50, 150, 255) or Color3.fromRGB(50, 255, 100))
    hl.FillTransparency = 0.6
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.Adornee = char
    hl.Parent = char
    table.insert(espObjects, hl)

    -- BillboardGui for Info
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 100, 0, 40)
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop = true
    bb.Adornee = char:FindFirstChild("Head")
    bb.Parent = char
    table.insert(espObjects, bb)

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(1, 0, 0, 20)
    nameLbl.BackgroundTransparency = 1
    nameLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLbl.TextStrokeTransparency = 0.5
    nameLbl.TextSize = 14
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.Text = p.DisplayName
    nameLbl.Parent = bb

    local distLbl = Instance.new("TextLabel")
    distLbl.Size = UDim2.new(1, 0, 0, 20)
    distLbl.Position = UDim2.new(0, 0, 0, 20)
    distLbl.BackgroundTransparency = 1
    distLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLbl.TextStrokeTransparency = 0.5
    distLbl.TextSize = 12
    distLbl.Font = Enum.Font.Gotham
    distLbl.Parent = bb

    -- Update distance loop
    local conn = RunService.Heartbeat:Connect(function()
        if not bb.Parent or not GetRoot() then conn:Disconnect() return end
        local dist = math.floor((char:FindFirstChild("HumanoidRootPart").Position - GetRoot().Position).Magnitude)
        distLbl.Text = dist .. "m"
    end)
    table.insert(espObjects, conn)
end

MkToggle(Hub, L[currentLang].esp_names, false, function(a)
    espActive = a
    ClearESP()
    ClearConn("esp_update")
    if a then
        for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
        Conn("esp_update", Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function() task.wait(0.5); ApplyESP(p) end)
        end))
    end
end)

-- 3. Optimized Fly with Speed Integration
local flySpeed = 50
MkSlider(Hub, L[currentLang].fly .. " Speed", 20, 150, 50, function(v) flySpeed = v end)

local flyActive = false
MkToggle(Hub, L[currentLang].fly, false, function(a)
    flyActive = a
    ClearConn("fly")
    local root = GetRoot()
    local hum = GetHum()
    
    if a and root and hum then
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bv.Velocity = Vector3.zero
        bv.Parent = root
        
        local bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        bg.P = 1e4
        bg.Parent = root
        
        hum.PlatformStand = true
        
        Conn("fly", RunService.RenderStepped:Connect(function()
            if not flyActive or not root.Parent then return end
            bg.CFrame = camera.CFrame
            local dir = camera.CFrame:VectorToWorldSpace(hum.MoveDirection)
            if hum.MoveDirection == Vector3.zero then
                bv.Velocity = Vector3.zero
            else
                bv.Velocity = dir.Unit * flySpeed
            end
        end))
    else
        if hum then hum.PlatformStand = false end
        if root then
            for _, inst in ipairs(root:GetChildren()) do
                if inst:IsA("BodyVelocity") or inst:IsA("BodyGyro") then inst:Destroy() end
            end
        end
    end
end)

