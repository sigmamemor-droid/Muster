local function GetChar() return player.Character end
local function GetHum() local c = GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function IsMurderer(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) ~= nil
end
local function IsSheriff(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil
end

local function GetMurdererRoot()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p.Character.HumanoidRootPart
        end
    end
    return nil
end
local function GetMurdererHead()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild("Head") then
            return p.Character.Head
        end
    end
    return nil
end
local function GetSheriffRoot()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsSheriff(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p.Character.HumanoidRootPart
        end
    end
    return nil
end

local function GetTool(n)
    local c = GetChar()
    if c and c:FindFirstChild(n) then return c:FindFirstChild(n) end
    if player.Backpack and player.Backpack:FindFirstChild(n) then return player.Backpack:FindFirstChild(n) end
    return nil
end
local function FindGunInHand()
    local c = GetChar(); if not c then return nil end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver")) then return t end
    end
    return nil
end
local function FindKnifeInHand()
    local c = GetChar(); if not c then return nil end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find("knife") then return t end
    end
    return nil
end

local function FireGunAtTarget(gun, target)
    if not gun or not target then return false end
    for _, r in ipairs(gun:GetDescendants()) do
        if r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(target.Position, target) end)
            return true
        end
    end
    return false
end
local function ThrowKnifeAtTarget(knife, target)
    if not knife or not target then return false end
    for _, r in ipairs(knife:GetDescendants()) do
        if r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(target) end)
            return true
        end
    end
    return false
end

-- NEW: Find nearest coin by distance
local function FindNearestCoin(rootPart)
    local nearest, nearestDist = nil, math.huge
    local normal = workspace:FindFirstChild("Normal")
    if not normal then return nil end
    local containers = {normal:FindFirstChild("CoinContainer"), normal:FindFirstChild("Coins")}
    for _, container in ipairs(containers) do
        if container then
            for _, coin in ipairs(container:GetChildren()) do
                if coin:IsA("BasePart") and (coin.Name:match("Coin") or coin.Name:match("coin")) then
                    local dist = (coin.Position - rootPart.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = coin
                    end
                end
            end
        end
    end
    -- Also search workspace directly
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("BasePart") and obj.Name:match("Coin") then
            local dist = (obj.Position - rootPart.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearest = obj
            end
        end
    end
    return nearest
end

-- NEW: Get all players sorted by distance
local function GetPlayersByDistance(rootPart)
    local sorted = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
            table.insert(sorted, {player = p, dist = dist})
        end
    end
    table.sort(sorted, function(a, b) return a.dist < b.dist end)
    return sorted
end

