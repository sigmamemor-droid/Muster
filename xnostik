local function SetESP(targetPlayer, color)
    if targetPlayer == player then return end
    local function apply(char)
        if not char then return end
        pcall(function()
            if char:FindFirstChild("idkESP") then char.idkESP:Destroy() end
            local h = Instance.new("Highlight")
            h.Name = "idkESP"
            h.FillColor = color
            h.FillTransparency = 0.55
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
            h.OutlineTransparency = 0.4
            h.Adornee = char
            h.Parent = char
        end)
    end
    pcall(function()
        if targetPlayer.Character then apply(targetPlayer.Character) end
    end)
    local conn = targetPlayer.CharacterAdded:Connect(function(c)
        task.wait(0.5)
        apply(c)
    end)
    table.insert(espConns, conn)
end

