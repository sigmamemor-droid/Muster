    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
    end)
    
    while Gui.Parent do
        task.wait(1)
        pcall(function()
            -- FPS
            local now = tick()
            local elapsed = now - lastTime
            local fps = math.floor(frameCount / elapsed)
            frameCount = 0
            lastTime = now
            fpsLabel.Text = "FPS: " .. fps
            
            -- Ping
            local ping = math.floor(player:GetNetworkPing() * 1000)
            pingLabel.Text = "Ping: " .. ping .. "ms"
            
            -- Player count
            playerCountLabel.Text = "Players: " .. #Players:GetPlayers() .. "/" .. Players.MaxPlayers
            
            -- Roles
            local myRole = "Innocent"
            local bp = player:FindFirstChild("Backpack")
            local char = player.Character
            if (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) then
                myRole = "Murderer 🔪"
                myRoleLabel.TextColor3 = P.Red
            elseif (char and char:FindFirstChild("Gun")) or (bp and bp:FindFirstChild("Gun")) then
                myRole = "Sheriff 🔫"
                myRoleLabel.TextColor3 = P.Blue
            else
                myRoleLabel.TextColor3 = P.Green
            end
            myRoleLabel.Text = "Your Role: " .. myRole
            
            -- Murderer name
            local foundMurderer = false
            local foundSheriff = false
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player then
                    pcall(function()
                        local hasMurderer = (p.Character and p.Character:FindFirstChild("Knife"))
                            or (p:FindFirstChild("Backpack") and p.Backpack:FindFirstChild("Knife"))
                        local hasSheriff = (p.Character and p.Character:FindFirstChild("Gun"))
                            or (p:FindFirstChild("Backpack") and p.Backpack:FindFirstChild("Gun"))
                        
                        if hasMurderer then
                            murdererLabel.Text = "Murderer: " .. p.DisplayName
                            murdererLabel.TextColor3 = P.Red
                            foundMurderer = true
                        end
                        if hasSheriff then
                            sheriffLabel.Text = "Sheriff: " .. p.DisplayName
                            sheriffLabel.TextColor3 = P.Blue
                            foundSheriff = true
                        end
                    end)
                end
            end
            if not foundMurderer then
                murdererLabel.Text = "Murderer: not found"
                murdererLabel.TextColor3 = P.TextMuted
            end
            if not foundSheriff then
                sheriffLabel.Text = "Sheriff: not found"
                sheriffLabel.TextColor3 = P.TextMuted
            end
        end)
    end
end)

