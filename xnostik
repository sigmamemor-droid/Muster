local flyOn = false
MkToggle("Home", "fly", false, function(a)
    flyOn = a; ClearConn("fly")
    local r = GetRoot(); local h = GetHum()
    if a and r and h then
        local bv = Instance.new("BodyVelocity"); bv.Name = "lz_fly_bv"; bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(1e9,1e9,1e9); bv.Parent = r
        local bg = Instance.new("BodyGyro"); bg.Name = "lz_fly_bg"; bg.MaxTorque = Vector3.new(1e9,1e9,1e9); bg.P = 9000; bg.Parent = r
        h.PlatformStand = true
        Conn("fly", RunService.RenderStepped:Connect(function()
            if not flyOn or not r or not bv or not bv.Parent then return end
            local cf = camera.CFrame
            local moveVec = h.MoveDirection
            local flySpeed = 65
            -- Horizontal movement from joystick
            local worldDir = cf:VectorToWorldSpace(moveVec)
            if worldDir.Magnitude > 0 then worldDir = worldDir.Unit end
            -- Vertical: camera up vector if looking up/down
            local vert = 0
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vert = 1 elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vert = -1 end
            -- Mobile: use camera look direction Y component
            local camLookY = cf.LookVector.Y
            if moveVec.Magnitude > 0.1 then vert = vert + camLookY * 0.5 end
            bv.Velocity = Vector3.new(worldDir.X * flySpeed, vert * flySpeed, worldDir.Z * flySpeed)
            bg.CFrame = cf
        end))
    else
        if h then h.PlatformStand = false end
        pcall(function()
            if r then
                local bv = r:FindFirstChild("lz_fly_bv"); if bv then bv:Destroy() end
                local bg = r:FindFirstChild("lz_fly_bg"); if bg then bg:Destroy() end
