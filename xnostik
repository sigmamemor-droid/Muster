-- Aimbot
local aimbotEnabled = false
local aimbotTarget = nil

MainSection:NewToggle("🎯 Aimbot (Авто-прицел)", "Автоматически наводится на убийцу", function(state)
    aimbotEnabled = state
    if state then
        spawn(function()
            while aimbotEnabled do
                local closest = nil
                local shortestDistance = math.huge
                
                for _, player in pairs(game.Players:GetPlayers()) do
                    if player ~= game.Players.LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                        -- Проверка, является ли игрок убийцей (по ножу в руке)
                        local hasKnife = false
                        for _, tool in pairs(player.Character:GetChildren()) do
                            if tool:IsA("Tool") and (tool.Name:lower():find("knife") or tool.Name:lower():find("godly") or tool.Name:lower():find("ancients")) then
                                hasKnife = true
                                break
                            end
                        end
                        
                        if hasKnife then
                            local distance = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                            if distance < shortestDistance then
                                shortestDistance = distance
                                closest = player
                            end
                        end
                    end
                end
                
                if closest and closest.Character and closest.Character:FindFirstChild("Head") then
                    local cam = workspace.CurrentCamera
                    cam.CFrame = CFrame.new(cam.CFrame.Position, closest.Character.Head.Position)
                end
                task.wait(0.05)
            end
        end)
    end
end)

-- Auto Shoot
MainSection:NewToggle("🔫 Auto Shoot", "Автоматически стреляет при наведении", function(state)
    getgenv().AutoShoot = state
    if state then
        spawn(function()
            while getgenv().AutoShoot do
                if aimbotEnabled and aimbotTarget then
                    local args = {
                        [1] = "Shoot",
                        [2] = aimbotTarget.Character.Head.Position
                    }
                    game:GetService("ReplicatedStorage"):FindFirstChild("ShootEvent"):FireServer(unpack(args))
                end
                task.wait(0.1)
            end
        end)
    end
end)

-- God Mode
local godModeEnabled = false
MainSection:NewToggle("🛡 God Mode", "Неуязвимость (невозможно умереть)", function(state)
    godModeEnabled = state
    if state then
        spawn(function()
            while godModeEnabled do
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.Health = 100
                    char.Humanoid.MaxHealth = 99999
                    
                    -- Отключение урона
                    for _, part in pairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
                task.wait(0.01)
            end
        end)
    end
end)

-- Speed Hack
MainSection:NewSlider("⚡ Скорость", "Множитель скорости", 100, 16, function(value)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = value
    end
end)

-- ==================== ВИЗУАЛЫ ====================
local VisualSection = VisualTab:NewSection("ESP и визуалы")

-- Player ESP
VisualSection:NewToggle("👤 ESP Игроков", "Показывает всех игроков через стены", function(state)
    if state then
        spawn(function()
            while state do
                for _, player in pairs(game.Players:GetPlayers()) do
                    if player ~= game.Players.LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                        if not player.Character.Head:FindFirstChild("ESP_Label") then
                            local BillboardGui = Instance.new("BillboardGui")
                            local TextLabel = Instance.new("TextLabel")
                            
                            BillboardGui.Name = "ESP_Label"
                            BillboardGui.Adornee = player.Character.Head
                            BillboardGui.Size = UDim2.new(0, 100, 0, 50)
                            BillboardGui.StudsOffset = Vector3.new(0, 2, 0)
                            BillboardGui.AlwaysOnTop = true
                            
                            TextLabel.Size = UDim2.new(1, 0, 1, 0)
                            TextLabel.BackgroundTransparency = 1
                            TextLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                            TextLabel.TextStrokeTransparency = 0
                            TextLabel.Text = player.Name
                            
                            TextLabel.Parent = BillboardGui
                            BillboardGui.Parent = player.Character.Head
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    else
        for _, player in pairs(game.Players:GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("Head") then
                local esp = player.Character.Head:FindFirstChild("ESP_Label")
                if esp then esp:Destroy() end
            end
        end
    end
end)

-- Chams
VisualSection:NewToggle("🎨 Chams", "Подсветка игроков цветом", function(state)
    if state then
        spawn(function()
            while state do
                for _, player in pairs(game.Players:GetPlayers()) do
                    if player.Character then
                        for _, part in pairs(player.Character:GetChildren()) do
                            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                                part.Material = Enum.Material.ForceField
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end)

-- ==================== ФАРМ ====================
local FarmSection = FarmTab:NewSection("Автоматический фарм")

FarmSection:NewToggle("🪙 Auto Collect", "Авто-сбор монет", function(state)
    if state then
        spawn(function()
            while state do
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    for _, obj in pairs(workspace:GetDescendants()) do
                        if obj.Name == "Coin" or obj.Name == "Coin_Server" then
                            char.HumanoidRootPart.CFrame = obj.CFrame
                            task.wait(0.1)
                        end
                    end
                end
                task.wait(1)
            end
        end)
    end
end)

FarmSection:NewToggle("💎 Auto Farm Boxes", "Авто-открытие коробок", function(state)
    if state then
        spawn(function()
            while state do
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    for _, obj in pairs(workspace:GetDescendants()) do
                        if obj.Name:lower():find("box") or obj.Name:lower():find("crate") then
                            char.HumanoidRootPart.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
                            task.wait(0.5)
                            -- Симуляция клика
                            fireproximityprompt(obj)
                        end
                    end
                end
                task.wait(3)
            end
        end)
    end
end)

