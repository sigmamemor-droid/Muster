-- Screen Shake Effect
local function triggerScreenShake(intensity)
    if not Config.ScreenShake then return end
    local originalCF = Camera.CFrame
    local shakeAmt = intensity or Config.ShakeIntensity
    
    task.spawn(function()
        for _ = 1, 5 do
            Camera.CFrame = originalCF * CFrame.new(
                (math.random(-100, 100) / 100) * shakeAmt,
                (math.random(-100, 100) / 100) * shakeAmt,
                0
            )
            task.wait(0.015)
        end
        Camera.CFrame = originalCF
    end)
end

-- Draw Hitmarker Screen Indicators
local function drawHitmarker()
    for _, drawing in ipairs(Hitmarker_Drawings) do
        pcall(function() drawing:Remove() end)
    end
    Hitmarker_Drawings = {}
    
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local length = 15
    local thickness = 2.5
    local color = Color3.fromRGB(255, 50, 50)
    
    local line1 = Drawing.new("Line")
    line1.From = center + Vector2.new(-length, -length)
    line1.To = center + Vector2.new(length, length)
    line1.Color = color
    line1.Thickness = thickness
    line1.Visible = true
    table.insert(Hitmarker_Drawings, line1)
    
    local line2 = Drawing.new("Line")
    line2.From = center + Vector2.new(length, -length)
    line2.To = center + Vector2.new(-length, length)
    line2.Color = color
    line2.Thickness = thickness
    line2.Visible = true
    table.insert(Hitmarker_Drawings, line2)
    
    LastHitmarkerTime = tick()
end

local function updateHitmarkerTransparency()
    if #Hitmarker_Drawings == 0 then return end
    local elapsed = tick() - LastHitmarkerTime
    local duration = 0.35
    
    if elapsed > duration then
        for _, drawing in ipairs(Hitmarker_Drawings) do
            pcall(function() drawing:Remove() end)
        end
        Hitmarker_Drawings = {}
    else
        local alpha = 1 - (elapsed / duration)
        for _, drawing in ipairs(Hitmarker_Drawings) do
            drawing.Transparency = alpha
        end
    end
end

-- Initialize Health Monitors
local function initHealthMonitor()
    local lastHealth = {}
    RunService.RenderStepped:Connect(function()
        if not Config.HitMarker then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if player.Character then
                local hum = player.Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    local current = hum.Health
                    local last = lastHealth[player.Name] or hum.MaxHealth
                    if current < last and current > 0 then
                        drawHitmarker()
                        if Config.ScreenShake then
                            triggerScreenShake(Config.ShakeIntensity)
                        end
                    end
                    lastHealth[player.Name] = current
                end
            end
        end
    end)
    
    Players.PlayerRemoving:Connect(function(plr)
        lastHealth[plr.Name] = nil
    end)
end
task.spawn(initHealthMonitor)

-- Healthbar Drawing Setup
local function clearHealthbar(player)
    if Health_Bars[player] then
        pcall(function()
            Health_Bars[player].bg:Remove()
            Health_Bars[player].fill:Remove()
        end)
        Health_Bars[player] = nil
    end
end

local function createHealthbar(player)
    clearHealthbar(player)
    
    local bg = Drawing.new("Square")
    bg.Filled = true
    bg.Color = Color3.fromRGB(0, 0, 0)
    bg.Transparency = 0.6
    bg.Visible = false
    
    local fill = Drawing.new("Square")
    fill.Filled = true
    fill.Visible = false
    
    Health_Bars[player] = { bg = bg, fill = fill }
end

local function drawHealthbars()
    for player, drawings in pairs(Health_Bars) do
        drawings.bg.Visible = false
        drawings.fill.Visible = false
    end
    
    if not Config.HealthBarESP then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        if not hum or not head then continue end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
        if not onScreen then continue end
        
        local elements = Health_Bars[player]
        if not elements then
            createHealthbar(player)
            elements = Health_Bars[player]
        end
        
        local pct = hum.Health / hum.MaxHealth
        local width = 42
        local height = 5
        
        elements.bg.Position = Vector2.new(screenPos.X - (width / 2), screenPos.Y - 15)
        elements.bg.Size = Vector2.new(width, height)
        elements.bg.Visible = true
        
        elements.fill.Position = Vector2.new(screenPos.X - (width / 2), screenPos.Y - 15)
        elements.fill.Size = Vector2.new(width * pct, height)
        elements.fill.Color = (pct > 0.5 and Color3.fromRGB(0, 255, 100)) or (pct > 0.25 and Color3.fromRGB(255, 200, 0)) or Color3.fromRGB(255, 50, 50)
        elements.fill.Visible = true
    end
end

-- ESP Drawing Core
local function createESP(player)
    if player == LocalPlayer then return end
    if ESP_Cache[player] then return end
    
    ESP_Cache[player] = {
        boxFill = Drawing.new("Square"),
        boxOutline = Drawing.new("Square"),
        tracer = Drawing.new("Line"),
        text = Drawing.new("Text")
    }
end

local function removeESP(player)
    if ESP_Cache[player] then
        pcall(function()
            ESP_Cache[player].boxFill:Remove()
            ESP_Cache[player].boxOutline:Remove()
            ESP_Cache[player].tracer:Remove()
            ESP_Cache[player].text:Remove()
        end)
        ESP_Cache[player] = nil
    end
end

local function updateESP()
    for _, drawings in pairs(ESP_Cache) do
        drawings.boxFill.Visible = false
        drawings.boxOutline.Visible = false
        drawings.tracer.Visible = false
        drawings.text.Visible = false
    end
    
    if not Config.ESP then return end
    
    local selfChar = LocalPlayer.Character
    if not selfChar then return end
    local selfHRP = selfChar:FindFirstChild("HumanoidRootPart")
    if not selfHRP then return end
    
    local customColor = getColor(Config.ESPBoxColor)
    
    for player, drawings in pairs(ESP_Cache) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        
        local head = char:FindFirstChild("Head")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not head or not hrp then continue end
        
        local dist = (hrp.Position - selfHRP.Position).Magnitude
        if dist > 1500 then continue end
        
        if Config.ESPBox then
            local topPos, topOnScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            local bottomPos, bottomOnScreen = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
            if topOnScreen and bottomOnScreen then
                local height = math.abs(topPos.Y - bottomPos.Y)
                local width = height * 0.4
                
                drawings.boxOutline.Position = Vector2.new(bottomPos.X - (width / 2), topPos.Y)
                drawings.boxOutline.Size = Vector2.new(width, height)
                drawings.boxOutline.Color = customColor
                drawings.boxOutline.Thickness = 1
                drawings.boxOutline.Visible = true
            end
        end
        
        if Config.ESPTracer then
            local bottomPos, bottomOnScreen = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
            if bottomOnScreen then
                drawings.tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                drawings.tracer.To = Vector2.new(bottomPos.X, bottomPos.Y)
                drawings.tracer.Color = customColor
                drawings.tracer.Thickness = 1
                drawings.tracer.Visible = true
            end
        end
        
        if Config.ESPName or Config.ESPDistance then
            local content = ""
            if Config.ESPName then content = player.Name end
            if Config.ESPDistance then content = content .. " [" .. math.floor(dist) .. "m]" end
            
            local bottomPos, bottomOnScreen = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
            if bottomOnScreen then
                drawings.text.Text = content
                drawings.text.Size = 13
                drawings.text.Center = true
                drawings.text.Outline = true
                drawings.text.Color = Color3.fromRGB(255, 255, 255)
                drawings.text.Position = Vector2.new(bottomPos.X, bottomPos.Y - 20)
                drawings.text.Visible = true
            end
        end
    end
end

-- Chams Configuration
local function createChams(player)
    if player == LocalPlayer then return end
    if Chams_Cache[player] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = Config.ChamsTransparency
    highlight.OutlineTransparency = 0.15
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillColor = getColor(Config.ChamsColor)
    highlight.Enabled = false
    Chams_Cache[player] = highlight
end

local function applyChamsSettings()
    for _, hl in pairs(Chams_Cache) do
        pcall(function()
            hl.FillTransparency = Config.ChamsTransparency
        end)
    end
end

local function drawChams()
    for player, hl in pairs(Chams_Cache) do
        if not player.Parent or not player.Character then
            hl.Enabled = false
            hl.Parent = nil
            continue
        end
        
        if not Config.RoleChams then
            hl.Enabled = false
            hl.Parent = nil
            continue
        end
        
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            hl.Enabled = false
            hl.Parent = nil
            continue
        end
        
        pcall(function()
            hl.Parent = player.Character
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillTransparency = Config.ChamsTransparency
            
            local isMur = player.Character:FindFirstChild("Knife") or (player:FindFirstChild("Backpack") and player.Backpack:FindFirstChild("Knife"))
            local isSher = player.Character:FindFirstChild("Gun") or (player:FindFirstChild("Backpack") and player.Backpack:FindFirstChild("Gun"))
            
            if Config.RoleChamsKeepRoles then
                if isMur then
                    hl.FillColor = Color3.fromRGB(255, 30, 30)
                elseif isSher then
                    hl.FillColor = Color3.fromRGB(30, 120, 255)
                else
                    hl.FillColor = getColor(Config.RoleChamsColor)
                end
            else
                if Config.RoleChamsColor ~= "Default" then
                    hl.FillColor = getColor(Config.RoleChamsColor)
                elseif isMur then
                    hl.FillColor = Color3.fromRGB(255, 30, 30)
                elseif isSher then
                    hl.FillColor = Color3.fromRGB(30, 120, 255)
                else
                    hl.FillColor = Color3.fromRGB(30, 255, 100)
                end
            end
            hl.Enabled = true
        end)
    end
end

-- Skeleton ESP Drawing
local function clearSkeletonDrawings()
    for _, line in ipairs(Skeleton_Drawings) do
        pcall(function() line:Remove() end)
    end
    Skeleton_Drawings = {}
end

local function handleSkeletonESP()
    clearSkeletonDrawings()
    if not Config.SkeletonESP then
        if SkeletonConnection then
            SkeletonConnection:Disconnect()
            SkeletonConnection = nil
        end
        return
    end
    
    if SkeletonConnection then return end
    
    SkeletonConnection = RunService.RenderStepped:Connect(function()
        if not Config.SkeletonESP then return end
        clearSkeletonDrawings()
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end
            local char = player.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end
            
            local head = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            local lArm = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm")
            local rArm = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm")
            local lLeg = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg")
            local rLeg = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")
            
            if head and torso then
                local clr = Color3.fromRGB(255, 255, 255)
                local function connectBones(p1, p2)
                    local scr1, vis1 = Camera:WorldToViewportPoint(p1.Position)
                    local scr2, vis2 = Camera:WorldToViewportPoint(p2.Position)
                    if vis1 and vis2 then
                        local boneLine = Drawing.new("Line")
                        boneLine.Visible = true
                        boneLine.From = Vector2.new(scr1.X, scr1.Y)
                        boneLine.To = Vector2.new(scr2.X, scr2.Y)
                        boneLine.Color = clr
                        boneLine.Thickness = 1.5
                        boneLine.Transparency = 0.7
                        table.insert(Skeleton_Drawings, boneLine)
                    end
                end
                
                connectBones(head, torso)
                if lArm then connectBones(torso, lArm) end
                if rArm then connectBones(torso, rArm) end
                if lLeg then connectBones(torso, lLeg) end
                if rLeg then connectBones(torso, rLeg) end
            end
        end
    end)
end

-- Active Trails Generation
local function addPlayerTrail(char)
    if not char or not Config.Trail then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp or Active_Trails[char] then return end
    
    local isBig = Config.TrailSize == "Big"
    local clr = getColor(Config.TrailColor)
    
