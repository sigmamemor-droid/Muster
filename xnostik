local function GetRole(p)
    if not p.Character then return "INNOCENT", C.Green end
    local c = p.Character
    local b = p.Backpack
    if c:FindFirstChild("Knife") or b:FindFirstChild("Knife") then return "MURDERER", C.Red end
    if c:FindFirstChild("Gun") or b:FindFirstChild("Gun") then return "SHERIFF", C.Accent end
    return "INNOCENT", C.Green
end

local function MakeESP(p)
    local bill = Instance.new("BillboardGui")
    bill.AlwaysOnTop = true
    bill.Size = UDim2.new(0, 170, 0, 70)
    bill.StudsOffset = Vector3.new(0, 3.5, 0)
    bill.Name = "PH_ESP"

    local bg = Instance.new("Frame", bill)
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundColor3 = Color3.fromRGB(10,16,35)
    bg.BackgroundTransparency = 0.2
    bg.BorderSizePixel = 0
    Corner(bg, 8)
    Stroke(bg, C.Divider, 1)

    local nm = NewLabel(bg, "", 12, Color3.fromRGB(255,255,255), Enum.Font.GothamBold)
    nm.Size = UDim2.new(1,-8,0,22)
    nm.Position = UDim2.new(0,4,0,4)
    nm.TextStrokeTransparency = 0.5

    local rl = NewLabel(bg, "", 11, C.Red, Enum.Font.GothamBold)
    rl.Size = UDim2.new(1,-8,0,18)
    rl.Position = UDim2.new(0,4,0,24)
    rl.TextStrokeTransparency = 0.5

    local inf = NewLabel(bg, "", 10, C.SubText, Enum.Font.Gotham)
    inf.Size = UDim2.new(1,-8,0,16)
    inf.Position = UDim2.new(0,4,0,44)

    local hl = Instance.new("Highlight")
    hl.FillTransparency = 0.7
    hl.OutlineTransparency = 0.1

    ESPObjs[p] = {Bill=bill, Name=nm, Role=rl, Info=inf, HL=hl}
end

local function CleanESP(p)
    if ESPObjs[p] then
        pcall(function() ESPObjs[p].Bill:Destroy() end)
        pcall(function() ESPObjs[p].HL:Destroy() end)
        ESPObjs[p] = nil
    end
end

Players.PlayerRemoving:Connect(CleanESP)

local function MakeObjESP(obj, col, txt)
    if ObjESPT[obj] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = col
    hl.OutlineColor = col
    hl.FillTransparency = 0.55
    hl.OutlineTransparency = 0.15
    hl.Parent = obj

    local bill = Instance.new("BillboardGui", obj)
    bill.AlwaysOnTop = true
    bill.Size = UDim2.new(0, 100, 0, 32)
    bill.StudsOffset = Vector3.new(0, 3.5, 0)

    local bg = Instance.new("Frame", bill)
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundColor3 = Color3.fromRGB(10,16,35)
    bg.BackgroundTransparency = 0.25
    bg.BorderSizePixel = 0
    Corner(bg, 6)

    local lbl = NewLabel(bg, txt, 11, col, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
    lbl.Size = UDim2.new(1,0,1,0)
    lbl.TextStrokeTransparency = 0.5

    ObjESPT[obj] = {HL=hl, Bill=bill}
end

