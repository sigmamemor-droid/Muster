local function AddToggleButton(text, defaultState, callback)
    local order = NextOrder()
    local active = defaultState or false

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 0, 34)
    Btn.BackgroundColor3 = active and Colors.green or Colors.elevated
    Btn.Text = ""
    Btn.AutoButtonColor = false
    Btn.LayoutOrder = order
    Btn.Parent = ScrollHolder

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Btn

    -- Индикатор
    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 4, 0, 18)
    Indicator.Position = UDim2.new(0, 8, 0.5, -9)
    Indicator.BackgroundColor3 = active and Colors.green or Colors.textDim
    Indicator.BorderSizePixel = 0
    Indicator.Parent = Btn
    Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0)

    -- Текст
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 20, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Colors.text
    Label.TextSize = 13
    Label.Font = Enum.Font.GothamSemibold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Btn

    -- Статус
    local Status = Instance.new("TextLabel")
    Status.Size = UDim2.new(0, 40, 1, 0)
    Status.Position = UDim2.new(1, -48, 0, 0)
    Status.BackgroundTransparency = 1
    Status.Text = active and "ON" or "OFF"
    Status.TextColor3 = active and Colors.green or Colors.textDim
    Status.TextSize = 12
    Status.Font = Enum.Font.GothamBold
    Status.TextXAlignment = Enum.TextXAlignment.Right
    Status.Parent = Btn

    local function UpdateVisual()
        local targetBg = active and Color3.fromRGB(25, 50, 35) or Colors.elevated
        local targetInd = active and Colors.green or Colors.textDim
        TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = targetBg}):Play()
        TweenService:Create(Indicator, TweenInfo.new(0.15), {BackgroundColor3 = targetInd}):Play()
        Status.Text = active and "ON" or "OFF"
        Status.TextColor3 = active and Colors.green or Colors.textDim
    end

    Btn.MouseButton1Click:Connect(function()
        active = not active
        UpdateVisual()
        callback(active, Btn)
    end)

    if active then UpdateVisual() end

    return function() return active end, function(state)
        active = state
        UpdateVisual()
    end
end

