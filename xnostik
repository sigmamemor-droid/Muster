-- Слайдер (как на картинке — с красной точкой слева)
local function Slider(parent, text, min, max, default, suffix, callback)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -28, 0, 68)
    card.BackgroundColor3 = C.BG2
    card.BorderSizePixel = 0
    card.Parent = parent
    Corner(card, 10)
    Stroke(card, C.Divider, 1)

    local label = NewLabel(card, text, 13, C.Text, Enum.Font.GothamSemibold)
    label.Size = UDim2.new(0.7, 0, 0, 24)
    label.Position = UDim2.new(0, 18, 0, 6)

    local valLabel = NewLabel(card, tostring(default)..(suffix or "%"), 12, C.Accent2, Enum.Font.GothamBold,
        Enum.TextXAlignment.Right)
    valLabel.Size = UDim2.new(0.3, -18, 0, 24)
    valLabel.Position = UDim2.new(0.7, 0, 0, 6)

    -- Трек слайдера
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -36, 0, 4)
    track.Position = UDim2.new(0, 18, 0, 46)
    track.BackgroundColor3 = C.BG4
    track.BorderSizePixel = 0
    track.Parent = card
    Corner(track, 2)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255,255,255)
    fill.BorderSizePixel = 0
    fill.Parent = track
    Corner(fill, 2)
    Grad(fill, C.Red, Color3.fromRGB(230,230,255), 0)

    -- Кнопка (knob) — белый кружок
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new((default-min)/(max-min), 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 5
    knob.Parent = track
    Corner(knob, 8)

    -- Тень на кнопке
    local knobStroke = Stroke(knob, Color3.fromRGB(150,150,220), 1.5)

    local val = default
    local sliding = false

    local function Update(input)
        local rel = math.clamp(
            (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        val = math.floor(min + (max-min)*rel + 0.5)
        valLabel.Text = tostring(val) .. (suffix or "%")
        Tw(fill, {Size = UDim2.new(rel,0,1,0)}, 0.05)
        Tw(knob, {Position = UDim2.new(rel,0,0.5,0)}, 0.05)
        if callback then pcall(callback, val) end
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true; Update(i)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)

    card.MouseEnter:Connect(function() Tw(card, {BackgroundColor3 = C.BG3}, 0.15) end)
    card.MouseLeave:Connect(function() Tw(card, {BackgroundColor3 = C.BG2}, 0.15) end)

    return {GetValue = function() return val end}
end

-- Дропдаун (как "Default ▼" на картинке)
local function Dropdown(parent, text, options, default, callback)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -28, 0, 52)
    card.BackgroundColor3 = C.BG2
    card.BorderSizePixel = 0
    card.ClipsDescendants = false
    card.ZIndex = 10
    card.Parent = parent
    Corner(card, 10)
    Stroke(card, C.Divider, 1)

    local label = NewLabel(card, text, 13, C.Text, Enum.Font.GothamSemibold)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 18, 0, 0)
    label.ZIndex = 11

    local selBtn = Instance.new("TextButton")
    selBtn.Size = UDim2.new(0, 110, 0, 30)
    selBtn.Position = UDim2.new(1, -120, 0.5, -15)
    selBtn.BackgroundColor3 = C.BG4
    selBtn.Text = (default or options[1] or "—") .. "  ▼"
    selBtn.Font = Enum.Font.GothamSemibold
    selBtn.TextSize = 11
    selBtn.TextColor3 = C.Accent2
    selBtn.BorderSizePixel = 0
    selBtn.AutoButtonColor = false
    selBtn.ZIndex = 11
    selBtn.Parent = card
    Corner(selBtn, 7)
    Stroke(selBtn, C.Divider, 1)

    local opened = false
    local selected = default or options[1]

    local dropFrame = Instance.new("Frame")
    dropFrame.Size = UDim2.new(0, 110, 0, 0)
    dropFrame.Position = UDim2.new(1, -120, 1, 4)
    dropFrame.BackgroundColor3 = C.BG4
    dropFrame.BorderSizePixel = 0
    dropFrame.ClipsDescendants = true
    dropFrame.ZIndex = 20
    dropFrame.Visible = false
    dropFrame.Parent = card
    Corner(dropFrame, 8)
    Stroke(dropFrame, C.Divider, 1)

    local dropLayout = Instance.new("UIListLayout")
    dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
    dropLayout.Parent = dropFrame

    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 30)
        optBtn.BackgroundColor3 = C.BG4
        optBtn.Text = opt
        optBtn.Font = Enum.Font.Gotham
        optBtn.TextSize = 11
        optBtn.TextColor3 = opt == selected and C.Accent2 or C.Text
        optBtn.BorderSizePixel = 0
        optBtn.AutoButtonColor = false
        optBtn.ZIndex = 21
        optBtn.Parent = dropFrame

        optBtn.MouseEnter:Connect(function() Tw(optBtn, {BackgroundColor3 = C.BG3}, 0.1) end)
        optBtn.MouseLeave:Connect(function() Tw(optBtn, {BackgroundColor3 = C.BG4}, 0.1) end)
        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            selBtn.Text = opt .. "  ▼"
            opened = false
            Tw(dropFrame, {Size = UDim2.new(0,110,0,0)}, 0.2)
            task.delay(0.22, function() dropFrame.Visible = false end)
            if callback then pcall(callback, opt) end
        end)
    end

    selBtn.MouseButton1Click:Connect(function()
        opened = not opened
        dropFrame.Visible = true
        local h = #options * 30
        Tw(dropFrame, {Size = UDim2.new(0, 110, 0, opened and h or 0)}, 0.2, Enum.EasingStyle.Back)
        if not opened then task.delay(0.22, function() dropFrame.Visible = false end) end
    end)

    card.MouseEnter:Connect(function() Tw(card, {BackgroundColor3 = C.BG3}, 0.15) end)
    card.MouseLeave:Connect(function() Tw(card, {BackgroundColor3 = C.BG2}, 0.15) end)
end

