-- LOADING ANIMATION
---------------------------------------------------------
local function AnimateLoading()
    -- Glows
    QuickTween(GlowOuter, 1.0, {ImageTransparency = 0.6}):Play()
    QuickTween(GlowInner, 0.8, {ImageTransparency = 0.4}):Play()
    task.wait(0.4)

    -- Logo pop-in
    TweenService:Create(LogoFrame,
        TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 110, 0, 110), Position = UDim2.new(0.5, -55, 0, 65)}
    ):Play()
    task.wait(0.5)

    -- Logo pulse
    local pulseAlive = true
    task.spawn(function()
        while pulseAlive and LoadingScreen.Parent do
            QuickTween(LogoStroke, 1.2, {Transparency = 0.1}, Enum.EasingStyle.Sine):Play()
            QuickTween(GlowInner, 1.2, {
                ImageTransparency = 0.25,
                Size = UDim2.new(0, 210, 0, 210),
                Position = UDim2.new(0.5, -105, 0, 15)
            }, Enum.EasingStyle.Sine):Play()
            task.wait(1.2)
            if not pulseAlive then break end
            QuickTween(LogoStroke, 1.2, {Transparency = 0.6}, Enum.EasingStyle.Sine):Play()
            QuickTween(GlowInner, 1.2, {
                ImageTransparency = 0.65,
                Size = UDim2.new(0, 180, 0, 180),
                Position = UDim2.new(0.5, -90, 0, 30)
            }, Enum.EasingStyle.Sine):Play()
            task.wait(1.2)
        end
    end)

    -- Text appear
    for _, lbl in ipairs({LoadTitle, LoadSubtitle, LoadStatus, LoadPercent}) do
        QuickTween(lbl, 0.4, {TextTransparency = 0}):Play()
        task.wait(0.1)
    end
    QuickTween(LoadFooter, 0.5, {TextTransparency = 0.35}):Play()
    task.wait(0.2)

    -- Progress
    local stages = {
        {p=0.10, text="Initializing...",           t=0.35},
        {p=0.25, text="Loading framework...",       t=0.30},
        {p=0.40, text="Configuring ESP...",         t=0.30},
        {p=0.55, text="Setting up combat...",       t=0.25},
        {p=0.68, text="Loading boombox...",         t=0.28},
        {p=0.80, text="Applying safety...",         t=0.30},
        {p=0.92, text="Connecting services...",     t=0.25},
        {p=1.00, text="Ready!",                     t=0.20},
    }

    for _, s in ipairs(stages) do
        QuickTween(ProgressFill, s.t, {Size = UDim2.new(s.p, 0, 1, 0)}):Play()
        LoadStatus.Text  = s.text
        LoadPercent.Text = math.floor(s.p * 100) .. "%"
        task.wait(s.t + 0.06)
    end

    LoadStatus.TextColor3  = C.green
    LoadPercent.TextColor3 = C.green
    task.wait(0.7)

    -- Cleanup
    pulseAlive = false
    snowAlive  = false

    -- Fade out
    local fadeInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    QuickTween(LoadingScreen, 0.5, {BackgroundTransparency = 1},
        Enum.EasingStyle.Quad, Enum.EasingDirection.In):Play()

    for _, child in ipairs(LoadCenter:GetDescendants()) do
        if child:IsA("TextLabel") then
            TweenService:Create(child, fadeInfo, {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            TweenService:Create(child, fadeInfo, {BackgroundTransparency = 1}):Play()
        elseif child:IsA("ImageLabel") then
            TweenService:Create(child, fadeInfo, {ImageTransparency = 1}):Play()
        end
    end

    -- Fade snowflakes that are still visible
    for _, child in ipairs(LoadingScreen:GetChildren()) do
        if child:IsA("TextLabel") and child ~= LoadCenter then
            TweenService:Create(child, fadeInfo, {TextTransparency = 1}):Play()
        end
    end

    TweenService:Create(LogoFrame,
        TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        {Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0,90)}
    ):Play()

    task.wait(0.6)
    LoadingScreen:Destroy()
end

