-- LOADING ANIMATION
---------------------------------------------------------
local function AnimateLoading()
    -- Glow appear
    TweenService:Create(GlowOuter, TweenInfo.new(0.8, Enum.EasingStyle.Quad), {ImageTransparency = 0.55}):Play()
    TweenService:Create(GlowInner, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {ImageTransparency = 0.35}):Play()

    -- Particles float
    for _, p in ipairs(particles) do
        local ty = p.Position.Y.Scale - 0.3 - math.random() * 0.4
        TweenService:Create(p, TweenInfo.new(3 + math.random() * 4, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, true), {
            Position = UDim2.new(p.Position.X.Scale + (math.random() - 0.5) * 0.12, 0, ty, 0),
            BackgroundTransparency = math.random(35, 92) / 100
        }):Play()
    end

    -- Spinner rotation
    task.spawn(function()
        while SpinnerRing.Parent and LoadingScreen.Parent do
            SpinnerRing.Rotation = SpinnerRing.Rotation + 2
            RunService.RenderStepped:Wait()
        end
    end)

    task.wait(0.2)

    -- Logo pop in
    LogoFrame.Size = UDim2.new(0, 0, 0, 0)
    LogoFrame.Position = UDim2.new(0.5, 0, 0, 120)
    TweenService:Create(LogoFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 90, 0, 90),
        Position = UDim2.new(0.5, -45, 0, 75)
    }):Play()

    -- Logo pulse
    task.spawn(function()
        while LogoFrame.Parent and LoadingScreen.Parent do
            TweenService:Create(LogoStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.05}):Play()
            TweenService:Create(GlowInner, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.2, Size = UDim2.new(0, 200, 0, 200), Position = UDim2.new(0.5, -100, 0, 20)
            }):Play()
            task.wait(0.8)
            TweenService:Create(LogoStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.55}):Play()
            TweenService:Create(GlowInner, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.55, Size = UDim2.new(0, 180, 0, 180), Position = UDim2.new(0.5, -90, 0, 30)
            }):Play()
            task.wait(0.8)
        end
    end)

    task.wait(0.4)

    -- Text fade in
    TweenService:Create(LoadTitle, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.15)
    TweenService:Create(LoadSubtitle, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.15)
    TweenService:Create(LoadStatus, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadPercent, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadFooter, TweenInfo.new(0.4), {TextTransparency = 0.3}):Play()

    task.wait(0.15)

    -- Progress stages
    local stages = {
        {p = 0.10, t = "Initializing core engine...", d = 0.3},
        {p = 0.22, t = "Loading tab framework...", d = 0.25},
        {p = 0.35, t = "Building UI components...", d = 0.3},
        {p = 0.48, t = "Configuring ESP system...", d = 0.28},
        {p = 0.58, t = "Setting up combat module...", d = 0.22},
        {p = 0.68, t = "Loading boombox engine...", d = 0.25},
        {p = 0.78, t = "Initializing fly & noclip...", d = 0.3},
        {p = 0.88, t = "Applying anti-detection layer...", d = 0.35},
        {p = 0.95, t = "Connecting services...", d = 0.2},
        {p = 1.00, t = "✓ Ready!", d = 0.2},
    }

    for _, s in ipairs(stages) do
        TweenService:Create(ProgressFill, TweenInfo.new(s.d, Enum.EasingStyle.Quad), {
            Size = UDim2.new(s.p, 0, 1, 0)
        }):Play()
        LoadStatus.Text = s.t
        LoadPercent.Text = math.floor(s.p * 100) .. "%"
        task.wait(s.d + 0.04)
    end

    LoadStatus.TextColor3 = C.green
    LoadPercent.TextColor3 = C.green
    task.wait(0.5)

    -- Fade out everything
    TweenService:Create(LoadingScreen, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
    for _, child in ipairs(LoadCenter:GetDescendants()) do
        if child:IsA("TextLabel") then
            TweenService:Create(child, TweenInfo.new(0.35), {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.35), {BackgroundTransparency = 1}):Play()
            local s = child:FindFirstChildOfClass("UIStroke")
            if s then TweenService:Create(s, TweenInfo.new(0.35), {Transparency = 1}):Play() end
        elseif child:IsA("ImageLabel") then
            TweenService:Create(child, TweenInfo.new(0.35), {ImageTransparency = 1}):Play()
        end
    end
    for _, p in ipairs(particles) do
        TweenService:Create(p, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    end

    TweenService:Create(LogoFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0, 100)
    }):Play()

    task.wait(0.6)
    LoadingScreen:Destroy()
end

-- RUN LOADING
AnimateLoading()

