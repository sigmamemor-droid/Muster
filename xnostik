local espConnections = {}

local function ClearAllESP()
    for _, p in pairs(game.Players:GetPlayers()) do
        pcall(function()
            if p.Character and p.Character:FindFirstChild("MM2ESP") then
                p.Character.MM2ESP:Destroy()
            end
        end)
    end
    for _, conn in pairs(espConnections) do
        pcall(function() conn:Disconnect() end)
    end
    espConnections = {}
end

local function ApplyESP(targetPlayer, color)
    if targetPlayer == player then return end
    
    local function addHighlight(char)
        if not char then return end
        pcall(function()
            if char:FindFirstChild("MM2ESP") then
                char.MM2ESP:Destroy()
            end
            local h = Instance.new("Highlight")
            h.Name = "MM2ESP"
            h.FillColor = color
            h.FillTransparency = 0.5
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
            h.OutlineTransparency = 0.3
            h.Adornee = char
            h.Parent = char
        end)
    end
    
    pcall(function()
        if targetPlayer.Character then
            addHighlight(targetPlayer.Character)
        end
    end)
    
    local conn = targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        addHighlight(char)
    end)
    table.insert(espConnections, conn)
end

