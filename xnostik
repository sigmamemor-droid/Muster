        TIcon.Position = UDim2.new(0, 10, 0, 0)
        TIcon.BackgroundTransparency = 1
        TIcon.Text = icon
        TIcon.TextColor3 = C.TextGray
        TIcon.TextSize = 14

        local TText = Instance.new("TextLabel", TabBtn)
        TText.Size = UDim2.new(1, -40, 1, 0)
        TText.Position = UDim2.new(0, 40, 0, 0)
        TText.BackgroundTransparency = 1
        TText.Text = name
        TText.TextColor3 = C.TextGray
        TText.Font = Enum.Font.GothamSemibold
        TText.TextSize = 13
        TText.TextXAlignment = Enum.TextXAlignment.Left

        local Page = Instance.new("ScrollingFrame", PagesContainer)
        Page.Size = UDim2.new(1, -15, 1, 0)
        Page.Position = UDim2.new(0, 15, 0, 0)
        Page.BackgroundTransparency = 1
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = C.Element
        Page.Visible = false
        local PageList = Instance.new("UIListLayout", Page)
        PageList.Padding = UDim.new(0, 8)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Window.Tabs) do
                v.Page.Visible = false
                TweenService:Create(v.Btn, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                v.TIcon.TextColor3 = C.TextGray
                v.TText.TextColor3 = C.TextGray
            end
            Page.Visible = true
            PageTitle.Text = name
            TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0, BackgroundColor3 = C.Element}):Play()
            TIcon.TextColor3 = C.TextWhite
            TText.TextColor3 = C.TextWhite
        end)

        if not Window.CurrentTab then
            Window.CurrentTab = name
            Page.Visible = true
            PageTitle.Text = name
            TabBtn.BackgroundTransparency = 0
            TabBtn.BackgroundColor3 = C.Element
            TIcon.TextColor3 = C.TextWhite
            TText.TextColor3 = C.TextWhite
        end

        local Tab = {Page = Page, Btn = TabBtn, TIcon = TIcon, TText = TText}
        table.insert(Window.Tabs, Tab)

        -- Элементы вкладки
        function Tab:AddSection(text)
            local Sec = Instance.new("Frame", Page)
            Sec.Size = UDim2.new(1, -15, 0, 20)
            Sec.BackgroundTransparency = 1
            
            local SText = Instance.new("TextLabel", Sec)
            SText.Size = UDim2.new(0.3, 0, 1, 0)
            SText.BackgroundTransparency = 1
            SText.Text = text
            SText.TextColor3 = C.TextWhite
            SText.Font = Enum.Font.GothamBold
            SText.TextSize = 13
            SText.TextXAlignment = Enum.TextXAlignment.Left

