local function StopSound()
    if currentSound then
        pcall(function() currentSound:Stop() end)
        pcall(function() currentSound:Destroy() end)
        currentSound     = nil
        State.soundPlaying = false
    end
end

local function PlaySound(audioId, volume)
    StopSound()
    local root = GetRoot()
    if not root then return false end

    local id  = tonumber(audioId)
    if not id then return false end

    local vol = math.clamp(tonumber(volume) or 2, 0, 5)

    local snd        = Instance.new("Sound")
    snd.SoundId      = "rbxassetid://" .. math.floor(id)
    snd.Volume       = vol
    snd.Looped       = true
    snd.Parent       = root
    snd:Play()

    currentSound       = snd
    State.soundPlaying = true
    State.boomboxId    = audioId
    State.boomboxVol   = volume
    return true
end

