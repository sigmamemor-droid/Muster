-- ESP ROLES (з автооновленням)
local espRolesActive = false
AddToggleButton("ESP Roles (Auto-Update)", function(state)
    espRolesActive = state
    ClearAllESP()
    if state then
        SafeDisconnect("ESPRolesLoop")
        
        local function UpdateRoleESP()
            ClearAllESP()
            if not espRolesActive then return end
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player then
                    local isMurderer = false
                    local isSheriff = false
                    pcall(function()
                        if p.Character and p.Character:FindFirstChild("Knife") then
                            isMurderer = true
                        elseif p:FindFirstChild("Backpack") and p.Backpack:FindFirstChild("Knife") then
                            isMurderer = true
                        end
                        if p.Character and p.Character:FindFirstChild("Gun") then
                            isSheriff = true
                        elseif p:FindFirstChild("Backpack") and p.Backpack:FindFirstChild("Gun") then
                            isSheriff = true
                        end
                    end)
                    
                    if isMurderer then
                        ApplyESP(p, Color3.fromRGB(255, 40, 40))
                    elseif isSheriff then
                        ApplyESP(p, Color3.fromRGB(40, 120, 255))
                    else
                        ApplyESP(p, Color3.fromRGB(60, 220, 120))
                    end
                end
            end
        end
        
        UpdateRoleESP()
        -- Оновлення кожні 3 секунди
        Connections.ESPRolesLoop = task.spawn(function()
            while espRolesActive do
                task.wait(3)
                if espRolesActive then
                    UpdateRoleESP()
                end
            end
        end)
    else
        SafeDisconnect("ESPRolesLoop")
    end
end)

