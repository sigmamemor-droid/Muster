-- Kill All Exploit (Requires Knife)
local function executeKillAll()
    local selfChar = LocalPlayer.Character
    local knife = selfChar and (selfChar:FindFirstChild("Knife") or LocalPlayer.Backpack:FindFirstChild("Knife"))
    if not knife then
        notify("Kill All", "You need a Knife equipped or in Backpack!", 1.5)
        return
    end
    
    local selfHRP = selfChar:FindFirstChild("HumanoidRootPart")
    if not selfHRP then return end
    
    local backupCF = selfHRP.CFrame
    knife.Parent = selfChar
    
    local count = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            selfHRP.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1)
            task.wait(0.05)
            
            local stab = knife:FindFirstChild("Stab") or knife:FindFirstChild("OnSlash")
            if stab then stab:FireServer() end
            
            pcall(function()
                firetouchinterest(knife:FindFirstChild("Handle"), player.Character.HumanoidRootPart, 0)
                firetouchinterest(knife:FindFirstChild("Handle"), player.Character.HumanoidRootPart, 1)
            end)
            count = count + 1
            task.wait(0.05)
        end
    end
    selfHRP.CFrame = backupCF
    notify("Kill All", "Killed " .. count .. " players!", 1.5)
end

