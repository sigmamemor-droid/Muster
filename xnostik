-- Combat Logic Loop
local lastSilent, lastAura, lastShoot = 0, 0, 0
RunService.Heartbeat:Connect(function()
    if SilentAim and tick() - lastSilent > 0.2 then
        local gun = FindGunInHand(); local knife = FindKnifeInHand()
        if gun then
            local mHead = GetMurdererHead()
            if mHead then FireGunAtTarget(gun, mHead); lastSilent = tick() end
        elseif knife then
            local cl, md = nil, 200
            for _, p in ipairs(Players:GetPlayers()) do 
                if p ~= player and p.Character and p.Character:FindFirstChild("Head") then 
                    local d = (p.Character.Head.Position - player.Character.Head.Position).Magnitude
                    if d < md then md = d; cl = p.Character end 
                end 
            end
            if cl then ThrowKnifeAtTarget(knife, cl.Head.Position); lastSilent = tick() end
        end
    end

    if KillAura and tick() - lastAura > 0.15 then
        local knife = FindKnifeInHand()
        if knife then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if (p.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude <= AuraRange then 
                        ThrowKnifeAtTarget(knife, p.Character.HumanoidRootPart.Position)
                        lastAura = tick() 
                    end
                end
            end
        end
    end

    if AutoShoot and tick() - lastShoot > 0.3 then
        local gun = FindGunInHand()
        if gun then
            local mHead = GetMurdererHead()
            if mHead and mHead.Parent then
                local o = camera.CFrame.Position; local d = (mHead.Position - o).Unit * 150
                local rp = RaycastParams.new(); rp.FilterDescendantsInstances = {player.Character}; rp.FilterType = Enum.RaycastFilterType.Exclude
                local r = workspace:Raycast(o, d, rp)
                if r and r.Instance:IsDescendantOf(mHead.Parent) then 
                    FireGunAtTarget(gun, mHead); lastShoot = tick() 
                end
            end
        end
    end
end)

