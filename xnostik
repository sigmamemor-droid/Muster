UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if Main.Visible then
            Tween(Main, {Size = UDim2.new(0, 700, 0, 0)}, 0.3, Enum.EasingStyle.Back)
            task.delay(0.35, function()
                Main.Visible = false
                Main.Size = UDim2.new(0, 700, 0, 490)
            end)
        else
            Main.Visible = true
            Main.Size = UDim2.new(0, 700, 0, 0)
            Tween(Main, {Size = UDim2.new(0, 700, 0, 490)}, 0.4, Enum.EasingStyle.Back)
        end
    end

    -- Быстрые клавиши
    if input.KeyCode == Enum.KeyCode.F1 then
        State.SilentAim = not State.SilentAim
        Notify("Silent Aim", State.SilentAim and "Включён [F1]" or "Выключен [F1]",
            State.SilentAim and "success" or "error", 2)
    end
    if input.KeyCode == Enum.KeyCode.F2 then
        State.ESP = not State.ESP
        Notify("ESP", State.ESP and "Включён [F2]" or "Выключен [F2]",
            State.ESP and "success" or "error", 2)
    end
    if input.KeyCode == Enum.KeyCode.F3 then
        State.KillAll = not State.KillAll
        Notify("Kill All", State.KillAll and "Включён [F3]" or "Выключен [F3]",
            State.KillAll and "success" or "error", 2)
    end
end)

