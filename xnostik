-- АВТОФАРМ (КАК НА СКРИНШОТЕ)
---------------------------------------------------------
FarmTab:AddSection("Статистика")
local StatSession = FarmTab:AddLabel("Сессия: 0")
local StatTotal = FarmTab:AddLabel("Всего: 0")
local StatSpeed = FarmTab:AddLabel("Скорость: 0 / мин")
local StatStatus = FarmTab:AddLabel("Статус: Наблюдаю")

local FarmData = {Active = false, Coins = 0, Start = tick()}
FarmTab:AddSection("Фарм")
FarmTab:AddToggle("Автофарм", function(s) 
    FarmData.Active = s 
    if s then StatStatus.Text = "Статус: Фарминг..." else StatStatus.Text = "Статус: Остановлен" end
end)
local AutoRespawn = false
FarmTab:AddToggle("Авто-респавн", function(s) AutoRespawn = s end)
local AntiFling = false
FarmTab:AddToggle("Анти-флинг", function(s) AntiFling = s end)
local AvoidMurd = false
FarmTab:AddToggle("Избегать убийцу", function(s) AvoidMurd = s end)
local AutoFling = false
FarmTab:AddToggle("Авто-флинг", function(s) AutoFling = s end)

RunService.Stepped:Connect(function()
    local r = GetRoot()
    if not r then return end

    if AntiFling then
        if r.Velocity.Magnitude > 100 or r.RotVelocity.Magnitude > 100 then
            r.Velocity = Vector3.zero
            r.RotVelocity = Vector3.zero
        end
    end

    if AvoidMurd then
        local m = GetMurd()
        if m and m.Character and m.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (r.Position - m.Character.HumanoidRootPart.Position).Magnitude
            if dist < 30 then
                r.CFrame = r.CFrame * CFrame.new(0, 0, -30) -- Отпрыгнуть назад
            end
        end
    end

    if FarmData.Active then
        local normal = workspace:FindFirstChild("Normal")
        if normal and normal:FindFirstChild("CoinContainer") then
            local targetCoin = nil
            for _, coin in ipairs(normal.CoinContainer:GetChildren()) do
                if coin:IsA("BasePart") then targetCoin = coin; break end
            end
            if targetCoin then
                r.CFrame = targetCoin.CFrame
                task.wait(0.1)
                -- Обновление статы (примерная симуляция сбора)
                FarmData.Coins = FarmData.Coins + 1
                StatSession.Text = "Сессия: " .. FarmData.Coins
                StatTotal.Text = "Всего: " .. (FarmData.Coins * 2)
                local minutes = (tick() - FarmData.Start) / 60
                if minutes > 0 then StatSpeed.Text = "Скорость: " .. math.floor(FarmData.Coins / minutes) .. " / мин" end
            else
                StatStatus.Text = "Статус: Ожидание монет..."
            end
        else
            StatStatus.Text = "Статус: Карта не найдена"
        end
    end

    if AutoFling then
        r.AssemblyAngularVelocity = Vector3.new(256, 256, 256)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (r.Position - p.Character.HumanoidRootPart.Position).Magnitude < 10 then
                    p.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 256, 0)
                end
            end
        end
    end
end)

