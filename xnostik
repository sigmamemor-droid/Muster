    descLabel.TextSize = 11
    descLabel.TextColor3 = Config.UI.SubTextColor
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Parent = frame

    -- Сам переключатель
    local toggleBg = Instance.new("Frame")
    toggleBg.Size = UDim2.new(0, 44, 0, 24)
    toggleBg.Position = UDim2.new(1, -58, 0.5, -12)
    toggleBg.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    toggleBg.BorderSizePixel = 0
    toggleBg.Parent = frame

    local toggleBgCorner = Instance.new("UICorner")
    toggleBgCorner.CornerRadius = UDim.new(1, 0)
    toggleBgCorner.Parent = toggleBg

    local toggleKnob = Instance.new("Frame")
    toggleKnob.Size = UDim2.new(0, 18, 0, 18)
    toggleKnob.Position = UDim2.new(0, 3, 0.5, -9)
    toggleKnob.BackgroundColor3 = Color3.fromRGB(200, 200, 215)
    toggleKnob.BorderSizePixel = 0
    toggleKnob.Parent = toggleBg

    local toggleKnobCorner = Instance.new("UICorner")
    toggleKnobCorner.CornerRadius = UDim.new(1, 0)
    toggleKnobCorner.Parent = toggleKnob

    local enabled = default or false

    local function SetState(state, noCallback)
        enabled = state
        if state then
            Tween(toggleBg, {BackgroundColor3 = Config.UI.AccentColor}, 0.2)
            Tween(toggleKnob, {Position = UDim2.new(0, 23, 0.5, -9), BackgroundColor3 = Color3.fromRGB(255,255,255)}, 0.2)
        else
            Tween(toggleBg, {BackgroundColor3 = Color3.fromRGB(50, 50, 65)}, 0.2)
            Tween(toggleKnob, {Position = UDim2.new(0, 3, 0.5, -9), BackgroundColor3 = Color3.fromRGB(200, 200, 215)}, 0.2)
        end
        if not noCallback and callback then callback(state) end
    end

    SetState(default or false, true)

    local clickArea = Instance.new("TextButton")
    clickArea.Size = UDim2.new(1, 0, 1, 0)
    clickArea.BackgroundTransparency = 1
    clickArea.Text = ""
    clickArea.Parent = frame

    clickArea.MouseButton1Click:Connect(function()
        Ripple(frame)
        SetState(not enabled)
    end)

    frame.MouseEnter:Connect(function()
        Tween(frame, {BackgroundColor3 = Color3.fromRGB(30, 30, 45)}, 0.15)
    end)
    frame.MouseLeave:Connect(function()
        Tween(frame, {BackgroundColor3 = Config.UI.TabColor}, 0.15)
    end)

    return {SetState = SetState, GetState = function() return enabled end}
end

