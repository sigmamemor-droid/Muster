            Tw(Main, {Size = UDim2.new(0,820,0,0)}, 0.3, Enum.EasingStyle.Back)
            task.delay(0.35, function()
                Main.Visible = false
                Main.Size = UDim2.new(0,820,0,560)
            end)
        else
            Main.Visible = true
            Main.Size = UDim2.new(0,820,0,0)
            Tw(Main, {Size = UDim2.new(0,820,0,560)}, 0.4, Enum.EasingStyle.Back)
        end
    end
    if i.KeyCode == Enum.KeyCode.F1 then State.SilentAim = not State.SilentAim end
    if i.KeyCode == Enum.KeyCode.F2 then State.RoleESP = not State.RoleESP end
    if i.KeyCode == Enum.KeyCode.F3 then State.KillAll = not State.KillAll end
end)

