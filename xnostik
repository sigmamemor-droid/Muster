local function CreateHighlight(obj, color, name)
    if obj:FindFirstChild(name) then obj[name]:Destroy() end
    local hl = Instance.new("Highlight")
    hl.Name = name
    hl.FillColor = color
    hl.FillTransparency = 0.6
    hl.OutlineColor = color
    hl.Parent = obj
end

CreateToggle(TabVisuals, "Role ESP", false, function(state)
    if state then
        IDK.Connections["ESP"] = RunService.Heartbeat:Connect(function()
            if not IDK.ESP_Tick or tick() - IDK.ESP_Tick > 1 then
                IDK.ESP_Tick = tick()
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character then
                        local r = GetRole(p)
                        if r == "Murderer" then CreateHighlight(p.Character, Color3.fromRGB(255, 40, 40), "IDK_ESP")
                        elseif r == "Sheriff" then CreateHighlight(p.Character, Color3.fromRGB(40, 100, 255), "IDK_ESP")
                        else CreateHighlight(p.Character, Color3.fromRGB(40, 220, 100), "IDK_ESP") end
                    end
                end
            end
        end)
    else
        if IDK.Connections["ESP"] then IDK.Connections["ESP"]:Disconnect() end
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("IDK_ESP") then p.Character.IDK_ESP:Destroy() end
        end
    end
end)

