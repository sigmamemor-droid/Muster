-- ESP Loop
RunService.RenderStepped:Connect(function()
    -- FOV
    if State.ShowFOV and State.SilentAim then
        fovDraw.Visible = true
        fovDraw.Radius = State.FOV
        fovDraw.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    else
        fovDraw.Visible = false
    end

    -- Игроки
    for _, p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            CleanESP(p); continue
        end
        if not ESPObjs[p] then MakeESP(p) end

        local data = ESPObjs[p]
        if not data then continue end

        local role, col = GetRole(p)
        local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local dist = myR and math.floor((myR.Position - p.Character.HumanoidRootPart.Position).Magnitude) or 0
        local hum = p.Character:FindFirstChild("Humanoid")
        local hp = hum and math.floor(hum.Health) or 0
        local mhp = hum and math.floor(hum.MaxHealth) or 100

        local show = State.RoleESP and (
            (role=="MURDERER" and State.MurdererESP) or
            (role=="SHERIFF" and State.SheriffESP) or
            (role=="INNOCENT")
        )

        pcall(function()
            data.Bill.Adornee = p.Character.HumanoidRootPart
            data.Bill.Parent = p.Character
            data.Bill.Enabled = show
            data.HL.Parent = p.Character
            data.HL.Enabled = show
            data.HL.FillColor = col
            data.HL.OutlineColor = col
        end)

        if show then
            data.Name.Text = "👤 " .. p.Name
            data.Role.Text = role
            data.Role.TextColor3 = col
            data.Info.Text = string.format("❤ %d/%d  📏 %dst", hp, mhp, dist)
        end
    end

    -- Объекты
    for _, obj in pairs(workspace:GetDescendants()) do
        if not ObjESPT[obj] then
            if obj.Name == "Gun" and State.GunESP then
                MakeObjESP(obj, C.Yellow or Color3.fromRGB(255,210,60), "🔫 GUN")
            elseif obj.Name == "Knife" and State.RoleESP then
                MakeObjESP(obj, C.Red, "🔪 KNIFE")
            elseif obj.Name == "Coin" then
                MakeObjESP(obj, Color3.fromRGB(0,220,255), "🪙 COIN")
            end
        end
    end

    for obj, data in pairs(ObjESPT) do
        if not obj or not obj.Parent then
            pcall(function() data.HL:Destroy() end)
            pcall(function() data.Bill:Destroy() end)
            ObjESPT[obj] = nil
        end
    end
end)

