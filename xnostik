-- ESP Главный цикл
RunService.RenderStepped:Connect(function()
    -- FOV Circle
    if State.FOVCircle and State.SilentAim then
        fovCircle.Visible = true
        fovCircle.Radius = State.FOV
        fovCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        fovCircle.Color = Color3.fromRGB(180, 0, 255)
    else
        fovCircle.Visible = false
    end

    if not State.ESP then return end

    -- Игроки
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
            RemovePlayerESP(plr)
            continue
        end

        if not ESPObjects[plr] then
            CreatePlayerESP(plr)
        end

        local data = ESPObjects[plr]
        if not data then continue end

        local role, color = GetRole(plr)
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local dist = myRoot and math.floor((myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude) or 0
        local hum = plr.Character:FindFirstChild("Humanoid")
        local hp = hum and math.floor(hum.Health) or 0
        local maxhp = hum and math.floor(hum.MaxHealth) or 100

        local show = (role == "MURDERER" and State.MurdererESP) or
                     (role == "SHERIFF" and State.SheriffESP) or
                     (role == "INNOCENT" and State.InnocentESP)

        pcall(function()
            data.Bill.Adornee = plr.Character.HumanoidRootPart
            data.Bill.Parent = plr.Character
            data.Bill.Enabled = show

            data.HL.Parent = plr.Character
            data.HL.Enabled = show
            data.HL.FillColor = color
            data.HL.OutlineColor = color
        end)

        if show then
            data.Name.Text = "👤 " .. plr.Name
            data.Role.Text = role
            data.Role.TextColor3 = color
            data.Role.TextStrokeColor3 = color

            local info = ""
            if State.ShowHP then info ..= string.format("❤ %d/%d  ", hp, maxhp) end
            if State.ShowDist then info ..= string.format("📏 %d st", dist) end
            data.Info.Text = info
        end
    end

    -- Объекты
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Gun" and State.GunESP then
            CreateObjESP(obj, Cfg.Yellow, "🔫 GUN")
        elseif obj.Name == "Knife" and State.KnifeESP then
            CreateObjESP(obj, Cfg.Red, "🔪 KNIFE")
        elseif obj.Name == "Coin" and State.CoinESP then
            CreateObjESP(obj, Color3.fromRGB(0,230,255), "🪙 COIN")
        end
    end

    -- Очистка мёртвых объектов
    for obj, data in pairs(ObjESP) do
        if not obj or not obj.Parent then
            pcall(function() data.HL:Destroy() end)
            pcall(function() data.Bill:Destroy() end)
            ObjESP[obj] = nil
        else
            local isGun = obj.Name == "Gun"
            local isKnife = obj.Name == "Knife"
            local isCoin = obj.Name == "Coin"
            local vis = (isGun and State.GunESP) or (isKnife and State.KnifeESP) or (isCoin and State.CoinESP)
            pcall(function()
                data.HL.Enabled = vis
                data.Bill.Enabled = vis
            end)
        end
    end
end)

