--[=[ СИСТЕМА КОНФИГОВ ]=]
function AztupHub.Config:Save(slot)
    local data = HttpService:JSONEncode(AztupHub.State.Settings)
    if writefile then
        writefile("AztupHub_" .. (slot or "default") .. ".json", data)
    else
        setclipboard(data)
    end
end

function AztupHub.Config:Load(slot)
    if not readfile then return end
    local data = readfile("AztupHub_" .. (slot or "default") .. ".json")
    if data then
        local decoded = HttpService:JSONDecode(data)
        for k, v in pairs(decoded) do
            AztupHub.State.Settings[k] = v
        end
    end
end

