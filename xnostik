AddSeparator("ESP VISUALS", 15)

local function ApplyESP(targetPlayer, color)
    if targetPlayer == player then return end
    local function addHighlights(char)
        if not char then return end
        if char:FindFirstChild("MenuESP") then char.MenuESP:Destroy() end
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "MenuESP"
        Highlight.FillColor = color
        Highlight.FillTransparency = 0.4
        Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        Highlight.Adornee = char
        Highlight.Parent = char
    end
    if targetPlayer.Character then addHighlights(targetPlayer.Character) end
    targetPlayer.CharacterAdded:Connect(addHighlights)
end

local function ClearESP()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("MenuESP") then
            p.Character.MenuESP:Destroy()
        end
    end
end

