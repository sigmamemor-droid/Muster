-- TAB CREATOR
local TabButtons = {}
local function createTab(name, icon, order)
    local b = Instance.new("TextButton")
    b.Name = name
    b.Parent = TabContainer
    b.BackgroundColor3 = Colors.SurfaceLight
    b.BackgroundTransparency = 1
    b.BorderSizePixel = 0
    b.Size = UDim2.new(1, 0, 0, 36)
    b.Text = ""
    b.LayoutOrder = order
    b.AutoButtonColor = false
    corner(b, 8)

    local ic = Instance.new("TextLabel")
    ic.Parent = b
    ic.BackgroundTransparency = 1
    ic.Position = UDim2.new(0, 10, 0, 0)
    ic.Size = UDim2.new(0, 20, 1, 0)
    ic.Text = icon
    ic.TextSize = 14
    ic.Font = Enum.Font.SourceSans
    ic.TextColor3 = Colors.TextMuted

    local nm = Instance.new("TextLabel")
    nm.Parent = b
    nm.BackgroundTransparency = 1
    nm.Position = UDim2.new(0, 34, 0, 0)
    nm.Size = UDim2.new(1, -44, 1, 0)
    nm.Text = name
    nm.TextColor3 = Colors.TextSecondary
    nm.Font = Enum.Font.GothamSemibold
    nm.TextSize = 12
    nm.TextXAlignment = Enum.TextXAlignment.Left

    local ind = Instance.new("Frame")
    ind.Parent = b
    ind.BackgroundColor3 = Colors.Accent
    ind.BorderSizePixel = 0
    ind.Size = UDim2.new(0, 3, 0, 0)
    ind.Position = UDim2.new(0, 0, 0.5, 0)
    ind.AnchorPoint = Vector2.new(0, 0.5)
    corner(ind, 2)

    b.MouseEnter:Connect(function()
        if State.ActiveTab ~= name then
            tween(b, {BackgroundTransparency=0.5}, 0.15)
            tween(nm, {TextColor3=Colors.TextPrimary}, 0.15)
        end
    end)
    b.MouseLeave:Connect(function()
        if State.ActiveTab ~= name then
            tween(b, {BackgroundTransparency=1}, 0.15)
            tween(nm, {TextColor3=Colors.TextSecondary}, 0.15)
        end
    end)
    TabButtons[name] = {Button=b, Icon=ic, Name=nm, Indicator=ind}
    return b
end

local function setActiveTab(name)
    State.ActiveTab = name
    for n, d in pairs(TabButtons) do
        if n == name then
            tween(d.Button, {BackgroundTransparency=0.3}, 0.2)
            tween(d.Name, {TextColor3=Colors.TextPrimary}, 0.2)
            tween(d.Icon, {TextColor3=Colors.Accent}, 0.2)
            tween(d.Indicator, {Size=UDim2.new(0,3,0,18)}, 0.25, Enum.EasingStyle.Back)
        else
            tween(d.Button, {BackgroundTransparency=1}, 0.2)
            tween(d.Name, {TextColor3=Colors.TextSecondary}, 0.2)
            tween(d.Icon, {TextColor3=Colors.TextMuted}, 0.2)
            tween(d.Indicator, {Size=UDim2.new(0,3,0,0)}, 0.15)
        end
    end
end

