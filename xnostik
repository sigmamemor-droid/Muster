local function AnimateLoading()
    -- Фаза 1: Появление свечения (0.0s - 0.5s)
    TweenService:Create(GlowOuter, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        ImageTransparency = 0.6
    }):Play()
    TweenService:Create(GlowInner, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        ImageTransparency = 0.4
    }):Play()

    -- Анимация частиц
    for _, p in ipairs(particles) do
        local targetY = p.Position.Y.Scale - 0.3 - math.random() * 0.4
        TweenService:Create(p, TweenInfo.new(
            3 + math.random() * 4,
            Enum.EasingStyle.Linear,
            Enum.EasingDirection.InOut,
            -1, true
        ), {
            Position = UDim2.new(p.Position.X.Scale + (math.random() - 0.5) * 0.1, 0, targetY, 0),
            BackgroundTransparency = math.random(40, 95) / 100
        }):Play()
    end

    task.wait(0.3)

    -- Фаза 2: Появление логотипа (вращение + масштаб)
    LogoFrame.Size = UDim2.new(0, 0, 0, 0)
    LogoFrame.Position = UDim2.new(0.5, 0, 0, 120)
    TweenService:Create(LogoFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 100, 0, 100),
        Position = UDim2.new(0.5, -50, 0, 70),
        Rotation = 45
    }):Play()

    task.wait(0.5)

    -- Пульсация свечения логотипа
    task.spawn(function()
        while LoadingScreen.Parent do
            TweenService:Create(LogoStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Transparency = 0.1
            }):Play()
            TweenService:Create(GlowInner, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.3,
                Size = UDim2.new(0, 200, 0, 200),
                Position = UDim2.new(0.5, -100, 0, 20)
            }):Play()
            task.wait(1)
            TweenService:Create(LogoStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Transparency = 0.6
            }):Play()
            TweenService:Create(GlowInner, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.6,
                Size = UDim2.new(0, 180, 0, 180),
                Position = UDim2.new(0.5, -90, 0, 30)
            }):Play()
            task.wait(1)
        end
    end)

    -- Фаза 3: Появление текста
    TweenService:Create(LoadTitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    task.wait(0.2)
    TweenService:Create(LoadSubtitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    task.wait(0.2)
    TweenService:Create(LoadStatus, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadPercent, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadFooter, TweenInfo.new(0.5), {TextTransparency = 0.4}):Play()

    task.wait(0.2)

    -- Фаза 4: Прогресс-бар с этапами
    local stages = {
        {progress = 0.15, text = "Initializing core modules...", time = 0.4},
        {progress = 0.30, text = "Loading UI framework...", time = 0.3},
        {progress = 0.45, text = "Configuring ESP system...", time = 0.35},
        {progress = 0.55, text = "Setting up combat module...", time = 0.25},
        {progress = 0.70, text = "Loading boombox engine...", time = 0.3},
        {progress = 0.80, text = "Applying anti-detection...", time = 0.4},
        {progress = 0.90, text = "Connecting to services...", time = 0.3},
        {progress = 1.00, text = "Ready!", time = 0.3},
    }

    for _, stage in ipairs(stages) do
        TweenService:Create(ProgressFill, TweenInfo.new(stage.time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(stage.progress, 0, 1, 0)
        }):Play()
        LoadStatus.Text = stage.text
        LoadPercent.Text = math.floor(stage.progress * 100) .. "%"
        task.wait(stage.time + 0.05)
    end

    -- Фаза 5: Пауза на "Ready!"
    LoadStatus.TextColor3 = Colors.green
    LoadPercent.TextColor3 = Colors.green
    task.wait(0.6)

    -- Фаза 6: Fade out
    TweenService:Create(LoadingScreen, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
    }):Play()

    for _, child in ipairs(LoadCenter:GetDescendants()) do
        if child:IsA("TextLabel") then
            TweenService:Create(child, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        elseif child:IsA("ImageLabel") then
            TweenService:Create(child, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
        end
    end

    for _, p in ipairs(particles) do
        TweenService:Create(p, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    end

    -- Логотип уходит вверх
    TweenService:Create(LogoFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0, 80)
    }):Play()

    task.wait(0.7)
    LoadingScreen:Destroy()
end

