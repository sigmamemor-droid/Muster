local connections = {}
local function Conn(n, c) if connections[n] then connections[n]:Disconnect() end; connections[n] = c end
local function ClearConn(n) if connections[n] then connections[n]:Disconnect(); connections[n] = nil end end

local function GetChar() return player.Character end
local function GetHum() local c = GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function IsMurderer(p) return p.Character and (p.Character:FindFirstChild("Knife") or p.Backpack:FindFirstChild("Knife")) ~= nil end
local function IsSheriff(p) return p.Character and (p.Character:FindFirstChild("Gun") or p.Backpack:FindFirstChild("Gun")) ~= nil end

