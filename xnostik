--[=[ ИНИЦИАЛИЗАЦИЯ ]=]
function AztupHub:Init()
    if self.State.Initialized then return end
    self.State.Initialized = true
    
    -- Загружаем конфиг
    self.Config:Load("default")
    
    -- Создаём UI
    local window = AztupUI:NewWindow({
        Name = "Aztup Hub v" .. self.Version,
        Size = Vector2.new(540, 620),
        Theme = "CyberBlue",
        Tabs = self.State.Tabs
    })
    
    -- Заполняем вкладки элементами (оригинальные)
    -- Main tab
    local mainContainer = window["Container_Main"]
    AztupUI:CreateToggle(mainContainer, {Name = "Enable Aztup Hub", Default = true, Callback = function(v) print("Hub enabled: " .. tostring(v)) end})
    AztupUI:CreateToggle(mainContainer, {Name = "Auto Update", Default = true})
    AztupUI:CreateSlider(mainContainer, {Name = "FPS Limit", Min = 30, Max = 240, Default = 60})
    
    -- Aimbot tab
    local aimContainer = window["Container_Aimbot"]
    AztupUI:CreateToggle(aimContainer, {Name = "Aimbot", Default = false, Callback = function(v) self.State.Settings.Aimbot.Enabled = v end})
    AztupUI:CreateToggle(aimContainer, {Name = "Silent Aim", Default = false, Callback = function(v) self.State.Settings.Aimbot.Silent = v end})
    AztupUI:CreateSlider(aimContainer, {Name = "FOV", Min = 20, Max = 500, Default = 150, Callback = function(v) self.State.Settings.Aimbot.FOV = v end})
    AztupUI:CreateSlider(aimContainer, {Name = "Smoothness", Min = 0, Max = 1, Default = 30, Callback = function(v) self.State.Settings.Aimbot.Smoothness = v / 100 end})
    
    -- ESP tab
    local espContainer = window["Container_ESP"]
    AztupUI:CreateToggle(espContainer, {Name = "ESP", Default = false, Callback = function(v) self.State.Settings.ESP.Enabled = v end})
    AztupUI:CreateToggle(espContainer, {Name = "Box ESP", Default = true, Callback = function(v) self.State.Settings.ESP.Box = v end})
    AztupUI:CreateToggle(espContainer, {Name = "Show Names", Default = true, Callback = function(v) self.State.Settings.ESP.Names = v end})
    AztupUI:CreateToggle(espContainer, {Name = "Show Roles", Default = true, Callback = function(v) self.State.Settings.ESP.Roles = v end})
    
    -- Farm tab
    local farmContainer = window["Container_Farm"]
    AztupUI:CreateToggle(farmContainer, {Name = "Auto Farm", Default = false, Callback = function(v) self.State.Settings.Farm.Enabled = v end})
    AztupUI:CreateToggle(farmContainer, {Name = "Auto Collect", Default = true, Callback = function(v) self.State.Settings.Farm.AutoCollect = v end})
    AztupUI:CreateSlider(farmContainer, {Name = "Collect Radius", Min = 20, Max = 200, Default = 50, Callback = function(v) self.State.Settings.Farm.CollectRadius = v end})
    
    -- Misc tab
    local miscContainer = window["Container_Misc"]
    AztupUI:CreateToggle(miscContainer, {Name = "Fly", Default = false, Callback = function(v) self.State.Settings.Misc.Fly = v end})
    AztupUI:CreateToggle(miscContainer, {Name = "Noclip", Default = false, Callback = function(v) self.State.Settings.Misc.Noclip = v end})
    AztupUI:CreateSlider(miscContainer, {Name = "Walkspeed", Min = 10, Max = 120, Default = 16, Callback = function(v) self.State.Settings.Misc.Speed = v end})
    AztupUI:CreateSlider(miscContainer, {Name = "Jump Power", Min = 40, Max = 200, Default = 50, Callback = function(v) self.State.Settings.Misc.Jump = v end})
    
    -- Settings tab
    local settingsContainer = window["Container_Settings"]
    AztupUI:CreateToggle(settingsContainer, {Name = "Auto Save Config", Default = true})
    local saveBtn = Instance.new("TextButton")
    saveBtn.Size = UDim2.fromScale(0.8, 0.07)
    saveBtn.Position = UDim2.fromScale(0.1, 0.3)
    saveBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    saveBtn.Text = "Save Config"
    saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    saveBtn.Font = Enum.Font.GothamBold
    saveBtn.TextSize = 16
    saveBtn.BorderSizePixel = 0
    saveBtn.Parent = settingsContainer
    saveBtn.MouseButton1Click:Connect(function()
        self.Config:Save("default")
        print("[AztupHub] Config saved")
    end)
    
    local loadBtn = saveBtn:Clone()
    loadBtn.Position = UDim2.fromScale(0.1, 0.4)
    loadBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 100)
    loadBtn.Text = "Load Config"
    loadBtn.Parent = settingsContainer
    loadBtn.MouseButton1Click:Connect(function()
        self.Config:Load("default")
        print("[AztupHub] Config loaded")
    end)
    
    self.UI = window
    self.State.Loaded = true
    print("[AztupHub] Fully loaded | Version " .. self.Version)
    
    -- Запускаем основные циклы
    RunService.Heartbeat:Connect(function()
        self.Aimbot:Run()
        self.ESP:Run()
        self.Farm:Run()
        self.Misc:Run()
    end)
end

