-- ADVANCED TARGET ORBIT FLING [BETA] (FULLY DETAILED PHYSICS BYPASS)
local targetFlingActive = false
MkButton("Fun & Troll", "fling_btn", C.accent, function()
    if not selectedPlayer or not selectedPlayer.Character then 
        Notify("linbergz", "Select target player!", C.red, 2) 
        return 
    end
    
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    local targetRoot = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = selectedPlayer.Character:FindFirstChildOfClass("Humanoid")
    
    if root and targetRoot and humanoid and targetHum and targetHum.Health > 0 then
        if targetFlingActive then return end
        targetFlingActive = true
        
        local savedPos = root.CFrame
        Notify("linbergz", "Target locked: Flinging " .. selectedPlayer.DisplayName, C.accent, 2.5)
        
        -- Disable personal limb collision to prevent self-flings
        local storedPartsState = {}
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                storedPartsState[part] = {part.CanCollide, part.Massless}
                part.CanCollide = false
                part.Massless = true
            end
        end
        
        -- Enable root collision specifically to transfer kinetic physical impulse
        root.CanCollide = true
        
        -- High Torque Rotational angular force injection
        local bodyAngularVelocity = Instance.new("BodyAngularVelocity")
        bodyAngularVelocity.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyAngularVelocity.AngularVelocity = Vector3.new(0, 99999, 0)
        bodyAngularVelocity.Parent = root
        
        -- Put humanoid in Physics state to prevent script recovery
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        
        local start = tick()
        while tick() - start < 3.2 do
            if not targetRoot or not targetRoot.Parent or targetHum.Health <= 0 then 
                break 
            end
            
            -- Cycle coordinates underneath target player to launch them upwards
            root.CFrame = targetRoot.CFrame * CFrame.new(0, -1.3, 0)
            root.AssemblyLinearVelocity = Vector3.new(0, 450000, 0)
            task.wait(0.01)
        end
        
        -- Physical cleanup
        bodyAngularVelocity:Destroy()
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        root.CFrame = savedPos
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        
        -- Restore original collisions state
        for part, data in pairs(storedPartsState) do
            if part.Parent then
                part.CanCollide = data[1]
                part.Massless = data[2]
            end
        end
        
        targetFlingActive = false
        Notify("linbergz", "Fling sequence completed", C.green, 2)
    end
end)

