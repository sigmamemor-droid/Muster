local function AddTab(name, icon)
    local content = CreateTabContent()
    
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, 0, 0, 34)
    tabBtn.BackgroundColor3 = P.Card
    tabBtn.BackgroundTransparency = 1
    tabBtn.Text = icon .. "  " .. name
    tabBtn.TextColor3 = P.TextDim
    tabBtn.TextSize = 12
    tabBtn.Font = Enum.Font.GothamSemibold
    tabBtn.TextXAlignment = Enum.TextXAlignment.Left
    tabBtn.AutoButtonColor = false
    tabBtn.LayoutOrder = #TabButtons + 1
    tabBtn.Parent = Sidebar
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)
    
    local tabPadding = Instance.new("UIPadding")
    tabPadding.PaddingLeft = UDim.new(0, 10)
    tabPadding.Parent = tabBtn
    
    -- Indicator
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 3, 0.6, 0)
    indicator.Position = UDim2.new(0, -7, 0.2, 0)
    indicator.BackgroundColor3 = P.Accent
    indicator.BorderSizePixel = 0
    indicator.BackgroundTransparency = 1
    indicator.Parent = tabBtn
    Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 2)
    
    local tabData = {
        Name = name,
        Button = tabBtn,
        Content = content,
        Indicator = indicator,
        OrderCounter = 0,
    }
    
    function tabData:NextOrder()
        self.OrderCounter = self.OrderCounter + 1
        return self.OrderCounter
    end
    
    table.insert(Tabs, tabData)
    table.insert(TabButtons, tabBtn)
    
    -- Tab switch
    tabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= tabData then
            QuickTween(tabBtn, {BackgroundTransparency = 0.5}, 0.12)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if ActiveTab ~= tabData then
            QuickTween(tabBtn, {BackgroundTransparency = 1}, 0.12)
        end
    end)
    
    tabBtn.MouseButton1Click:Connect(function()
        if ActiveTab == tabData then return end
        
        -- Деактивуємо попередній
        if ActiveTab then
            ActiveTab.Content.Visible = false
            QuickTween(ActiveTab.Button, {
                BackgroundTransparency = 1,
                TextColor3 = P.TextDim
            }, 0.15)
            QuickTween(ActiveTab.Indicator, {BackgroundTransparency = 1}, 0.15)
        end
        
        -- Активуємо новий
        ActiveTab = tabData
        content.Visible = true
        QuickTween(tabBtn, {
            BackgroundTransparency = 0.3,
            TextColor3 = P.Text
        }, 0.15)
        QuickTween(indicator, {BackgroundTransparency = 0}, 0.15)
    end)
    
    return tabData
end

