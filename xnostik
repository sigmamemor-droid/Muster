local hubOpen = false
local function ToggleHub()
    hubOpen = not hubOpen
    if hubOpen then 
        Hub.Visible = true; Shadow.Visible = true
        Hub.Size = UDim2.new(0, HUB_W, 0, 0)
        Hub.GroupTransparency = 1
        
        TweenService:Create(Hub, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, HUB_W, 0, HUB_H)}):Play()
        TweenService:Create(Hub, TweenInfo.new(0.25), {GroupTransparency = 0}):Play()
        TweenService:Create(HubBlur, TweenInfo.new(0.3), {Size = 12}):Play()
        
        -- Shadow fade in
        Shadow.ImageTransparency = 1
        TweenService:Create(Shadow, TweenInfo.new(0.4), {ImageTransparency = 0.4}):Play()
    else 
        local tw = TweenService:Create(Hub, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {Size = UDim2.new(0, HUB_W, 0, 0)}) 
        tw:Play()
        TweenService:Create(Hub, TweenInfo.new(0.15), {GroupTransparency = 1}):Play()
        TweenService:Create(HubBlur, TweenInfo.new(0.2), {Size = 0}):Play()
        TweenService:Create(Shadow, TweenInfo.new(0.2), {ImageTransparency = 1}):Play()
        tw.Completed:Connect(function() Hub.Visible = false; Shadow.Visible = false; Hub.Size = UDim2.new(0, HUB_W, 0, HUB_H); Hub.GroupTransparency = 0 end) 
    end
end
ToggleBtn.MouseButton1Click:Connect(ToggleHub)
