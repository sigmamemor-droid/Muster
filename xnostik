-- УБИЙЦА
local MurdAim = false
local KillAura = false
MurdererTab:AddToggle("Тихий Аимбот (Нож)", function(s) MurdAim = s end)
MurdererTab:AddToggle("Kill Aura", function(s) KillAura = s end)

RunService.Heartbeat:Connect(function()
    local knife = lp.Character and lp.Character:FindFirstChild("Knife")
    if not knife then return end

    if KillAura then
        local r = GetRoot()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if r and (p.Character.HumanoidRootPart.Position - r.Position).Magnitude < 16 then
                    local re = knife:FindFirstChildOfClass("RemoteEvent")
                    if re then re:FireServer(p.Character.HumanoidRootPart.Position) end
                end
            end
        end
    elseif MurdAim then
        local target, dist = nil, 200
        local head = lp.Character:FindFirstChild("Head")
        if head then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
                    local d = (p.Character.Head.Position - head.Position).Magnitude
                    if d < dist then dist = d; target = p end
                end
            end
            if target then
                local re = knife:FindFirstChildOfClass("RemoteEvent")
                if re then re:FireServer(target.Character.Head.Position) end
            end
        end
    end
