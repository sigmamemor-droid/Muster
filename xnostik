    descL.Parent = card

    -- Переключатель
    local switchBg = Instance.new("Frame")
    switchBg.Size = UDim2.new(0, 46, 0, 24)
    switchBg.Position = UDim2.new(1, -58, 0.5, -12)
    switchBg.BorderSizePixel = 0
    switchBg.BackgroundColor3 = default and Cfg.Accent or Color3.fromRGB(40,40,58)
    switchBg.Parent = card
    MakeCorner(switchBg, 12)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.Parent = switchBg
    MakeCorner(knob, 9)

    local enabled = default
    local obj = {Value = enabled}

    local function setState(val, silent)
        enabled = val
        obj.Value = val
        if val then
            Tween(switchBg, {BackgroundColor3 = Cfg.Accent}, 0.2)
            Tween(knob, {Position = UDim2.new(1, -21, 0.5, -9)}, 0.2)
            Tween(stateBar, {BackgroundColor3 = Cfg.Accent}, 0.2)
        else
            Tween(switchBg, {BackgroundColor3 = Color3.fromRGB(40,40,58)}, 0.2)
            Tween(knob, {Position = UDim2.new(0, 3, 0.5, -9)}, 0.2)
            Tween(stateBar, {BackgroundColor3 = Color3.fromRGB(50,50,65)}, 0.2)
        end
        if not silent and callback then
            pcall(callback, val)
        end
    end

    setState(default, true)

    local click = Instance.new("TextButton")
    click.Size = UDim2.new(1, 0, 1, 0)
    click.BackgroundTransparency = 1
    click.Text = ""
    click.Parent = card

    click.MouseButton1Click:Connect(function()
        setState(not enabled)
    end)

    card.MouseEnter:Connect(function()
        Tween(card, {BackgroundColor3 = Cfg.BG4}, 0.15)
    end)
    card.MouseLeave:Connect(function()
        Tween(card, {BackgroundColor3 = Cfg.BG3}, 0.15)
    end)

    obj.Set = setState
    return obj
end

local function Slider(parent, title, desc, min, max, default, suffix, callback)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -16, 0, 68)
    card.BackgroundColor3 = Cfg.BG3
    card.BorderSizePixel = 0
    card.Parent = parent
    MakeCorner(card, 9)
    MakeStroke(card, Color3.fromRGB(40,40,58), 1)

    local titleL = Instance.new("TextLabel")
    titleL.Size = UDim2.new(0.65, 0, 0, 22)
    titleL.Position = UDim2.new(0, 16, 0, 6)
    titleL.BackgroundTransparency = 1
    titleL.Text = title
    titleL.Font = Enum.Font.GothamSemibold
    titleL.TextSize = 13
    titleL.TextColor3 = Cfg.Text
    titleL.TextXAlignment = Enum.TextXAlignment.Left
    titleL.Parent = card

    local valL = Instance.new("TextLabel")
    valL.Size = UDim2.new(0.35, -16, 0, 22)
    valL.Position = UDim2.new(0.65, 0, 0, 6)
    valL.BackgroundTransparency = 1
    valL.Text = tostring(default) .. (suffix or "")
    valL.Font = Enum.Font.GothamBold
    valL.TextSize = 13
    valL.TextColor3 = Cfg.Accent2
    valL.TextXAlignment = Enum.TextXAlignment.Right
    valL.Parent = card

    local descL = Instance.new("TextLabel")
    descL.Size = UDim2.new(1, -32, 0, 16)
    descL.Position = UDim2.new(0, 16, 0, 26)
    descL.BackgroundTransparency = 1
    descL.Text = desc
    descL.Font = Enum.Font.Gotham
    descL.TextSize = 10
    descL.TextColor3 = Cfg.SubText
    descL.TextXAlignment = Enum.TextXAlignment.Left
    descL.Parent = card

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -32, 0, 5)
    track.Position = UDim2.new(0, 16, 0, 50)
    track.BackgroundColor3 = Color3.fromRGB(35,35,50)
    track.BorderSizePixel = 0
    track.Parent = card
    MakeCorner(track, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255,255,255)
    fill.BorderSizePixel = 0
    fill.Parent = track
    MakeCorner(fill, 3)
    MakeGrad(fill,
        Color3.fromRGB(110, 0, 255),
        Color3.fromRGB(210, 80, 255)
    )

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 13, 0, 13)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new((default-min)/(max-min), 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 5
    knob.Parent = track
    MakeCorner(knob, 7)

    local currentVal = default
    local isDragging = false

    local function update(input)
        local rel = math.clamp(
            (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
            0, 1
        )
        local raw = min + (max - min) * rel
        local val = math.floor(raw + 0.5)
        currentVal = val
        valL.Text = tostring(val) .. (suffix or "")
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, 0.5, 0)
        if callback then pcall(callback, val) end
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            update(i)
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if isDragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            update(i)
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = false
        end
    end)

    card.MouseEnter:Connect(function()
        Tween(card, {BackgroundColor3 = Cfg.BG4}, 0.15)
    end)
    card.MouseLeave:Connect(function()
        Tween(card, {BackgroundColor3 = Cfg.BG3}, 0.15)
    end)

    return {GetValue = function() return currentVal end}
end

