    h.Name = "MenuESP"
    h.FillColor = col; h.FillTransparency = 0.3
    h.OutlineColor = C.white; h.OutlineTransparency = 0.15
    h.Adornee = char; h.Parent = char
end

local function ESPPlayer(p, col)
    if p == player then return end
