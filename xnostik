-- VISUALS (ESP)
---------------------------------------------------------
local EspRoles = false
local function ClearRoles() 
    for _, p in ipairs(Players:GetPlayers()) do 
        if p.Character and p.Character:FindFirstChild("OrionESP") then p.Character.OrionESP:Destroy() end 
    end 
end

VisualsTab:AddToggle({
    Name = "Role ESP (Подсветка Ролей)",
    Default = false,
    Callback = function(Value)
        EspRoles = Value
        if not Value then ClearRoles() end
    end
})

local EspGun = false
VisualsTab:AddToggle({
    Name = "Gun ESP (Подсветка Оружия)",
    Default = false,
    Callback = function(Value) EspGun = Value end
})

local activeVisuals = {}
local function ClearDrawings() for _, v in ipairs(activeVisuals) do pcall(function() v:Destroy() end) end; activeVisuals = {} end

RunService.RenderStepped:Connect(function()
    -- Role ESP (Highlight)
    if EspRoles then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local isM, isS = IsMurderer(p), IsSheriff(p)
                local hl = p.Character:FindFirstChild("OrionESP")
                if not hl then
                    hl = Instance.new("Highlight")
                    hl.Name = "OrionESP"
                    hl.Parent = p.Character
                    hl.OutlineTransparency = 0.2
                    hl.FillTransparency = 0.5
                end
                if isM then hl.FillColor = Color3.fromRGB(255, 50, 50)
                elseif isS then hl.FillColor = Color3.fromRGB(50, 150, 255)
                else hl.FillColor = Color3.fromRGB(50, 255, 100) end
            end
        end
    end

    -- Gun ESP
    ClearDrawings()
    if EspGun then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("revolver")) then
                local h = obj:FindFirstChild("Handle")
                if h then
                    local pPos, oS = camera:WorldToViewportPoint(h.Position)
                    if oS then
                        local t = Instance.new("TextLabel")
                        t.Size = UDim2.new(0,60,0,20); t.Position = UDim2.new(0, pPos.X-30, 0, pPos.Y-10)
                        t.BackgroundTransparency = 1; t.Text = "GUN"; t.TextColor3 = Color3.fromRGB(255, 200, 50)
                        t.TextSize = 14; t.Font = Enum.Font.GothamBold; t.Parent = ScreenGui
                        table.insert(activeVisuals, t)
                    end
                end
            end
        end
    end
end)

