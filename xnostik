local Item_ESP = {}
local function MakeItemESP(obj, txt, col)
	if Item_ESP[obj] then return end
	local d = {}
	d.HL = Instance.new("Highlight", obj)
	d.HL.FillColor = col
	d.HL.OutlineColor = col
	d.HL.FillTransparency = 0.6
	d.HL.OutlineTransparency = 0.1
	d.HL.Enabled = false

	d.Bill = Instance.new("BillboardGui", obj)
	d.Bill.Size = UDim2.new(0, 70, 0, 20)
	d.Bill.StudsOffset = Vector3.new(0, 1.8, 0)
	d.Bill.AlwaysOnTop = true
	d.Bill.Enabled = false

	local l = Instance.new("TextLabel", d.Bill)
	l.Size = UDim2.new(1, 0, 1, 0)
	l.BackgroundTransparency = 1
	l.Text = txt
	l.Font = Enum.Font.GothamBold
	l.TextSize = 11
	l.TextColor3 = col

	Item_ESP[obj] = d
	obj.AncestryChanged:Connect(function(_, par)
		if not par then
			pcall(function() d.HL:Destroy() end)
			pcall(function() d.Bill:Destroy() end)
			Item_ESP[obj] = nil
		end
	end)
end

