function Library:TeleportToItem(itemName)
    if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end
    for item, data in pairs(ESPManager.ItemCache) do
        if item and data.Type == itemName then
            local cframe = item:IsA("BasePart") and item.CFrame or item:GetPivot()
            if cframe then
                LP.Character.HumanoidRootPart.CFrame = cframe + Vector3.new(0, 3, 0)
                return
            end
        end
    end
end

if hookmetamethod then
    local old; old = hookmetamethod(game, "__namecall", function(self, ...)
        if State.SilentAim and getnamecallmethod() == "FireServer" and tostring(self):find("Gun") then
            local args = {...}
            local center, bestTarget, bestDist = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2), nil, State.FOV
            for p, data in pairs(ESPManager.PlayerCache) do
                if p.Character and p.Character.Head then
                    local head = p.Character.Head
                    local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestTarget = head
                        end
                    end
                end
            end
            if bestTarget then
                args[2] = bestTarget.Position + (bestTarget.AssemblyLinearVelocity * (State.Prediction / 100))
                return old(self, unpack(args))
            end
        end
        return old(self, ...)
    end)
end

