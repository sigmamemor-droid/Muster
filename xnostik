-- SILENT AIM / AUTO SHOOT (Gun)
local function AutoShootGun()
	local gun = EquipTool("Gun"); if not gun then Notify("Shoot", "No Gun!", C.orange, 2); return end
	local remote = gun:FindFirstChildWhichIsA("RemoteEvent") or gun:FindFirstChild("ShootGun"); if not remote then Notify("Shoot", "Remote Missing", C.orange, 2); return end
	local head = GetMurdererHead(); if not head then Notify("Shoot", "No Target", C.orange, 2); return end
	local root = GetRoot(); if not root then return end
	local pred = PredictPos(head, 250); local origin = root.Position + Vector3.new(0,1.5,0); local dir = (pred - origin).Unit * 300
	pcall(function() remote:FireServer(origin, dir) end); pcall(function() remote:FireServer(pred) end); pcall(function() remote:FireServer("Shoot", pred) end)
	Notify("Silent Aim", "Fired", C.green, 1.5)
end

-- KILL ALL KNIFE (Prediction + Rate Limit)
local function KillAllKnife()
	local knife = EquipTool("Knife"); if not knife then Notify("Kill All", "No Knife!", C.red, 2); return end
	local remote = knife:FindFirstChildWhichIsA("RemoteEvent") or knife:FindFirstChild("ThrowKnife"); if not remote then Notify("Kill All", "Knife Remote Missing", C.orange, 2); return end
	
	local targets = {}; local roles = GetRoles()
	for _, plr in ipairs(Players:GetPlayers()) do if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChildOfClass("Humanoid").Health > 0 then table.insert(targets, plr) end end
	if #targets == 0 then Notify("Kill All", "No Targets", C.orange, 2); return end
	
	Notify("Kill All", "Throwing at "..#targets.." players...", C.orange, 3)
	task.spawn(function()
		for _, plr in ipairs(targets) do
			if not GetChar() or not GetChar():FindFirstChild("Knife") then break end
			local head = plr.Character.Head; local pred = PredictPos(head, 90)
			pcall(function() remote:FireServer(pred) end); pcall(function() remote:FireServer(CFrame.new(GetRoot().Position, pred)) end); pcall(function() remote:FireServer("Throw", pred) end)
			task.wait(0.15) -- Server rate limit safety
		end
		Notify("Kill All", "Done.", C.green, 2)
	end)
end

-- ESP SYSTEMS
local ESP_TAG = "MM2_ESP_HL"; local GUN_TAG = "MM2_GUN_ESP"
local ActiveHighlights = {}; local ActiveGunEsp = {}

local function ClearESP()
	EspMaid:Clean()
	for _, hl in ipairs(CollectionService:GetTagged(ESP_TAG)) do hl:Destroy() end
	ActiveHighlights = {}
end

local function ApplyHL(char, color)
	if not char or char:FindFirstChild(ESP_TAG) then return end
	local hl = Instance.new("Highlight"); hl.Name = ESP_TAG; hl.FillColor = color; hl.FillTransparency = 0.3; hl.OutlineColor = C.white; hl.OutlineTransparency = 0; hl.Adornee = char; hl.Parent = char
	CollectionService:AddTag(hl, ESP_TAG); EspMaid:Give(hl); ActiveHighlights[char] = hl
end

local function UpdateRolesESP()
	local roles = GetRoles()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character then
			local col = C.green
			if plr == roles.Murderer then col = C.red
			elseif plr == roles.Sheriff then col = C.cyan
			elseif plr == roles.Hero then col = C.yellow end
			ApplyHL(plr.Character, col)
		end
	end
end

local function ToggleRolesESP(state)
	States.ESP_Roles = state
	if state then
		UpdateRolesESP()
		EspMaid:Give(RunService.Heartbeat:Connect(function() if tick()%0.15<0.016 then UpdateRolesESP() end end))
		EspMaid:Give(Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() task.wait(1); if States.ESP_Roles then UpdateRolesESP() end end) end))
		Notify("ESP Roles", "Live Updates On", C.accentLight, 2)
	else ClearESP(); Notify("ESP Roles", "Off", C.textDim, 1) end
end

local function ToggleAllESP(state)
