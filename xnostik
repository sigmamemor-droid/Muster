    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0); lbl.Position = UDim2.new(0, 10, 0, 0); lbl.BackgroundTransparency = 1
    lbl.Text = ""; lbl.TextColor3 = C.textDim; lbl.TextSize = 9; lbl.Font = currentFont; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row; updateableLabels[lbl] = labelKey; table.insert(globalTextObjects, lbl)
    local val = Instance.new("TextLabel")
    val.Size = UDim2.new(0.5, -10, 1, 0); val.Position = UDim2.new(0.5, 0, 0, 0); val.BackgroundTransparency = 1
    val.Text = initialValue; val.TextColor3 = valueColor or C.accentLight; val.TextSize = 9; val.Font = Enum.Font.GothamBold; val.TextXAlignment = Enum.TextXAlignment.Right
    val.Parent = row; table.insert(globalTextObjects, val)
    return val
end

