local function Toggle(parent, text, key, cb)
	local f = Instance.new("Frame")
	f.Parent = parent
	f.Size = UDim2.new(1, -4, 0, 38)
	f.BackgroundColor3 = T.BG2
	f.BackgroundTransparency = 0.2
	f.BorderSizePixel = 0
	Corner(f, 8)
	Stroke(f, T.BG3, 1)

	local l = Instance.new("TextLabel")
	l.Parent = f
	l.Size = UDim2.new(1, -70, 1, 0)
	l.Position = UDim2.new(0, 12, 0, 0)
	l.BackgroundTransparency = 1
	l.Text = text
	l.Font = Enum.Font.GothamBold
	l.TextSize = 12
	l.TextColor3 = T.Text
	l.TextXAlignment = Enum.TextXAlignment.Left

	local bg = Instance.new("Frame")
	bg.Parent = f
	bg.Size = UDim2.new(0, 38, 0, 20)
	bg.Position = UDim2.new(1, -50, 0.5, -10)
	bg.BackgroundColor3 = State[key] and T.Accent or T.BG3
	bg.BorderSizePixel = 0
	Corner(bg, 10)

	local knob = Instance.new("Frame")
	knob.Parent = bg
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = State[key] and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
	knob.BackgroundColor3 = T.Text
	knob.BorderSizePixel = 0
	Corner(knob, 7)

	local val = State[key]
	local function Set(v, silent)
		val = v
		State[key] = v
		Tw(bg, nil, {BackgroundColor3 = v and T.Accent or T.BG3})
		Tw(knob, nil, {Position = v and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)})
		if not silent and cb then pcall(cb, v) end
	end

	local hit = Instance.new("TextButton")
	hit.Parent = f
	hit.Size = UDim2.new(1, 0, 1, 0)
	hit.BackgroundTransparency = 1
	hit.Text = ""
	hit.MouseButton1Click:Connect(function() Set(not val) end)

	f.MouseEnter:Connect(function() Tw(f, nil, {BackgroundTransparency = 0}) end)
	f.MouseLeave:Connect(function() Tw(f, nil, {BackgroundTransparency = 0.2}) end)
end

local function Slider(parent, text, min, max, key, suffix, cb)
	local f = Instance.new("Frame")
	f.Parent = parent
	f.Size = UDim2.new(1, -4, 0, 54)
	f.BackgroundColor3 = T.BG2
	f.BackgroundTransparency = 0.2
	f.BorderSizePixel = 0
	Corner(f, 8)
	Stroke(f, T.BG3, 1)

	local l = Instance.new("TextLabel")
	l.Parent = f
	l.Size = UDim2.new(0.6, 0, 0, 22)
	l.Position = UDim2.new(0, 12, 0, 4)
	l.BackgroundTransparency = 1
	l.Text = text
	l.Font = Enum.Font.GothamBold
	l.TextSize = 12
	l.TextColor3 = T.Text
	l.TextXAlignment = Enum.TextXAlignment.Left

	local vl = Instance.new("TextLabel")
	vl.Parent = f
	vl.Size = UDim2.new(0.4, -12, 0, 22)
	vl.Position = UDim2.new(0.6, 0, 0, 4)
	vl.BackgroundTransparency = 1
	vl.Text = tostring(State[key]) .. (suffix or "")
	vl.Font = Enum.Font.GothamBold
	vl.TextSize = 11
	vl.TextColor3 = T.Accent
	vl.TextXAlignment = Enum.TextXAlignment.Right

	local track = Instance.new("Frame")
	track.Parent = f
	track.Size = UDim2.new(1, -24, 0, 4)
	track.Position = UDim2.new(0, 12, 0, 36)
	track.BackgroundColor3 = T.BG3
	track.BorderSizePixel = 0
	Corner(track, 2)

	local fill = Instance.new("Frame")
	fill.Parent = track
	fill.Size = UDim2.new(math.clamp((State[key]-min)/(max-min), 0, 1), 0, 1, 0)
	fill.BackgroundColor3 = T.Accent
	fill.BorderSizePixel = 0
	Corner(fill, 2)

	local knob = Instance.new("Frame")
	knob.Parent = fill
	knob.Size = UDim2.new(0, 12, 0, 12)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(1, 0, 0.5, 0)
	knob.BackgroundColor3 = T.Text
	knob.BorderSizePixel = 0
	Corner(knob, 6)

	local dragging = false
	local function Update(input)
		local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local nval = math.floor(min + (max - min) * rel + 0.5)
		State[key] = nval
		vl.Text = tostring(nval) .. (suffix or "")
		if cb then pcall(cb, nval) end
	end

	track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(i) end end)
	track.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

	f.MouseEnter:Connect(function() Tw(f, nil, {BackgroundTransparency = 0}) end)
	f.MouseLeave:Connect(function() Tw(f, nil, {BackgroundTransparency = 0.2}) end)
end

