            elseif desc:IsA("UIStroke") then
                if desc.Color == Color3.fromRGB(255, 50, 50) or desc.Color == Color3.fromRGB(50, 150, 255) then
                    desc.Color = CurrentAccent
                end
            elseif desc:IsA("ImageLabel") then
