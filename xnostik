-- УЛУЧШЕНИЕ: Аимбот с FOV и плавным наведением (Lerp)
local aimbotFOV = 150
local aimbotSmooth = 0.2
MkToggle("Combat", "aimbot", false, function(a) 
    ClearConn("aim")
    if a then 
        Conn("aim", RunService.RenderStepped:Connect(function() 
            local h = GetMurdererHead()
            if h then 
                local screenPos, onScreen = camera:WorldToScreenPoint(h.Position)
                if onScreen then
                    local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist <= aimbotFOV then
                        local targetCF = CFrame.new(camera.CFrame.Position, h.Position)
                        camera.CFrame = camera.CFrame:Lerp(targetCF, aimbotSmooth)
                    end
                end
            end 
        end)) 
    end 
end)

