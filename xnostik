    local bStroke = Instance.new("UIStroke")
    bStroke.Color       = active and C.green or C.elevated
    bStroke.Thickness   = 1
    bStroke.Transparency = active and 0.5 or 1
    bStroke.Parent      = btn

    local ind = Instance.new("Frame")
    ind.Size            = UDim2.new(0, 3, 0, 16)
    ind.Position        = UDim2.new(0, 8, 0.5, -8)
