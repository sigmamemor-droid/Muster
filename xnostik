-- ===== ROLE DETECTION =====
local function getRole(plr)
    if not plr then return "Innocent" end
    local backpack = plr:FindFirstChild("Backpack")
    local char = plr.Character
    if (backpack and backpack:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife")) then
        return "Murderer" end
    if (backpack and (backpack:FindFirstChild("Gun") or backpack:FindFirstChild("Revolver"))) or (char and (char:FindFirstChild("Gun") or char:FindFirstChild("Revolver"))) then
        return "Sheriff" end
    return "Innocent"
end
local function getMurderer()
    for _,v in pairs(Players:GetPlayers()) do if getRole(v)=="Murderer" then return v end end
end
local function getSheriff()
    for _,v in pairs(Players:GetPlayers()) do if getRole(v)=="Sheriff" then return v end end
end

