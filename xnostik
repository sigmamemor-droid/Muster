-- CHARACTER RESPAWN HANDLER
local function OnCharacterAdded(char)
	CharMaid:Clean(); FlyMaid:Clean()
	local hum = char:WaitForChild("Humanoid", 5); local root = char:WaitForChild("HumanoidRootPart", 5); if not hum or not root then return end
	
	-- Restore States
	if States.SpeedHack then BindHeartbeat("Speed", function() UpdateSpeed() end); UpdateSpeed() end
	if States.JumpHack then BindHeartbeat("Jump", function() UpdateJump() end); UpdateJump() end
	if States.InfJump then CharMaid:Give(UserInputService.JumpRequest:Connect(function() local h=GetHum(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end end)) end
	if States.AntiFling then BindHeartbeat("AntiFling", AntiFlingLoop) end
	if States.Fly then ToggleFly(true) end
	if States.Noclip then ToggleNoclip(true) end
	if States.Fullbright then ToggleFullbright(true) end
	if States.Aimbot then ToggleAimbot(true) end
	if States.ESP_Roles then ToggleRolesESP(true) end
	if States.ESP_All then ToggleAllESP(true) end
	if States.ESP_Guns then ToggleGunESP(true) end
	
	if States.BoomboxPlaying and States.BoomboxLastID ~= "" then task.wait(1.5); PlaySound(States.BoomboxLastID, States.BoomboxLastVol) end
	Notify("System", "Character Loaded", C.accent, 1.5)
end

