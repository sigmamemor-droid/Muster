-- Подтабы (как на картинке: Метки / Передвижение / UIS)
local function SubTabs(parent, tabs)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -28, 0, 38)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.Padding = UDim.new(0, 8)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = frame

    local pages = {}
    local btns = {}
    local current = nil

    local containers = {}
    for _, t in ipairs(tabs) do
        local cont = Instance.new("Frame")
        cont.Size = UDim2.new(1, -28, 0, 0)
        cont.BackgroundTransparency = 1
        cont.Visible = false
        cont.AutomaticSize = Enum.AutomaticSize.Y
        cont.Parent = parent

        local cl = Instance.new("UIListLayout")
        cl.Padding = UDim.new(0, 0)
        cl.SortOrder = Enum.SortOrder.LayoutOrder
        cl.HorizontalAlignment = Enum.HorizontalAlignment.Center
        cl.Parent = cont

        containers[t.id] = cont
        pages[t.id] = cont
    end

    local function SetSub(id)
        current = id
        for _, t in ipairs(tabs) do
            local btn = btns[t.id]
            if not btn then continue end
            if t.id == id then
                Tw(btn, {BackgroundColor3 = C.Pink}, 0.2)
                Tw(btn, {TextColor3 = Color3.fromRGB(255,255,255)}, 0.2)
                containers[t.id].Visible = true
            else
                Tw(btn, {BackgroundColor3 = Color3.fromRGB(0,0,0)}, 0.2)
                btn.BackgroundTransparency = 1
                Tw(btn, {TextColor3 = C.SubText}, 0.2)
                containers[t.id].Visible = false
            end
        end
    end

    for _, t in ipairs(tabs) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 0, 1, 0)
        btn.AutomaticSize = Enum.AutomaticSize.X
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
        btn.BackgroundTransparency = 1
        btn.Text = (t.icon and t.icon .. " " or "") .. t.name
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 12
        btn.TextColor3 = C.SubText
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = false
        btn.Parent = frame

        local bp = Instance.new("UIPadding")
        bp.PaddingLeft = UDim.new(0, 12)
        bp.PaddingRight = UDim.new(0, 12)
        bp.Parent = btn
        Corner(btn, 8)
        Stroke(btn, C.Pink, 1)

        btn.MouseButton1Click:Connect(function()
            SetSub(t.id)
        end)

        btns[t.id] = btn
    end

    -- Активируем первый
    if tabs[1] then SetSub(tabs[1].id) end

    return containers
end

