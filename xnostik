        if IDK.Connections["Aimbot"] then IDK.Connections["Aimbot"]:Disconnect() end
    end
end)

local function GetGunEvent()
    local char = GetCharacter()
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("gun") or tool.Name:lower():find("revolver")) then
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") and v.Name == "Shoot" then return v end
            end
            -- Fallback
            return tool:FindFirstChildOfClass("RemoteEvent", true)
        end
    end
end

CreateButton(TabCombat, "Kill Murderer (Requires Gun)", Theme.Accent, function()
    local target = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and GetRole(p) == "Murderer" and p.Character and p.Character:FindFirstChild("Head") then
            target = p.Character.Head
            break
        end
    end
    
    local remote = GetGunEvent()
    if target and remote then
        remote:FireServer(1, target.Position, "ah") -- Специфика аргументов MM2 может меняться, это стандартный обход
    end
end)

-- ======== VISUALS ========
local function ClearESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("IDK_ESP") then
            p.Character.IDK_ESP:Destroy()
        end
    end
    if IDK.Connections["ESP_Loop"] then IDK.Connections["ESP_Loop"]:Disconnect() end
end

local function CreateESPBox(char, color)
    if char:FindFirstChild("IDK_ESP") then char.IDK_ESP:Destroy() end
    local hl = Instance.new("Highlight")
    hl.Name = "IDK_ESP"
    hl.FillColor = color
    hl.FillTransparency = 0.5
    hl.OutlineColor = color
    hl.OutlineTransparency = 0
    hl.Parent = char
end

CreateToggle(TabVisuals, "Role ESP (Live Update)", false, function(state)
    ClearESP()
    if state then
        IDK.Connections["ESP_Loop"] = RunService.Heartbeat:Connect(function()
            -- Обновление раз в полсекунды для оптимизации (используем tick)
            if not IDK.LastESPTick or tick() - IDK.LastESPTick > 0.5 then
                IDK.LastESPTick = tick()
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character then
                        local role = GetRole(p)
                        if role == "Murderer" then CreateESPBox(p.Character, Theme.Red)
                        elseif role == "Sheriff" then CreateESPBox(p.Character, Color3.fromRGB(40, 120, 255))
                        else CreateESPBox(p.Character, Theme.Green) end
                    end
                end
            end
        end)
    end
end)

