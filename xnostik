task.spawn(function()
    while true do
        if State.KillAll and LP.Character and LP.Character.HumanoidRootPart and (LP.Backpack:FindFirstChild("Knife") or LP.Character:FindFirstChild("Knife")) then
            for p, data in pairs(ESPManager.PlayerCache) do
                if p.Character and p.Character.HumanoidRootPart and (LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude <= State.KillRange then
                    pcall(function() ReplicatedStorage.Remotes.Gameplay.KnifeHit:FireServer(p.Character) end)
                end
            end
            task.wait(0.1)
        else
            task.wait(0.5)
        end
    end
end)

task.spawn(function()
    while true do
        if State.AutoCoin then
            for item, data in pairs(ESPManager.ItemCache) do
                if item and data.Type == "Coin" then
                    pcall(function() ReplicatedStorage.Remotes.Gameplay.CollectCoin:FireServer(item) end)
                end
            end
            task.wait(State.CoinFarmDelay/1000)
        else
            task.wait(1)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        Main.Visible = not Main.Visible
        Tw(Main, TweenInfo.new(0.3), {BackgroundTransparency = Main.Visible and C.BG_Trans or 1})
        Tw(Blur, TweenInfo.new(0.3), {Size = Main.Visible and 16 or 0})
    end
end)

Library:SwitchTab("esp")
Main.Visible = false
task.wait()
Main.Visible = true
Tw(Main, TweenInfo.new(0.4), {BackgroundTransparency = C.BG_Trans})
Tw(Blur, TweenInfo.new(0.4), {Size = 16})
