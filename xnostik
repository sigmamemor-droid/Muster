-- ===== ОСНОВНОЙ ЦИКЛ ОБНОВЛЕНИЯ (теперь с задержкой 0.1 с) =====
task.spawn(function()
	local updateRate = 0.1
	while true do
		task.wait(updateRate)

		-- 1. Обновляем ESP для игроков
		for _, p in pairs(Players:GetPlayers()) do
			if p == LP then continue end
			if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
				if ESP_Data[p] then
					ESP_Data[p].HL.Enabled = false
					ESP_Data[p].Bill.Enabled = false
				end
				continue
			end
			if not ESP_Data[p] then MakeESP(p) end
			local d = ESP_Data[p]
			local role, col = GetRole(p)
			local show = State.ESP and ((role=="Murderer" and State.MurderESP) or (role=="Sheriff" and State.SheriffESP) or (role=="Innocent" and State.InnocentESP))
			pcall(function()
				d.HL.Parent = p.Character
				d.HL.Enabled = show
				d.HL.FillColor = col
				d.HL.OutlineColor = col
				d.Bill.Adornee = p.Character.HumanoidRootPart
				d.Bill.Enabled = show
				d.NameL.Text = p.Name
				d.RoleL.Text = role
				d.RoleL.TextColor3 = col
				local h = p.Character:FindFirstChildOfClass("Humanoid")
				local dist = 0
				if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
					dist = math.floor((LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude)
				end
				d.InfoL.Text = (h and math.floor(h.Health).." HP  " or "")..dist.."m"
			end)
		end

		-- 2. Обновляем ESP предметов
		for obj, d in pairs(Item_ESP) do
			if not obj or not obj.Parent then
				pcall(function() d.HL:Destroy() end)
				pcall(function() d.Bill:Destroy() end)
				Item_ESP[obj] = nil
				continue
			end
			local en = false
			if (obj.Name=="Gun" or obj.Name=="Knife") and State.GunESP then en = true end
			if obj.Name=="Coin" and State.CoinESP then en = true end
			pcall(function() d.HL.Enabled = en; d.Bill.Enabled = en end)
		end

		-- 3. KillAura (раз в 0.2 с)
		if State.KillAura and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
			local has = LP.Character:FindFirstChild("Knife") or LP.Backpack:FindFirstChild("Knife")
			if has then
				for _, p in pairs(Players:GetPlayers()) do
					if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
						local dist = (LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
						if dist <= State.KillRange then
							pcall(function() ReplicatedStorage.Remotes.Gameplay.KnifeHit:FireServer(p.Character) end)
						end
					end
				end
			end
		end

		-- 4. Fullbright / NoFog применяются сразу при изменении, здесь не нужно.

		-- 5. Noclip – включаем/выключаем при изменении State, здесь не нужно.
	end
end)

-- ===== РЕНДЕР-СТЕП ТОЛЬКО ДЛЯ FLY И FOV КРУГА (легковесно) =====
RunService.RenderStepped:Connect(function()
	-- FOV круг
	if FOV_Circle then
		FOV_Circle.Visible = State.SilentAim and State.ShowFOV
		if FOV_Circle.Visible then
			FOV_Circle.Radius = State.FOV
			FOV_Circle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
		end
	end

	-- Fly
	if State.Fly and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
		local r = LP.Character.HumanoidRootPart
		local h = LP.Character:FindFirstChildOfClass("Humanoid")
		if h then h.PlatformStand = true end
		local dir = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end
		if dir.Magnitude > 0 then
			r.CFrame = r.CFrame + dir.Unit * State.FlySpeed / 10
		end
	end
end)

