-- DYNAMIC THEMING UTILS
---------------------------------------------------------
local themedBg = {}
local themedSurface = {}
local themedAccent = {}

local function ApplyTheme(themeName)
    local theme = Themes[themeName]
    if not theme then return end
    
    C.bg = theme.bg
    C.surface = theme.surface
    C.accent = theme.accent
    C.accentLight = theme.accentLight
    
    for _, item in ipairs(themedBg) do if item.Parent then item.BackgroundColor3 = C.bg end end
    for _, item in ipairs(themedSurface) do if item.Parent then item.BackgroundColor3 = C.surface end end
    for _, item in ipairs(themedAccent) do 
        if item.Parent then
            if item:IsA("Frame") or item:IsA("TextButton") then
                item.BackgroundColor3 = C.accent
            elseif item:IsA("TextLabel") then
                item.TextColor3 = C.accentLight
            elseif item:IsA("UIStroke") then
                item.Color = C.accent
            end
        end
    end
end

