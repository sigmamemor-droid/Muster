local function UpdateLanguage(lang)
    currentLang = lang
    for item, key in pairs(updateableLabels) do
        if typeof(item) == "Instance" and (item:IsA("TextLabel") or item:IsA("TextButton") or item:IsA("TextBox")) then item.Text = L[currentLang][key] or key end
    end
end

local function ApplyTheme(themeName)
    local theme = Themes[themeName]; if not theme then return end
    currentThemeName = themeName; C.bg = theme.bg; C.surface = theme.surface; C.accent = theme.accent; C.accentLight = theme.accentLight
    for _, item in ipairs(themedBg) do if item.Parent then item.BackgroundColor3 = C.bg if item.Name == "Hub" or item.Name == "Sidebar" or item.Name == "TopBar" then item.BackgroundTransparency = menuTransparency end end end
    for _, item in ipairs(themedSurface) do if item.Parent then item.BackgroundColor3 = C.surface if item.Name == "TopBar" then item.BackgroundTransparency = menuTransparency end end end
    for _, item in ipairs(themedAccent) do if item.Parent then if item:IsA("Frame") or item:IsA("TextButton") then item.BackgroundColor3 = C.accent elseif item:IsA("TextLabel") then item.TextColor3 = C.accentLight elseif item:IsA("UIStroke") then item.Color = C.accent elseif item:IsA("UIGradient") then item.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, C.accent), ColorSequenceKeypoint.new(1, C.accentLight)}) end end end
end

