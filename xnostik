local function toggle(text, desc, cb, on, order)
    local C = Instance.new("Frame")
    C.Parent = ContentFrame
    C.BackgroundColor3 = Colors.SurfaceLight
    C.BorderSizePixel = 0
    C.Size = UDim2.new(1, 0, 0, desc and 52 or 42)
    C.LayoutOrder = order or 10
    corner(C, 8)
    stroke(C, Colors.Divider, 1, 0.7)
    C.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then tween(C,{BackgroundColor3=Colors.SurfaceHover},0.15) end end)
    C.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then tween(C,{BackgroundColor3=Colors.SurfaceLight},0.15) end end)

    local L = Instance.new("TextLabel")
    L.Parent = C
    L.BackgroundTransparency = 1
    L.Position = UDim2.new(0, 14, 0, desc and 6 or 0)
    L.Size = UDim2.new(0.65, 0, 0, desc and 22 or 42)
    L.Text = text
    L.TextColor3 = Colors.TextPrimary
    L.Font = Enum.Font.GothamSemibold
    L.TextSize = 13
    L.TextXAlignment = Enum.TextXAlignment.Left

    if desc then
        local D = Instance.new("TextLabel")
        D.Parent = C
        D.BackgroundTransparency = 1
        D.Position = UDim2.new(0, 14, 0, 26)
        D.Size = UDim2.new(0.7, 0, 0, 18)
        D.Text = desc
        D.TextColor3 = Colors.TextMuted
        D.Font = Enum.Font.Gotham
        D.TextSize = 11
        D.TextXAlignment = Enum.TextXAlignment.Left
    end

    local Out = Instance.new("TextButton")
    Out.Parent = C
    Out.BackgroundColor3 = on and Colors.Accent or Colors.ToggleOff
    Out.BorderSizePixel = 0
    Out.Size = UDim2.new(0, 44, 0, 22)
    Out.Position = UDim2.new(1, -58, 0.5, -11)
    Out.Text = ""
    Out.AutoButtonColor = false
    corner(Out, 11)

    local Cir = Instance.new("Frame")
    Cir.Parent = Out
    Cir.BackgroundColor3 = Colors.TextPrimary
    Cir.BorderSizePixel = 0
    Cir.Size = UDim2.new(0, 16, 0, 16)
    Cir.Position = on and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
