local function SwitchTab(id)
    if CurrentTab == id then return end
    CurrentTab = id

    for _, def in ipairs(TabDefs) do
        local btn = TabButtons[def.id]
        if not btn then continue end

        if def.id == id then
            Tw(btn.bg, {BackgroundColor3 = C.BG4}, 0.2)
            Tw(btn.label, {TextColor3 = C.Text}, 0.2)
            Tw(btn.icon, {TextColor3 = C.Accent2}, 0.2)
            btn.bar.Visible = true
        else
            Tw(btn.bg, {BackgroundColor3 = Color3.fromRGB(0,0,0)}, 0.2)
            btn.bg.BackgroundTransparency = 1
            Tw(btn.label, {TextColor3 = C.SubText}, 0.2)
            Tw(btn.icon, {TextColor3 = C.SubText}, 0.2)
            btn.bar.Visible = false
        end
    end

    for pid, page in pairs(Pages) do
        page.Visible = pid == id
    end
end

