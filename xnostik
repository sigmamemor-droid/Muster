            tween(Cir, {Position=UDim2.new(0,3,0.5,-8)}, 0.25, Enum.EasingStyle.Back)
        end
        cb(st)
        notify(text, st and "Enabled" or "Disabled", st and Colors.Green or Colors.Red, 2)
    end)
    if on then cb(true) end
    return C
end

