local function GetMurdererHead()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
            if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                return p.Character.Head
            end
        end
    end
    return nil
end

-- ==================== ESP (ДИСТАНЦИЯ + ИМЕНА + ЦВЕТА) ====================
local espObjects = {}

local function GetRoleColor(plr)
    local char = plr.Character
    if not char then return Color3.fromRGB(255, 255, 255) end
    if plr.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
        return Color3.fromRGB(255, 0, 0)
    elseif plr.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
        return Color3.fromRGB(0, 100, 255)
    else
        return Color3.fromRGB(0, 255, 100)
    end
end

local function CreateESP(plr)
    if plr == player then return end
    local function apply(char)
        if not char then return end
        if espObjects[plr] then return end

        local color = GetRoleColor(plr)

        local highlight = Instance.new("Highlight")
        highlight.FillColor = color
        highlight.FillTransparency = 0.35
        highlight.OutlineColor = Color3.fromRGB(255,255,255)
        highlight.Adornee = char
        highlight.Parent = char

        local billboard = Instance.new("BillboardGui")
        billboard.Adornee = char:FindFirstChild("Head")
        billboard.Size = UDim2.new(0, 220, 0, 60)
        billboard.StudsOffset = Vector3.new(0, 4, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = char

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1,0,1,0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color
        label.TextStrokeTransparency = 0.4
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 14
        label.Parent = billboard

        espObjects[plr] = {highlight, billboard, label}

        local conn = RunService.RenderStepped:Connect(function()
            if not (char:FindFirstChild("Head") and player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then return end
            local dist = (char.Head.Position - player.Character.HumanoidRootPart.Position).Magnitude
            label.Text = plr.Name .. "\n[" .. math.floor(dist) .. " studs]"
        end)

        table.insert(espObjects[plr], conn)
    end

    if plr.Character then apply(plr.Character) end
    plr.CharacterAdded:Connect(apply)
end

local function ClearESP()
    for _, objs in pairs(espObjects) do
        for _, obj in ipairs(objs) do
            if typeof(obj) == "RBXScriptConnection" then obj:Disconnect()
            elseif obj then obj:Destroy() end
        end
    end
    espObjects = {}
end

