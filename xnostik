-- GUN SHOOTING (improved: tries multiple remote signatures)
---------------------------------------------------------
local function AttemptShoot(targetHead)
    if not targetHead then return false end
    local tool = FindGunTool()
    if not tool then return false end

    local fired = false
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            -- Try all common argument patterns used by MM2's gun
            pcall(function() v:FireServer(targetHead.Position, targetHead) end)
            pcall(function() v:FireServer(targetHead) end)
            pcall(function() v:FireServer(targetHead.Position) end)
            fired = true
        end
    end
    return fired
end

