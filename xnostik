local currentSound = nil

local function setupSound()
    local lp = player
    if not lp or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil end
    if currentSound then currentSound:Destroy() end
    currentSound = Instance.new("Sound")
    currentSound.Parent = lp.Character.HumanoidRootPart
    currentSound.Looped = true
    return currentSound
end

PlayBtn.MouseButton1Click:Connect(function()
    local audioId = tonumber(AudioInput.Text)
    local vol = tonumber(VolumeInput.Text) or 2
    if audioId then
        local sound = setupSound()
        if sound then
            sound.SoundId = "rbxassetid://" .. audioId
            sound.Volume = vol
            sound:Play()
        end
    end
end)

StopBtn.MouseButton1Click:Connect(function()
    if currentSound then
        currentSound:Stop()
        currentSound:Destroy()
        currentSound = nil
    end
end)

