            }):Play()
        else
            TweenService:Create(SwitchBg, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(50, 40, 65)
            }):Play()
            TweenService:Create(SwitchDot, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 2, 0.5, -9),
                BackgroundColor3 = Colors.TextSecondary
