-- HELPERS
---------------------------------------------------------
local function GetCharacter() return player.Character end
local function GetHumanoid()
    local ch = GetCharacter()
    return ch and ch:FindFirstChildOfClass("Humanoid")
end
local function GetRoot()
    local ch = GetCharacter()
    return ch and ch:FindFirstChild("HumanoidRootPart")
end

local function IsMurderer(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) ~= nil
end

local function IsSheriff(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil
end

local function GetMurdererPart(partName)
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild(partName) then
            return p.Character:FindFirstChild(partName)
        end
    end
    return nil
end

local function FindGunTool()
    local ch = GetCharacter()
    if not ch then return nil end
    local function isGun(n)
        n = n:lower()
        return n == "gun" or n:find("gun") or n:find("pistol") or n:find("revolver")
    end
    for _, v in ipairs(ch:GetChildren()) do
        if v:IsA("Tool") and isGun(v.Name) then return v end
    end
    for _, v in ipairs(player.Backpack:GetChildren()) do
        if v:IsA("Tool") and isGun(v.Name) then return v end
    end
    return nil
end

local function QuickTween(obj, t, props, style, dir)
    return TweenService:Create(obj,
        TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
end

