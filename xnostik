local function GetRole(player)
    if not player.Character then return "Unknown", Color3.fromRGB(200,200,200) end
    local char = player.Character
    local bp = player.Backpack
    if char:FindFirstChild("Knife") or bp:FindFirstChild("Knife") then
        return "MURDERER", Color3.fromRGB(255, 30, 30)
    elseif char:FindFirstChild("Gun") or bp:FindFirstChild("Gun") then
        return "SHERIFF", Color3.fromRGB(30, 140, 255)
    end
    return "INNOCENT", Color3.fromRGB(30, 255, 100)
end

