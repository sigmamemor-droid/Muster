-- MOVEMENT
local function UpdateSpeed() local h=GetHum(); if h then h.WalkSpeed = States.SpeedHack and States.SpeedVal or 16 end end
local function UpdateJump() local h=GetHum(); if h then h.UseJumpPower=true; h.JumpPower = States.JumpHack and States.JumpVal or 50 end end

-- ANTI FLING
local function AntiFlingLoop()
	local root = GetRoot(); if not root then return end
	if root.AssemblyLinearVelocity.Magnitude > 250 then root.AssemblyLinearVelocity = Vector3.zero end
	if root.Position.Y < -50 then root.CFrame = CFrame.new(0, 20, 0); root.AssemblyLinearVelocity = Vector3.zero end
end

-- FLY (Constraints)
local function ToggleFly(state)
	States.Fly = state; FlyMaid:Clean()
	local root = GetRoot(); local hum = GetHum(); if not root or not hum then return end
	if state then
		hum.PlatformStand = true
		local att = root:FindFirstChild("RootAttachment") or Instance.new("Attachment", root); att.Name = "RootAttachment"
		local lv = Instance.new("LinearVelocity"); lv.Attachment0 = att; lv.MaxForce = math.huge; lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector; lv.VectorVelocity = Vector3.zero; lv.Parent = root
		local ao = Instance.new("AlignOrientation"); ao.Attachment0 = att; ao.Mode = Enum.OrientationAlignmentMode.OneAttachment; ao.CFrame = Camera.CFrame; ao.RigidityEnabled = true; ao.MaxTorque = math.huge; ao.Parent = root
		FlyMaid:Give(lv); FlyMaid:Give(ao)
		FlyMaid:Give(RunService.RenderStepped:Connect(function()
			if not lv.Parent then return end
			local dir = Vector3.zero; local cf = Camera.CFrame
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cf.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cf.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cf.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cf.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.yAxis end
			lv.VectorVelocity = dir.Magnitude > 0 and dir.Unit * 50 or Vector3.zero
			ao.CFrame = cf
		end))
		Notify("Fly", "Enabled (Constraints)", C.cyan, 2)
	else
		hum.PlatformStand = false
		Notify("Fly", "Disabled", C.textDim, 1)
	end
end

-- NOCLIP
local function ToggleNoclip(state)
	States.Noclip = state
	if state then BindStepped("Noclip", function() local c=GetChar(); if c then for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end end); Notify("Noclip", "Enabled", C.cyan, 2)
	else Notify("Noclip", "Disabled", C.textDim, 1) end
end

-- FULLBRIGHT
