-- ===== Silent Aim (хук, без изменений) =====
if hookmetamethod then
	local old = hookmetamethod(game, "__namecall", function(self, ...)
		if State.SilentAim and getnamecallmethod() == "FireServer" then
			local n = tostring(self.Name):lower()
			if n:find("shoot") or n:find("gun") or n:find("fire") then
				local args = {...}
				local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
				local best, bd = nil, State.FOV
				for _, p in pairs(Players:GetPlayers()) do
					if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
						local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
						if vis then
							local d = (Vector2.new(pos.X,pos.Y) - center).Magnitude
							if d < bd then bd = d; best = p.Character.Head end
						end
					end
				end
				if best then
					args[1] = best.Position + (best.AssemblyLinearVelocity * (State.Prediction/100))
					return old(self, unpack(args))
				end
			end
		end
		return old(self, ...)
	end)
end

