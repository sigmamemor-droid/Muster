-- ==================== ESP УЛУЧШЕННЫЙ ====================
local espObjects = {}

local function GetRoleColor(plr)
    if not plr.Character then return Color3.fromRGB(200, 200, 200) end
    if plr.Backpack:FindFirstChild("Knife") or plr.Character:FindFirstChild("Knife") then
        return Color3.fromRGB(255, 40, 40)   -- Murderer
    elseif plr.Backpack:FindFirstChild("Gun") or plr.Character:FindFirstChild("Gun") then
        return Color3.fromRGB(40, 120, 255)  -- Sheriff
    else
        return Color3.fromRGB(40, 255, 120)  -- Innocent
    end
end

local function CreateESP(plr)
    if plr == player then return end
    
    local function updateESP(char)
        if not char then return end
        if espObjects[plr] then
            for _, v in pairs(espObjects[plr]) do 
                if v and v.Parent then v:Destroy() end 
            end
        end

        local color = GetRoleColor(plr)

        -- Highlight
        local hl = Instance.new("Highlight")
        hl.FillColor = color
        hl.FillTransparency = 0.4
        hl.OutlineColor = Color3.fromRGB(255,255,255)
        hl.Adornee = char
        hl.Parent = char

        -- Billboard
        local bb = Instance.new("BillboardGui")
        bb.Adornee = char:FindFirstChild("Head")
        bb.Size = UDim2.new(0, 240, 0, 70)
        bb.StudsOffset = Vector3.new(0, 4.5, 0)
        bb.AlwaysOnTop = true
        bb.Parent = char

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1,0,1,0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color
        label.TextStrokeTransparency = 0.3
        label.Font = Enum.Font.GothamBold
        label.TextSize = 15
        label.Parent = bb

        espObjects[plr] = {hl, bb, label}

        -- Реал-тайм обновление
        local conn = RunService.RenderStepped:Connect(function()
            if not char:FindFirstChild("Head") or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
            local dist = (char.Head.Position - player.Character.HumanoidRootPart.Position).Magnitude
            label.Text = string.format("%s\n[%d studs]", plr.Name, math.floor(dist))
        end)

        table.insert(espObjects[plr], conn)
    end

    if plr.Character then updateESP(plr.Character) end
    plr.CharacterAdded:Connect(updateESP)
    
    -- Обновление цвета при смене роли
    plr.CharacterAdded:Connect(function()
        task.wait(0.5)
        if espObjects[plr] then updateESP(plr.Character) end
    end)
end

local function ClearESP()
    for _, objs in pairs(espObjects) do
        for _, obj in ipairs(objs) do
            if typeof(obj) == "RBXScriptConnection" then obj:Disconnect()
            elseif obj and obj.Parent then obj:Destroy() end
        end
    end
    espObjects = {}
end

