local activeTracers = {}
local activeBoxes = {}
local espConnections = {}

local function ClearVisuals()
    for _, draw in ipairs(activeTracers) do pcall(function() draw:Destroy() end) end
    for _, draw in ipairs(activeBoxes) do pcall(function() draw:Destroy() end) end
    activeTracers = {}
    activeBoxes = {}
end

local function DrawLine(p1, p2, col)
    local line = Instance.new("Frame")
    line.BorderSizePixel = 0
    line.BackgroundColor3 = col
    line.ZIndex = 5
    line.Parent = ScreenGui
    table.insert(activeTracers, line)
    
    local distance = (p1 - p2).Magnitude
    line.Size = UDim2.new(0, distance, 0, 1.5)
    line.Position = UDim2.new(0, (p1.X + p2.X)/2 - distance/2, 0, (p1.Y + p2.Y)/2)
    line.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
    return line
end

local function DrawBox(pos, size, col)
    local box = Instance.new("Frame")
    box.BackgroundColor3 = col
    box.BackgroundTransparency = 0.85
    box.Position = UDim2.new(0, pos.X - size.X/2, 0, pos.Y - size.Y/2)
    box.Size = UDim2.new(0, size.X, 0, size.Y)
    box.ZIndex = 4
    box.Parent = ScreenGui
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = col
    stroke.Thickness = 1.5
    stroke.Parent = box
    
    table.insert(activeBoxes, box)
    return box
end

