local Pages, CurrentTab = {}, nil

function Library:CreateTab(id, icon)
    local page = Instance.new("Frame")
    page.Parent = ContentArea
    page.Name = id
    page.Size = UDim2.new(1, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.BackgroundTransparency = 1
    page.Visible = false
    local PageLayout = Instance.new("UIListLayout", page)
    PageLayout.Padding = UDim.new(0, 6)
    PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    Pages[id] = page

    local btn = Instance.new("TextButton")
    btn.Parent = TabContainer
    btn.Size = UDim2.new(0, 35, 1, 0)
    btn.Text = icon
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 18
    btn.TextColor3 = C.SubText
    btn.BackgroundColor3 = C.Element
    btn.BackgroundTransparency = 1
    btn.AutoButtonColor = false
    Corner(btn, 8)

    local highlight = Instance.new("Frame")
    highlight.Parent = btn
    highlight.Size = UDim2.new(1, 0, 0, 3)
    highlight.Position = UDim2.new(0, 0, 1, 0)
    highlight.BackgroundColor3 = C.Accent
    highlight.BorderSizePixel = 0
    highlight.Visible = false
    Corner(highlight, 2)
    
    btn.MouseButton1Click:Connect(function() Library:SwitchTab(id) end)
    btn.MouseEnter:Connect(function() if CurrentTab ~= id then Tw(btn, {TextColor3 = C.Text}, 0.2) end end)
    btn.MouseLeave:Connect(function() if CurrentTab ~= id then Tw(btn, {TextColor3 = C.SubText}, 0.2) end end)
    
    Pages[id].Button = {Btn = btn, Highlight = highlight}
    return page
end

function Library:SwitchTab(id)
    if CurrentTab == id then return end
    CurrentTab = id
    for pageId, pageData in pairs(Pages) do
        local isCurrent = pageId == id
        pageData.Visible = isCurrent
        Tw(pageData.Button.Btn, { TextColor3 = isCurrent and C.Text or C.SubText }, 0.2)
        pageData.Button.Highlight.Visible = isCurrent
    end
end

