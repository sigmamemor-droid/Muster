AddActionButton("🗑 Destroy Menu", Colors.redDark, function()
    for key, conn in pairs(connections) do
        if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
    end
    ClearAllESP()
    StopCurrentSound()

    local hum = GetHumanoid()
    if hum then hum.WalkSpeed = 16 end

    pcall(function() ShotScreenBtn:Destroy() end)
    pcall(function() MagicScreenBtn:Destroy() end)

    -- Анимация закрытия
    TweenService:Create(MainWindow, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0)
    }):Play()
    TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        TextTransparency = 1
    }):Play()

    task.delay(0.4, function()
        ScreenGui:Destroy()
    end)
end)

