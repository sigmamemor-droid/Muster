local function SafeGetCharacter()
    local char = player.Character
    if not char then return nil, nil, nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    return char, humanoid, root
end

local function GetMurderer()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            pcall(function()
                local hasKnife = false
                if p.Character then
                    hasKnife = p.Character:FindFirstChild("Knife") ~= nil
                end
                if not hasKnife and p:FindFirstChild("Backpack") then
                    hasKnife = p.Backpack:FindFirstChild("Knife") ~= nil
                end
                if hasKnife then
                    return p
                end
            end)
        end
    end
    -- Повторний прохід без pcall обгортки return
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            local hasKnife = false
            local ok = pcall(function()
                if p.Character then
                    hasKnife = p.Character:FindFirstChild("Knife") ~= nil
                end
                if not hasKnife and p:FindFirstChild("Backpack") then
                    hasKnife = p.Backpack:FindFirstChild("Knife") ~= nil
                end
            end)
            if ok and hasKnife then
                return p
            end
        end
    end
    return nil
end

local function GetSheriff()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            local hasGun = false
            local ok = pcall(function()
                if p.Character then
                    hasGun = p.Character:FindFirstChild("Gun") ~= nil
                end
                if not hasGun and p:FindFirstChild("Backpack") then
                    hasGun = p.Backpack:FindFirstChild("Gun") ~= nil
                end
            end)
            if ok and hasGun then
                return p
            end
        end
    end
    return nil
end

local function GetPlayerHead(targetPlayer)
    if targetPlayer and targetPlayer.Character then
        return targetPlayer.Character:FindFirstChild("Head")
    end
    return nil
end

local function GetPlayerRoot(targetPlayer)
    if targetPlayer and targetPlayer.Character then
        return targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

