local function TabToggle(tab, text, default, callback)
    local order = tab:NextOrder()
    local isOn = default or false
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 36)
    frame.BackgroundColor3 = P.Card
    frame.BorderSizePixel = 0
    frame.LayoutOrder = order
    frame.Parent = tab.Content
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = P.Text
    label.TextSize = 12
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local switchBg = Instance.new("Frame")
    switchBg.Size = UDim2.new(0, 38, 0, 20)
    switchBg.Position = UDim2.new(1, -50, 0.5, -10)
    switchBg.BackgroundColor3 = isOn and P.Green or Color3.fromRGB(45, 40, 58)
    switchBg.BorderSizePixel = 0
    switchBg.Parent = frame
    Instance.new("UICorner", switchBg).CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 16, 0, 16)
    dot.Position = isOn and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    dot.BackgroundColor3 = P.Text
    dot.BorderSizePixel = 0
    dot.Parent = switchBg
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    
    local clickArea = Instance.new("TextButton")
    clickArea.Size = UDim2.new(1, 0, 1, 0)
    clickArea.BackgroundTransparency = 1
    clickArea.Text = ""
    clickArea.Parent = frame
    
    local function UpdateVisual()
        QuickTween(switchBg, {
            BackgroundColor3 = isOn and P.Green or Color3.fromRGB(45, 40, 58)
        }, 0.18)
        QuickTween(dot, {
            Position = isOn and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        }, 0.18)
    end
    
    clickArea.MouseEnter:Connect(function()
        QuickTween(frame, {BackgroundColor3 = P.CardHover}, 0.12)
    end)
    clickArea.MouseLeave:Connect(function()
        QuickTween(frame, {BackgroundColor3 = P.Card}, 0.12)
    end)
    
    clickArea.MouseButton1Click:Connect(function()
        isOn = not isOn
        UpdateVisual()
        callback(isOn)
    end)
    
    local control = {
        Set = function(state)
            isOn = state
            UpdateVisual()
        end,
        Get = function() return isOn end,
    }
    
    -- Якщо default = true, запускаємо callback
    if default then
        task.defer(function() callback(true) end)
    end
    
    return control
end

local function TabButton(tab, text, color, callback)
    local order = tab:NextOrder()
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.BackgroundColor3 = color or P.Accent
    btn.Text = text
    btn.TextColor3 = P.Text
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.LayoutOrder = order
    btn.Parent = tab.Content
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    CreateRipple(btn)
    
    btn.MouseEnter:Connect(function()
        QuickTween(btn, {BackgroundColor3 = Color3.new(
            math.min((color or P.Accent).R + 0.07, 1),
            math.min((color or P.Accent).G + 0.07, 1),
            math.min((color or P.Accent).B + 0.07, 1)
        )}, 0.12)
    end)
    btn.MouseLeave:Connect(function()
        QuickTween(btn, {BackgroundColor3 = color or P.Accent}, 0.12)
    end)
    
    btn.MouseButton1Click:Connect(function()
        callback(btn)
    end)
    
    return btn
end

