-- Animate
local function DoLoad()
    -- Logo pop
    Logo.Size = UDim2.new(0, 0, 0, 0)
    Logo.Position = UDim2.new(0.5, 0, 0, 110)
    TweenService:Create(Glow, TweenInfo.new(0.6), {ImageTransparency = 0.5}):Play()
    task.wait(0.2)
    TweenService:Create(Logo, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 80, 0, 80),
        Position = UDim2.new(0.5, -40, 0, 70)
    }):Play()

    -- Pulse
    task.spawn(function()
        while Logo.Parent and LoadScreen.Parent do
            TweenService:Create(LS, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0}):Play()
            task.wait(0.7)
            TweenService:Create(LS, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.5}):Play()
            task.wait(0.7)
        end
    end)

    task.wait(0.4)
    TweenService:Create(LoadTitle, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.15)
    TweenService:Create(LoadSub, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.1)
    TweenService:Create(LoadStat, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadPct, TweenInfo.new(0.3), {TextTransparency = 0}):Play()

    local stages = {
        {0.12, "Core engine...", 0.2},
        {0.28, "UI framework...", 0.2},
        {0.42, "Sidebar & tabs...", 0.2},
        {0.56, "ESP module...", 0.15},
        {0.68, "Combat system...", 0.2},
        {0.80, "Boombox engine...", 0.15},
        {0.92, "Anti-detection...", 0.2},
        {1.00, "✓ Ready", 0.15},
    }

    for _, s in ipairs(stages) do
        TweenService:Create(PFill, TweenInfo.new(s[3], Enum.EasingStyle.Quad), {
            Size = UDim2.new(s[1], 0, 1, 0)
        }):Play()
        LoadStat.Text = s[2]
        LoadPct.Text = math.floor(s[1] * 100) .. "%"
        task.wait(s[3] + 0.03)
    end

    LoadStat.TextColor3 = C.green
    LoadPct.TextColor3 = C.green
    task.wait(0.4)

    -- Fade out
    for _, ch in ipairs(LC:GetDescendants()) do
        if ch:IsA("TextLabel") then
            TweenService:Create(ch, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        elseif ch:IsA("Frame") then
            TweenService:Create(ch, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
            local st = ch:FindFirstChildOfClass("UIStroke")
            if st then TweenService:Create(st, TweenInfo.new(0.3), {Transparency = 1}):Play() end
        elseif ch:IsA("ImageLabel") then
            TweenService:Create(ch, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
        end
    end
    TweenService:Create(LoadScreen, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
    task.wait(0.5)
    LoadScreen:Destroy()
end

DoLoad()

