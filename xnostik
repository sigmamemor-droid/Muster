getESPRolesState = TabAddToggle("ESP", "ESP Roles (Live)", false, function(active)
    ClearAllESP()
    ClearConnection("esp_roles_loop")
    ClearConnection("esp_roles_new")
    espRolesCounter = 0

    if active then
        local function UpdateRoles()
            for _, p in ipairs(Players:GetPlayers()) do
                if p == player then continue end
                if not p.Character then continue end
                if IsMurderer(p) then
                    ApplyHighlight(p.Character, Color3.fromRGB(255, 40, 40))
                elseif IsSheriff(p) then
                    ApplyHighlight(p.Character, Color3.fromRGB(40, 100, 255))
                else
                    ApplyHighlight(p.Character, Color3.fromRGB(40, 230, 100))
                end
            end
        end
        UpdateRoles()
        connections["esp_roles_loop"] = RunService.Heartbeat:Connect(function()
            espRolesCounter = espRolesCounter + 1
            if espRolesCounter >= 120 then
                espRolesCounter = 0
                if getESPRolesState() then UpdateRoles() end
            end
        end)
        connections["esp_roles_new"] = Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function()
                task.wait(1)
                if getESPRolesState() then UpdateRoles() end
            end)
        end)
    end
end)

