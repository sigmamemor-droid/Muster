    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 10)

    local S = Instance.new("UIStroke")
    S.Color = color
    S.Thickness = 1
    S.Transparency = 0.5
    S.Parent = Card

    local Bar = Instance.new("Frame")
    Bar.Size = UDim2.new(0, 4, 1, -8)
    Bar.Position = UDim2.new(0, 4, 0, 4)
    Bar.BackgroundColor3 = color
    Bar.BorderSizePixel = 0
    Bar.ZIndex = 202
    Bar.Parent = Card
    Instance.new("UICorner", Bar).CornerRadius = UDim.new(1, 0)

    local T = Instance.new("TextLabel")
    T.Size = UDim2.new(1, -22, 0, 20)
    T.Position = UDim2.new(0, 16, 0, 6)
    T.BackgroundTransparency = 1
    T.Text = title
    T.TextColor3 = color
    T.TextSize = 12
    T.Font = Enum.Font.GothamBold
    T.TextXAlignment = Enum.TextXAlignment.Left
    T.TextTruncate = Enum.TextTruncate.AtEnd
    T.ZIndex = 202
    T.Parent = Card

    local M = Instance.new("TextLabel")
    M.Size = UDim2.new(1, -22, 0, 24)
    M.Position = UDim2.new(0, 16, 0, 26)
    M.BackgroundTransparency = 1
    M.Text = msg
    M.TextColor3 = C.textSec
    M.TextSize = 11
    M.Font = Enum.Font.Gotham
    M.TextXAlignment = Enum.TextXAlignment.Left
    M.TextWrapped = true
    M.TextTruncate = Enum.TextTruncate.AtEnd
    M.ZIndex = 202
    M.Parent = Card

    -- Slide in from right
    Card.Position = UDim2.new(1.2, 0, 0, 0)
    TweenService:Create(Card, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    task.delay(dur, function()
        if not Card.Parent then return end
        local tw = TweenService:Create(Card, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Position = UDim2.new(1.2, 0, 0, 0)
        })
        tw:Play()
        tw.Completed:Connect(function() pcall(function() Card:Destroy() end) end)
    end)
end

