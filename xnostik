        b.TextColor3      = C.text
        b.TextSize        = 14
        b.Font            = Enum.Font.GothamBold
        b.AutoButtonColor = false
        b.LayoutOrder     = ord
        b.Parent          = container
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 7)
        return b
    end

    local playBtn = RowBtn("▶ PLAY", C.green, 1)
    local stopBtn = RowBtn("■ STOP", C.red,   2)

    playBtn.MouseButton1Click:Connect(function()
        if PlaySound(AudioInput.Text, VolumeInput.Text) then
            QuickTween(playBtn, 0.1, {BackgroundColor3 = Color3.fromRGB(80,255,120)}):Play()
            task.delay(0.35, function()
                QuickTween(playBtn, 0.2, {BackgroundColor3 = C.green}):Play()
            end)
        end
    end)

    stopBtn.MouseButton1Click:Connect(function()
        StopSound()
        QuickTween(stopBtn, 0.1, {BackgroundColor3 = Color3.fromRGB(255,100,100)}):Play()
        task.delay(0.35, function()
            QuickTween(stopBtn, 0.2, {BackgroundColor3 = C.red}):Play()
        end)
    end)
end

