AddSeparator("ESP VISUALS")

-- Хранилище ESP-соединений
local espConnections = {}

local function ClearAllESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("MenuESP") then
            p.Character.MenuESP:Destroy()
        end
    end
    for key, conn in pairs(espConnections) do
        if typeof(conn) == "RBXScriptConnection" then
            conn:Disconnect()
        end
        espConnections[key] = nil
    end
end

local function ApplyHighlight(char, color)
    if not char then return end
    if char:FindFirstChild("MenuESP") then char.MenuESP:Destroy() end

    local hl = Instance.new("Highlight")
    hl.Name = "MenuESP"
    hl.FillColor = color
    hl.FillTransparency = 0.35
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.OutlineTransparency = 0.3
    hl.Adornee = char
    hl.Parent = char
end

local function ApplyESPToPlayer(p, color)
    if p == player then return end
    if p.Character then
        ApplyHighlight(p.Character, color)
    end
    local connKey = "esp_char_" .. p.UserId
    if espConnections[connKey] then espConnections[connKey]:Disconnect() end
    espConnections[connKey] = p.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        ApplyHighlight(char, color)
    end)
end

-- ESP ALL
local getESPAllState
getESPAllState = AddToggleButton("ESP All Players", false, function(active)
    ClearAllESP()
    ClearConnection("esp_new_player")
    if active then
        for _, p in ipairs(Players:GetPlayers()) do
            ApplyESPToPlayer(p, Color3.fromRGB(220, 220, 255))
        end
        connections["esp_new_player"] = Players.PlayerAdded:Connect(function(p)
            if getESPAllState() then
                ApplyESPToPlayer(p, Color3.fromRGB(220, 220, 255))
            end
        end)
    end
end)

-- ESP ROLES (постоянно обновляется)
local getESPRolesState
getESPRolesState = AddToggleButton("ESP Roles (Live)", false, function(active)
    ClearAllESP()
    ClearConnection("esp_roles_loop")
    ClearConnection("esp_roles_new")
    if active then
        local function UpdateRoles()
            for _, p in ipairs(Players:GetPlayers()) do
                if p == player then continue end
                if not p.Character then continue end
                if IsMurderer(p) then
                    ApplyHighlight(p.Character, Color3.fromRGB(255, 40, 40))
                elseif IsSheriff(p) then
                    ApplyHighlight(p.Character, Color3.fromRGB(40, 100, 255))
                else
                    ApplyHighlight(p.Character, Color3.fromRGB(40, 230, 100))
                end
            end
        end

        UpdateRoles()

        -- Обновление каждые 2 секунды
        connections["esp_roles_loop"] = RunService.Heartbeat:Connect(function()
            -- Throttle: обновляем каждые 120 кадров (~2 секунды)
            if not connections["_esp_counter"] then connections["_esp_counter"] = 0 end
            connections["_esp_counter"] = connections["_esp_counter"] + 1
            if connections["_esp_counter"] >= 120 then
                connections["_esp_counter"] = 0
                UpdateRoles()
            end
        end)

        connections["esp_roles_new"] = Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function()
                task.wait(1)
                if getESPRolesState() then UpdateRoles() end
            end)
        end)
    end
end)

