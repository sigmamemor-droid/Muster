local AudioInput = TabAddInput("Music", "Audio ID...", "")
local VolumeInput = TabAddInput("Music", "Volume (0.5 - 5)", "2")

local currentSound = nil
local soundWasPlaying = false
local lastAudioId = ""
local lastVolume = "2"

local function CreateAndPlaySound(audioId, volume)
    if currentSound then
        pcall(function() currentSound:Stop() end)
        pcall(function() currentSound:Destroy() end)
        currentSound = nil
    end
    local root = GetRoot()
    if not root then return false end
    local id = tonumber(audioId)
    if not id then return false end
    local vol = math.clamp(tonumber(volume) or 2, 0, 5)

    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. id
    sound.Volume = vol
    sound.Looped = true
    sound.Parent = root
    sound:Play()

    currentSound = sound
    soundWasPlaying = true
    lastAudioId = tostring(audioId)
    lastVolume = tostring(volume)
    return true
end

local function StopCurrentSound()
    if currentSound then
        pcall(function() currentSound:Stop() end)
        pcall(function() currentSound:Destroy() end)
        currentSound = nil
    end
    soundWasPlaying = false
end

