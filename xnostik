local espMurdEnabled, espSherEnabled, espInnEnabled, espGunEnabled, espCoinEnabled = false, false, false, false, false
local espTracersEnabled, espBoxesEnabled = false, false
local activeVisuals = {}

local function ClearVisuals() for _, v in ipairs(activeVisuals) do pcall(function() v:Destroy() end) end; activeVisuals = {} end

local function CreateESPData(p, isM, isS)
    local root = p.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local pos, onScreen = camera:WorldToViewportPoint(root.Position)
    if onScreen then
        local col = Color3.fromRGB(50,255,100); local roleTx = "INNOCENT"
        if isM then col = Color3.fromRGB(255,50,50); roleTx = "MURDERER" elseif isS then col = Color3.fromRGB(50,150,255); roleTx = "SHERIFF" end
        
        if espTracersEnabled then
            local line = Instance.new("Frame"); line.BorderSizePixel = 0; line.BackgroundColor3 = col; line.ZIndex = 5; line.Parent = ScreenGui; table.insert(activeVisuals, line)
            local p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y); local p2 = Vector2.new(pos.X, pos.Y)
            local dist = (p1 - p2).Magnitude; line.Size = UDim2.new(0, dist, 0, 1.5); line.Position = UDim2.new(0, (p1.X + p2.X)/2 - dist/2, 0, (p1.Y + p2.Y)/2); line.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
        end
        if espBoxesEnabled then
            local dist = math.floor((camera.CFrame.Position - root.Position).Magnitude)
            local h = (camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0)).Y)
            local w = h * 0.6
            local box = Instance.new("Frame"); box.BackgroundColor3 = col; box.BackgroundTransparency = 0.85; box.Position = UDim2.new(0, pos.X - w/2, 0, pos.Y - h/2); box.Size = UDim2.new(0, w, 0, h); box.ZIndex = 4; box.Parent = ScreenGui; table.insert(activeVisuals, box)
            Instance.new("UIStroke", box).Color = col
            local tx = Instance.new("TextLabel"); tx.Size = UDim2.new(1,0,0,15); tx.Position = UDim2.new(0,0,1,2); tx.BackgroundTransparency = 1; tx.Text = p.Name.." ["..dist.."s]\n"..roleTx; tx.TextColor3 = col; tx.TextSize = 9; tx.Font = Enum.Font.GothamBold; tx.Parent = box; tx.TextYAlignment = Enum.TextYAlignment.Top
        end
    end
end

RunService.RenderStepped:Connect(function()
    ClearVisuals()
    if espTracersEnabled or espBoxesEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                local isM, isS = IsMurderer(p), IsSheriff(p)
                if (isM and espMurdEnabled) or (isS and espSherEnabled) or (not isM and not isS and espInnEnabled) then CreateESPData(p, isM, isS) end
