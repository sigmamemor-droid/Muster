local targetPlayerName = ""
MkPlayerDropdown("Combat", "Target", function(selection) targetPlayerName = selection end)
MkToggle("Combat", "Fling Target (Beyblade)", false, function(state)
    ClearConn("fling")
    if state then
        if targetPlayerName == "" then Notify("Fling", "Select a target first!", C.orange, 2); return end
        local tP = Players:FindFirstChild(targetPlayerName)
        if not tP or not tP.Character then Notify("Fling", "Target not found", C.orange, 2); return end
        
        local h = GetHum()
        if h then h.PlatformStand = true end
        Conn("fling", RunService.Stepped:Connect(function()
            local r = GetRoot()
            local tChar = tP.Character
            if r and tChar and tChar:FindFirstChild("HumanoidRootPart") then
                -- Disable collisions to merge inside target
                for _, v in ipairs(GetChar():GetChildren()) do if v:IsA("BasePart") then v.CanCollide = false end end
                -- Spin extremely fast
                r.AssemblyAngularVelocity = Vector3.new(0, 99999, 0)
                -- Teleport repeatedly into target
                r.CFrame = tChar.HumanoidRootPart.CFrame
                r.AssemblyLinearVelocity = Vector3.zero
            else
                Notify("Fling", "Target lost or died", C.textDim, 2)
                ClearConn("fling")
                if GetHum() then GetHum().PlatformStand = false end
            end
        end))
        Notify("Fling", "Flinging " .. targetPlayerName .. "...", C.red, 3)
    else
        local h = GetHum()
        if h then h.PlatformStand = false end
        local r = GetRoot()
        if r then r.AssemblyAngularVelocity = Vector3.zero end
        Notify("Fling", "Fling stopped", C.textDim, 2)
    end
end)

