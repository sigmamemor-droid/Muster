-- Aimbot System Calculation
local function getClosestMurdererToFOV()
    local targetChar = getMurderer()
    if not targetChar then return nil end
    local head = targetChar:FindFirstChild("Head")
    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
    if not head or not hrp then return nil end
    
    local selfChar = LocalPlayer.Character
    if selfChar and selfChar:FindFirstChild("HumanoidRootPart") then
        if (selfChar.HumanoidRootPart.Position - hrp.Position).Magnitude > Config.AimbotRange then
            return nil
        end
    end
    
    local scrPos, onScreen = Camera:WorldToViewportPoint(head.Position)
    if onScreen then
        local delta = (Vector2.new(scrPos.X, scrPos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
        if delta <= Config.AimbotFOV then
            return head
        end
    end
    return nil
end

local function executeGunAction()
    local char = LocalPlayer.Character
    if not char then return false end
    
    local tool = char:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function() tool:Activate() end)
        return true
    end
    
    pcall(function()
        for _, rem in ipairs(char:GetDescendants()) do
            if rem:IsA("RemoteEvent") and rem.Name:lower():find("shoot") then
                rem:FireServer(Camera.CFrame.Position + (Camera.CFrame.LookVector * 100))
                return true
            end
        end
    end)
    return false
end

-- Metatable Hooker (Silent Aim & Wall Shoot)
local NamecallHook = nil
local function hookAimEvents()
    if NamecallHook then return end
    NamecallHook = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if method == "FireServer" and (Config.SilentAim or Config.Aimbot) then
            local targetChar = getMurderer()
            if targetChar then
                local targetPart = targetChar:FindFirstChild("Head") or targetChar:FindFirstChild("HumanoidRootPart")
                if targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (LocalPlayer.Character.HumanoidRootPart.Position - targetPart.Position).Magnitude
                    if dist <= Config.AimbotRange then
                        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
                        local spoofed = {}
                        for i, v in ipairs(args) do
                            if typeof(v) == "Vector3" then
                                spoofed[i] = targetPart.Position
                            elseif typeof(v) == "CFrame" then
                                spoofed[i] = CFrame.new(targetPart.Position)
                            else
                                spoofed[i] = v
                            end
                        end
                        return NamecallHook(self, spoofed)
                    end
                end
            end
        end
        
        return NamecallHook(self, unpack(args))
    end))
end

