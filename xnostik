local function setupTabSystem(parent, tabNames)
    local tabBtnContainer = Instance.new("Frame")
    tabBtnContainer.Size = UDim2.new(1, 0, 0, 30)
    tabBtnContainer.Position = UDim2.new(0, 0, 0, 20)
    tabBtnContainer.BackgroundTransparency = 1
    tabBtnContainer.Parent = parent
    
    local tabBtns, tabFrames = {}, {}
    local activeLine = Instance.new("Frame")
    activeLine.Size = UDim2.new(0, 60, 0, 2)
    activeLine.BackgroundColor3 = CurrentAccent
    activeLine.BorderSizePixel = 0
    activeLine.ZIndex = 25
    activeLine.Parent = tabBtnContainer
    activeLine.Visible = false
    activeLine.Position = UDim2.new(0, 0, 0, -4)
    
    local activeTab = tabNames[1]
    
    local function selectTab(targetTab)
        activeTab = targetTab
        for tName, btn in pairs(tabBtns) do
            btn.TextColor3 = Color3.fromRGB(140, 140, 150)
        end
        for tName, fr in pairs(tabFrames) do
            fr.Visible = false
        end
        
        local activeBtn = tabBtns[targetTab]
        if activeBtn then
            activeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            activeLine.Visible = true
            local lineOffset = activeBtn.AbsolutePosition.X - tabBtnContainer.AbsolutePosition.X
            activeLine.Position = UDim2.new(0, lineOffset, 0, -4)
            activeLine.Size = UDim2.new(0, activeBtn.AbsoluteSize.X, 0, 2)
        end
        if tabFrames[targetTab] then
            tabFrames[targetTab].Visible = true
        end
    end
    
    for idx, tName in ipairs(tabNames) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 60, 1, 0)
        btn.Position = UDim2.new(0, (idx - 1) * 65, 0, 0)
        btn.BackgroundTransparency = 1
        btn.Text = tName
        btn.TextColor3 = (idx == 1) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 150)
        btn.Font = Enum.Font.Gotham; btn.TextSize = 11
        btn.Parent = tabBtnContainer
        btn.AutoButtonColor = false
        tabBtns[tName] = btn
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 1, -55)
        frame.Position = UDim2.new(0, 0, 0, 55)
        frame.BackgroundTransparency = 1
        frame.Visible = (idx == 1)
        frame.Parent = parent
        tabFrames[tName] = frame
        
        btn.MouseButton1Click:Connect(function()
            selectTab(tName)
        end)
    end
    
    return tabFrames
end

