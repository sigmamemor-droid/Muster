    TC.BorderSizePixel = 0
    TC.ZIndex = 12
    TC.Parent = TBG
    Instance.new("UICorner", TC).CornerRadius = UDim.new(1, 0)

    local function Upd()
        TweenService:Create(B, TweenInfo.new(0.18), {BackgroundColor3 = active and C.greenDark or C.elevated}):Play()
        TweenService:Create(BS, TweenInfo.new(0.18), {Color = active and C.green or C.elevated, Transparency = active and 0.5 or 1}):Play()
        TweenService:Create(Ind, TweenInfo.new(0.18), {BackgroundColor3 = active and C.green or C.textMuted}):Play()
        TweenService:Create(TBG, TweenInfo.new(0.18), {BackgroundColor3 = active and C.green or C.textMuted}):Play()
        TweenService:Create(TC, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
            Position = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        }):Play()
    end

    B.MouseEnter:Connect(function()
        if not active then TweenService:Create(B, TweenInfo.new(0.1), {BackgroundColor3 = C.cardHover}):Play() end
    end)
    B.MouseLeave:Connect(function()
        if not active then TweenService:Create(B, TweenInfo.new(0.1), {BackgroundColor3 = C.elevated}):Play() end
    end)

    B.MouseButton1Click:Connect(function()
        active = not active
        Upd()
        cb(active)
    end)

    return function() return active end, function(s) active = s; Upd() end
end

