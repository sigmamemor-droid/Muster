local function GetChar() return player.Character end
local function GetHum() local c = GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function IsMurderer(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) ~= nil
end

local function IsSheriff(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil
end

local function IsHero(p)
    if p == player or not p.Character or IsMurderer(p) then return false end
    return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil
end

local function GetMurdererRoot()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then return p.Character.HumanoidRootPart end
    end
end

local function GetMurdererHead()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild("Head") then return p.Character.Head end
    end
end

local function GetTool(toolName)
    local c = GetChar()
    if c and c:FindFirstChild(toolName) then return c:FindFirstChild(toolName) end
    if player.Backpack and player.Backpack:FindFirstChild(toolName) then return player.Backpack:FindFirstChild(toolName) end
    return nil
end

local function FindGunInHand()
    local c = GetChar(); if not c then return nil end
    for _, v in ipairs(c:GetChildren()) do
        if v:IsA("Tool") and (v.Name:lower():find("gun") or v.Name:lower():find("revolver")) then return v end
    end
end

local function FindKnifeInHand()
    local c = GetChar(); if not c then return nil end
    for _, v in ipairs(c:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find("knife") then return v end
    end
end

local function FireGunAtTarget(gun, targetHead)
    if not gun or not targetHead then return false end
    for _, v in ipairs(gun:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            pcall(function() v:FireServer(targetHead.Position, targetHead) end)
            return true
        end
    end
end

local function ThrowKnifeAtTarget(knife, targetPos)
    if not knife or not targetPos then return false end
    for _, v in ipairs(knife:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            pcall(function() v:FireServer(targetPos) end)
            return true
        end
    end
end

