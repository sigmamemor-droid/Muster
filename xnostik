local function GetCharacter()
    return player.Character
end

local function GetHumanoid()
    local char = GetCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function GetRoot()
    local char = GetCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

---------------------------------------------------------
-- ОПРЕДЕЛЕНИЕ РОЛЕЙ MM2
---------------------------------------------------------
local function IsMurderer(p)
    if p == player then return false end
    if not p.Character then return false end
    local found = p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")
    return found ~= nil
end

local function IsSheriff(p)
    if p == player then return false end
    if not p.Character then return false end
    local found = p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")
    return found ~= nil
end

local function GetMurdererHead()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character:FindFirstChild("Head") then
            return p.Character.Head
        end
    end
    return nil
end

local function GetMurdererRoot()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character:FindFirstChild("HumanoidRootPart") then
            return p.Character.HumanoidRootPart
        end
    end
    return nil
end

