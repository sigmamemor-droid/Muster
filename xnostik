---------------------------------------------------------
local function FindAndShoot(targetHead)
    local char = player.Character
    if not char then return end
    local tool = nil
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            local n = v.Name:lower()
            if n:find("gun") or n:find("pistol") or n:find("revolver") or n:find("shoot") then
                tool = v
                break
            end
        end
    end
    if not tool then return end
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            pcall(function() v:FireServer(targetHead.Position, targetHead) end)
            pcall(function() v:FireServer(targetHead) end)
            pcall(function() v:FireServer(targetHead.Position) end)
            return
        end
    end
end

