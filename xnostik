-- ===== CHEAT LOGIC =====
local function clearESP(name)
    for _,v in pairs(ESPFolder:GetChildren()) do if not name or v.Name:find(name) then v:Destroy() end end
end
local function createESP(plr, color, text)
    if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
    if ESPFolder:FindFirstChild(plr.Name.."_ESP") then ESPFolder[plr.Name.."_ESP"]:Destroy() end
    local bill = Instance.new("BillboardGui")
    bill.Name = plr.Name.."_ESP"
    bill.Adornee = plr.Character.HumanoidRootPart
    bill.Size = UDim2.new(0,200,0,50)
    bill.StudsOffset = Vector3.new(0,3,0)
    bill.AlwaysOnTop = true
    bill.Parent = ESPFolder
    local txt = Instance.new("TextLabel", bill)
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.Text = text
    txt.TextColor3 = color
    txt.TextStrokeTransparency = 0
    txt.TextScaled = true
    txt.Font = Enum.Font.GothamBold
    local hl = Instance.new("Highlight")
    hl.Name = plr.Name.."_HL"
    hl.Adornee = plr.Character
    hl.FillColor = color
    hl.OutlineColor = Color3.new(1,1,1)
    hl.FillTransparency = 0.55
    hl.OutlineTransparency = 0
    hl.Parent = ESPFolder
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
end

local function getGunDrop()
    for _,v in pairs(Workspace:GetDescendants()) do if v.Name=="GunDrop" and v:IsA("BasePart") then return v end end
end
local function tpToGun()
    local gun = getGunDrop()
    if gun and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        LP.Character.HumanoidRootPart.CFrame = gun.CFrame + Vector3.new(0,3,0)
        notify("Gun grabbed!")
    end
end
_G.__mm2_gungrab = tpToGun

local function killPlayer(target)
    if not target or not target.Character then return end
    if getRole(LP) ~= "Murderer" then return end
    local char = LP.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local knife = char:FindFirstChild("Knife") or LP.Backpack:FindFirstChild("Knife")
    if knife then
        LP.Character.Humanoid:EquipTool(knife)
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            char.HumanoidRootPart.CFrame = hrp.CFrame + Vector3.new(0,0,1.8)
            task.wait(0.06)
            pcall(function()
                for _,v in pairs(knife:GetDescendants()) do
                    if v:IsA("RemoteEvent") then v:FireServer("Slash") end
                end
            end)
        end
    end
end
_G.__mm2_killnearest = function()
    local nearest, dist = nil, 999
    for _,p in pairs(Players:GetPlayers()) do
        if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - LP.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist=d nearest=p end
        end
    end
    if nearest then killPlayer(nearest) end
end
_G.__mm2_killall = function()
    for _,p in pairs(Players:GetPlayers()) do if p~=LP then killPlayer(p) task.wait(0.18) end end
end

local function shootMurderer()
    local murderer = getMurderer()
    if not murderer or not murderer.Character then notify("Murderer not found", Color3.fromRGB(255,90,90)) return end
    local gun = LP.Character and (LP.Character:FindFirstChild("Gun") or LP.Character:FindFirstChild("Revolver"))
        or LP.Backpack:FindFirstChild("Gun") or LP.Backpack:FindFirstChild("Revolver")
    if gun then
        LP.Character.Humanoid:EquipTool(gun)
        task.wait(0.07)
        pcall(function()
            local targetPos = murderer.Character.HumanoidRootPart.Position
            for _,v in pairs(gun:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    v:FireServer(1, targetPos, "AH2")
                end
            end
        end)
        notify("Shot at "..murderer.Name, Color3.fromRGB(0,200,255))
    else
        notify("No gun!", Color3.fromRGB(255,90,90))
    end
end
_G.__mm2_shoot = shootMurderer

-- Render loop
RunService.RenderStepped:Connect(function()
    if Toggles.LoopSpeed and LP.Character and LP.Character:FindFirstChild("Humanoid") then
        LP.Character.Humanoid.WalkSpeed = Values.WalkSpeed
    end
    if Toggles.PlayerESP then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local role = getRole(plr)
                local color = role=="Murderer" and Color3.fromRGB(255,55,75) or role=="Sheriff" and Color3.fromRGB(55,150,255) or Color3.fromRGB(80,255,120)
                if role ~= "Innocent" or Toggles.ShowInnocent then
                    createESP(plr, color, plr.Name.." ["..role.."]")
                end
            end
        end
    end
    if Toggles.CoinESP or Toggles.CoinMagnet then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v.Name:find("Coin") and v:IsA("BasePart") and v.Transparency < 1 then
                if Toggles.CoinESP and not ESPFolder:FindFirstChild("coin_"..v:GetDebugId()) then
                    local bb=Instance.new("BillboardGui", ESPFolder)
                    bb.Name="coin_"..v:GetDebugId()
                    bb.Adornee=v; bb.Size=UDim2.new(0,70,0,24); bb.AlwaysOnTop=true
                    local tl=Instance.new("TextLabel",bb); tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1
                    tl.Text="● COIN"; tl.TextColor3=Color3.fromRGB(255,210,0); tl.TextStrokeTransparency=0; tl.Font=Enum.Font.GothamBold; tl.TextScaled=true
                end
                if Toggles.CoinMagnet and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    if (v.Position - LP.Character.HumanoidRootPart.Position).Magnitude < 38 then
                        v.CFrame = LP.Character.HumanoidRootPart.CFrame
                    end
                end
            end
        end
    end
    if Toggles.GunESP then
        local g=getGunDrop()
        if g then
            if not ESPFolder:FindFirstChild("GunESP_BB") then
                local bb=Instance.new("BillboardGui", ESPFolder)
                bb.Name="GunESP_BB"; bb.Adornee=g; bb.Size=UDim2.new(0,160,0,36); bb.AlwaysOnTop=true
                local tl=Instance.new("TextLabel",bb); tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1
                tl.Text="⬇ GUN DROP"; tl.TextColor3=Color3.fromRGB(0,210,255); tl.TextScaled=true; tl.Font=Enum.Font.GothamBold; tl.TextStrokeTransparency=0
            end
        else
            if ESPFolder:FindFirstChild("GunESP_BB") then ESPFolder.GunESP_BB:Destroy() end
        end
    end
    if Toggles.Xray then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") and v.Name~="HumanoidRootPart" then
                v.LocalTransparencyModifier = 0.72
            end
        end
    end
    if Toggles.Noclip and LP.Character then
        for _,part in pairs(LP.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide=false end end
    end
    if Toggles.AutoGun then tpToGun() end
end)

-- Kill Aura
spawn(function() while task.wait(0.22) do
    if Toggles.KillAura and getRole(LP)=="Murderer" and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        for _,p in pairs(Players:GetPlayers()) do
            if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then
