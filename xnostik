-- Switch tab function
local function SwitchTab(name)
    if activeTabName == name then return end
    activeTabName = name

    for tabName, page in pairs(tabs) do
        page.Visible = (tabName == name)
    end

    for tabName, btn in pairs(tabButtons) do
        local isActive = (tabName == name)
        QuickTween(btn, 0.2, {
            BackgroundColor3 = isActive and C.sidebarActive or C.sidebar,
        }):Play()

        local iconLbl = btn:FindFirstChild("Icon")
        if iconLbl then
            QuickTween(iconLbl, 0.2, {
                TextColor3 = isActive and C.white or C.textDim,
            }):Play()
        end

        local nameLbl = btn:FindFirstChild("TabName")
        if nameLbl then
            QuickTween(nameLbl, 0.2, {
                TextColor3 = isActive and C.white or C.textMuted,
            }):Play()
        end

        -- Active indicator bar
        local bar = btn:FindFirstChild("ActiveBar")
        if bar then
            QuickTween(bar, 0.2, {
                BackgroundTransparency = isActive and 0 or 1,
            }):Play()
        end
    end
end

