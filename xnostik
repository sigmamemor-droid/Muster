local CurrentPage = nil

local TabDefs = {
    {name = "ESP",      icon = "👁",  sub = "Настройки видимости игроков"},
    {name = "Combat",   icon = "⚔️",  sub = "Боевые функции и чит"},
    {name = "Movement", icon = "🏃",  sub = "Скорость, прыжок, полёт"},
    {name = "Farm",     icon = "🪙",  sub = "Авто-сбор монет"},
    {name = "Visuals",  icon = "🎨",  sub = "Визуальные эффекты"},
    {name = "Settings", icon = "⚙️",  sub = "Настройки хаба"},
}

local function SetTab(name)
    if CurrentPage == name then return end
    CurrentPage = name

    for _, def in ipairs(TabDefs) do
        local btn = TabBtns[def.name]
        if not btn then continue end
        if def.name == name then
            Tween(btn.bg, {BackgroundColor3 = Color3.fromRGB(50, 15, 90)}, 0.2)
            Tween(btn.label, {TextColor3 = Cfg.Text}, 0.2)
            Tween(btn.icon, {TextColor3 = Cfg.Accent2}, 0.2)
            btn.bar.Visible = true
        else
            Tween(btn.bg, {BackgroundColor3 = Cfg.BG3}, 0.2)
            Tween(btn.label, {TextColor3 = Cfg.SubText}, 0.2)
            Tween(btn.icon, {TextColor3 = Cfg.SubText}, 0.2)
            btn.bar.Visible = false
        end
    end

    for pname, page in pairs(Pages) do
        page.Visible = pname == name
    end

    for _, def in ipairs(TabDefs) do
        if def.name == name then
            PageTitle.Text = def.name
            PageSub.Text = def.sub
        end
    end
end

for _, def in ipairs(TabDefs) do
