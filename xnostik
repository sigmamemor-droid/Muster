    local function addToggle(text, description, callback, enabled, order)
        local Card = Instance.new("Frame")
        Card.Parent = ContentFrame
        Card.BackgroundColor3 = Colors.SurfaceLight
        Card.BorderSizePixel = 0
        Card.Size = UDim2.new(1, 0, 0, description and 52 or 42)
        Card.LayoutOrder = order or 10
        addCorner(Card, 8)
        addStroke(Card, Colors.Divider, 1, 0.7)

        -- Hover на карточку
        Card.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                tween(Card, {BackgroundColor3 = Colors.SurfaceHover}, 0.15)
            end
        end)
        Card.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                tween(Card, {BackgroundColor3 = Colors.SurfaceLight}, 0.15)
            end
        end)

        -- Название
        local Label = Instance.new("TextLabel")
        Label.Parent = Card
        Label.BackgroundTransparency = 1
        Label.Position = UDim2.new(0, 14, 0, description and 6 or 0)
        Label.Size = UDim2.new(0.65, 0, 0, description and 22 or 42)
        Label.Text = text
        Label.TextColor3 = Colors.TextPrimary
        Label.Font = Enum.Font.GothamSemibold
        Label.TextSize = 13
        Label.TextXAlignment = Enum.TextXAlignment.Left

        -- Описание
        if description then
            local Desc = Instance.new("TextLabel")
            Desc.Parent = Card
            Desc.BackgroundTransparency = 1
            Desc.Position = UDim2.new(0, 14, 0, 26)
            Desc.Size = UDim2.new(0.65, 0, 0, 18)
            Desc.Text = description
            Desc.TextColor3 = Colors.TextMuted
            Desc.Font = Enum.Font.Gotham
            Desc.TextSize = 11
            Desc.TextXAlignment = Enum.TextXAlignment.Left
        end

        -- TOGGLE SWITCH
        local ToggleOuter = Instance.new("TextButton")
        ToggleOuter.Parent = Card
        ToggleOuter.BackgroundColor3 = enabled and Colors.Accent or Colors.ToggleOff
        ToggleOuter.BorderSizePixel = 0
        ToggleOuter.Size = UDim2.new(0, 44, 0, 22)
        ToggleOuter.Position = UDim2.new(1, -58, 0.5, -11)
        ToggleOuter.Text = ""
        ToggleOuter.AutoButtonColor = false
        addCorner(ToggleOuter, 11)

        -- Glow за toggle когда вкл
        local ToggleGlow = Instance.new("Frame")
        ToggleGlow.Parent = ToggleOuter
        ToggleGlow.BackgroundColor3 = Colors.Accent
        ToggleGlow.BackgroundTransparency = enabled and 0.7 or 1
        ToggleGlow.Size = UDim2.new(1, 10, 1, 10)
        ToggleGlow.Position = UDim2.new(0, -5, 0, -5)
        ToggleGlow.ZIndex = 0
        addCorner(ToggleGlow, 15)

        -- Круглый индикатор
        local Circle = Instance.new("Frame")
        Circle.Parent = ToggleOuter
        Circle.BackgroundColor3 = Colors.TextPrimary
        Circle.BorderSizePixel = 0
        Circle.Size = UDim2.new(0, 16, 0, 16)
        Circle.Position = enabled and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
        addCorner(Circle, 8)

        local state = enabled

        local function updateToggle(newState)
            state = newState
            if state then
                tween(ToggleOuter, {BackgroundColor3 = Colors.Accent}, 0.2)
                tween(Circle, {Position = UDim2.new(1, -19, 0.5, -8)}, 0.25, Enum.EasingStyle.Back)
                tween(ToggleGlow, {BackgroundTransparency = 0.7}, 0.3)
            else
                tween(ToggleOuter, {BackgroundColor3 = Colors.ToggleOff}, 0.2)
                tween(Circle, {Position = UDim2.new(0, 3, 0.5, -8)}, 0.25, Enum.EasingStyle.Back)
                tween(ToggleGlow, {BackgroundTransparency = 1}, 0.2)
            end
            callback(state)
        end

        ToggleOuter.MouseButton1Click:Connect(function()
            updateToggle(not state)
        end)

        if enabled then callback(true) end
        return Card
    end

