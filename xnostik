-- ANTI-FLING (ВИПРАВЛЕНИЙ)
local antiFlingActive = false
local antiFlingToggle = AddToggleButton("Anti-Fling", function(state)
    antiFlingActive = state
    if state then
        SafeDisconnect("AntiFling")
        Connections.AntiFling = RunService.Heartbeat:Connect(function()
            local char, humanoid, root = SafeGetCharacter()
            if not root then return end
            
            local vel = root.Velocity
            if vel.Magnitude > 200 then
                root.Velocity = Vector3.new(0, math.min(vel.Y, 50), 0)
                root.RotVelocity = Vector3.new(0, 0, 0)
            end
            if root.Position.Y < -50 then
                root.CFrame = CFrame.new(0, 50, 0)
                root.Velocity = Vector3.zero
            end
        end)
    else
        SafeDisconnect("AntiFling")
    end
end)
-- Увімкнемо Anti-Fling за замовчуванням
antiFlingToggle.SetState(true)
antiFlingActive = true
SafeDisconnect("AntiFling")
Connections.AntiFling = RunService.Heartbeat:Connect(function()
    if not antiFlingActive then return end
    local char, humanoid, root = SafeGetCharacter()
    if not root then return end
    local vel = root.Velocity
    if vel.Magnitude > 200 then
        root.Velocity = Vector3.new(0, math.min(vel.Y, 50), 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
    end
    if root.Position.Y < -50 then
        root.CFrame = CFrame.new(0, 50, 0)
        root.Velocity = Vector3.zero
    end
end)

