local function GetRole(p)
	if not p.Character then return "Innocent", T.Good end
	for _, t in ipairs(p.Character:GetChildren()) do
		if t:IsA("Tool") then
			if t.Name == "Knife" then return "Murderer", T.Danger end
			if t.Name == "Gun" then return "Sheriff", T.Accent end
		end
	end
	for _, t in ipairs(p.Backpack:GetChildren()) do
		if t:IsA("Tool") then
			if t.Name == "Knife" then return "Murderer", T.Danger end
			if t.Name == "Gun" then return "Sheriff", T.Accent end
		end
	end
	return "Innocent", T.Good
end

