-- MAID SYSTEM (Memory Safety)
---------------------------------------------------------
local Maid = {}; Maid.__index = Maid
function Maid.new() return setmetatable({_tasks={}}, Maid) end
function Maid:Give(t) if t then table.insert(self._tasks, t) end; return t end
function Maid:Clean()
	for _, t in ipairs(self._tasks) do
		local ty = type(t)
		if ty == "function" then pcall(t)
		elseif ty == "thread" then pcall(coroutine.close, t)
		elseif typeof(t) == "RBXScriptConnection" then t:Disconnect()
		elseif typeof(t) == "Instance" then t:Destroy() end
	end
	table.clear(self._tasks)
end

