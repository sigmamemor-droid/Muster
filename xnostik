-- UTILITY FUNCTIONS
---------------------------------------------------------
local function GetChar() return player.Character end
local function GetHum() local c = GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function IsMurderer(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) ~= nil
end
local function IsSheriff(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil
end

local function GetMurderer()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
    return nil
end
local function GetSheriff()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsSheriff(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
    return nil
end

local function GetRootPart(p)
    if p and p.Character then return p.Character:FindFirstChild("HumanoidRootPart") end
    return nil
end

local function GetTool(n)
    local c = GetChar()
    if c and c:FindFirstChild(n) then return c:FindFirstChild(n) end
    if player.Backpack and player.Backpack:FindFirstChild(n) then return player.Backpack:FindFirstChild(n) end
    return nil
end

local function FindGunInHand()
    local c = GetChar()
    if not c then return nil end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver")) then
            return t
        end
    end
    return nil
end

local function FireGunAtTarget(gun, target)
    if not gun or not target then return false end
    for _, r in ipairs(gun:GetDescendants()) do
        if r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(target.Position, target) end)
            return true
        end
    end
    return false
end

