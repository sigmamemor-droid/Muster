    holder.BackgroundTransparency = C.Element_Trans
    holder.AutoButtonColor = false
    Corner(holder, 8); Stroke(holder)
    
    holder.MouseEnter:Connect(function() Tw(holder, TweenInfo.new(0.2), {BackgroundColor3=C.Divider}) end)
    holder.MouseLeave:Connect(function() Tw(holder, TweenInfo.new(0.2), {BackgroundColor3=C.Element}) end)
    holder.MouseButton1Click:Connect(function()
        Tw(holder, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {Size=UDim2.new(1,0,0,34)})
        if callback then pcall(callback) end
    end)
end

