-- MATH & PHYSICAL UTILITIES
---------------------------------------------------------
local function GetChar() 
    return player.Character 
end

local function GetHum() 
    local character = GetChar()
    return character and character:FindFirstChildOfClass("Humanoid") 
end

local function GetRoot() 
    local character = GetChar()
    return character and character:FindFirstChild("HumanoidRootPart") 
end

local function IsMurderer(otherPlayer)
    if otherPlayer == player or not otherPlayer.Character then 
        return false 
    end
    local hasKnife = otherPlayer.Backpack:FindFirstChild("Knife") or otherPlayer.Character:FindFirstChild("Knife")
    return hasKnife ~= nil
end

local function IsSheriff(otherPlayer)
    if otherPlayer == player or not otherPlayer.Character then 
        return false 
    end
    local hasGun = otherPlayer.Backpack:FindFirstChild("Gun") or otherPlayer.Character:FindFirstChild("Gun")
    return hasGun ~= nil
end

local function GetMurdererRoot()
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if IsMurderer(otherPlayer) and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then 
            return otherPlayer.Character.HumanoidRootPart 
        end
    end
    return nil
end

local function GetMurdererHead()
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if IsMurderer(otherPlayer) and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Head") then 
            return otherPlayer.Character.Head 
        end
    end
    return nil
end

local function GetTool(toolName)
    local character = GetChar()
    if character and character:FindFirstChild(toolName) then 
        return character:FindFirstChild(toolName) 
    end
    if player.Backpack and player.Backpack:FindFirstChild(toolName) then 
        return player.Backpack:FindFirstChild(toolName) 
    end
    return nil
end

local function FindGunInHand()
    local character = GetChar()
    if not character then return nil end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("gun") or tool.Name:lower():find("revolver")) then 
            return tool 
        end
    end
    return nil
end

local function FindKnifeInHand()
    local character = GetChar()
    if not character then return nil end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("knife") then 
            return tool 
        end
    end
    return nil
end

local function FireGunAtTarget(gun, targetHead)
    if not gun or not targetHead then return false end
    for _, remote in ipairs(gun:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            pcall(function() 
                remote:FireServer(targetHead.Position, targetHead) 
            end)
            return true
        end
    end
    return false
end

local function ThrowKnifeAtTarget(knife, targetPosition)
    if not knife or not targetPosition then return false end
    for _, remote in ipairs(knife:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            pcall(function() 
                remote:FireServer(targetPosition) 
            end)
            return true
        end
    end
    return false
end

