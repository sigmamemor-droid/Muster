local function MkSlider(tab, text, mn, mx, def, cb)
    local o = NO(tab); local val = def or mn
    local Ct = Instance.new("Frame")
    Ct.Size = UDim2.new(1, 0, 0, 46)
    Ct.BackgroundColor3 = C.elevated; Ct.BorderSizePixel = 0
    Ct.LayoutOrder = o; Ct.ZIndex = 10
    Ct.Parent = GP(tab).frame
    Instance.new("UICorner", Ct).CornerRadius = UDim.new(0, 8)

    local Lb = Instance.new("TextLabel")
    Lb.Size = UDim2.new(0.6, 0, 0, 18); Lb.Position = UDim2.new(0, 10, 0, 4)
    Lb.BackgroundTransparency = 1; Lb.Text = text; Lb.TextColor3 = C.text
    Lb.TextSize = 11; Lb.Font = Enum.Font.GothamSemibold; Lb.TextXAlignment = Enum.TextXAlignment.Left
    Lb.ZIndex = 11; Lb.Parent = Ct

    local VL = Instance.new("TextLabel")
    VL.Size = UDim2.new(0.35, 0, 0, 18); VL.Position = UDim2.new(0.65, -10, 0, 4)
    VL.BackgroundTransparency = 1; VL.Text = tostring(val); VL.TextColor3 = C.accentLight
    VL.TextSize = 11; VL.Font = Enum.Font.GothamBold; VL.TextXAlignment = Enum.TextXAlignment.Right
    VL.ZIndex = 11; VL.Parent = Ct

    local SBG = Instance.new("Frame")
    SBG.Size = UDim2.new(1, -20, 0, 5); SBG.Position = UDim2.new(0, 10, 0, 28)
    SBG.BackgroundColor3 = C.bg; SBG.BorderSizePixel = 0; SBG.ZIndex = 11; SBG.Parent = Ct
    Instance.new("UICorner", SBG).CornerRadius = UDim.new(1, 0)

    local fp = (val - mn) / (mx - mn)
    local SF = Instance.new("Frame")
    SF.Size = UDim2.new(fp, 0, 1, 0); SF.BackgroundColor3 = C.accent; SF.BorderSizePixel = 0; SF.ZIndex = 12; SF.Parent = SBG
    Instance.new("UICorner", SF).CornerRadius = UDim.new(1, 0)

    local Kn = Instance.new("Frame")
    Kn.Size = UDim2.new(0, 12, 0, 12); Kn.Position = UDim2.new(fp, -6, 0.5, -6)
    Kn.BackgroundColor3 = C.white; Kn.BorderSizePixel = 0; Kn.ZIndex = 13; Kn.Parent = SBG
    Instance.new("UICorner", Kn).CornerRadius = UDim.new(1, 0)
    local KS = Instance.new("UIStroke"); KS.Color = C.accent; KS.Thickness = 2; KS.Parent = Kn

    local sl = false
    local function US(ix)
        local ap = SBG.AbsolutePosition.X; local as = SBG.AbsoluteSize.X
        local r = math.clamp((ix - ap) / as, 0, 1)
        val = math.floor(mn + (mx - mn) * r)
        VL.Text = tostring(val); SF.Size = UDim2.new(r, 0, 1, 0); Kn.Position = UDim2.new(r, -6, 0.5, -6)
        cb(val)
    end

    SBG.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sl = true; US(i.Position.X) end
    end)
    Kn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sl = true end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sl and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then US(i.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sl = false end
    end)

    return function() return val end
end

