local function AnimateLoading()
    TweenService:Create(GlowOuter, TweenInfo.new(0.8), {ImageTransparency = 0.6}):Play()
    TweenService:Create(GlowInner, TweenInfo.new(0.6), {ImageTransparency = 0.4}):Play()

    for _, p in ipairs(particles) do
        TweenService:Create(p, TweenInfo.new(3 + math.random() * 4, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, true), {
            Position = UDim2.new(p.Position.X.Scale + (math.random() - 0.5) * 0.1, 0, p.Position.Y.Scale - 0.3 - math.random() * 0.4, 0),
            BackgroundTransparency = math.random(40, 95) / 100
        }):Play()
    end

    task.wait(0.3)

    LogoFrame.Size = UDim2.new(0, 0, 0, 0)
    LogoFrame.Position = UDim2.new(0.5, 0, 0, 120)
    TweenService:Create(LogoFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 100, 0, 100),
        Position = UDim2.new(0.5, -50, 0, 70)
    }):Play()

    task.wait(0.5)

    -- Пульсация
    task.spawn(function()
        while LoadingScreen and LoadingScreen.Parent do
            TweenService:Create(LogoStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.1}):Play()
            TweenService:Create(GlowInner, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.3, Size = UDim2.new(0, 200, 0, 200), Position = UDim2.new(0.5, -100, 0, 20)
            }):Play()
            task.wait(1)
            if not LoadingScreen or not LoadingScreen.Parent then break end
            TweenService:Create(LogoStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.6}):Play()
            TweenService:Create(GlowInner, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                ImageTransparency = 0.6, Size = UDim2.new(0, 180, 0, 180), Position = UDim2.new(0.5, -90, 0, 30)
            }):Play()
            task.wait(1)
        end
    end)

    TweenService:Create(LoadTitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    task.wait(0.2)
    TweenService:Create(LoadSubtitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    task.wait(0.2)
    TweenService:Create(LoadStatus, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadPercent, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LoadFooter, TweenInfo.new(0.5), {TextTransparency = 0.4}):Play()
    task.wait(0.2)

    local stages = {
        {0.15, "Initializing core...", 0.35},
        {0.30, "Loading tab system...", 0.3},
        {0.45, "Configuring ESP...", 0.3},
        {0.55, "Setting up combat...", 0.25},
        {0.70, "Loading boombox...", 0.3},
        {0.85, "Applying protection...", 0.35},
        {0.95, "Final checks...", 0.2},
        {1.00, "Ready!", 0.25},
    }

    for _, s in ipairs(stages) do
        TweenService:Create(ProgressFill, TweenInfo.new(s[3], Enum.EasingStyle.Quad), {
            Size = UDim2.new(s[1], 0, 1, 0)
        }):Play()
        LoadStatus.Text = s[2]
        LoadPercent.Text = math.floor(s[1] * 100) .. "%"
        task.wait(s[3] + 0.05)
    end

    LoadStatus.TextColor3 = C.green
    LoadPercent.TextColor3 = C.green
    task.wait(0.5)

    -- Fade out
    for _, child in ipairs(LoadCenter:GetDescendants()) do
        if child:IsA("TextLabel") then
            TweenService:Create(child, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
            local s = child:FindFirstChildOfClass("UIStroke")
            if s then TweenService:Create(s, TweenInfo.new(0.4), {Transparency = 1}):Play() end
        elseif child:IsA("ImageLabel") then
            TweenService:Create(child, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
        end
    end
    for _, p in ipairs(particles) do
        TweenService:Create(p, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    end
    TweenService:Create(LoadingScreen, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()

    task.wait(0.6)
    LoadingScreen:Destroy()
end

AnimateLoading()

