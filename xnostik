---------------------------------------------------------
-- CONNECTION REGISTRY
-- All connections stored here; cleared by key or all at once
---------------------------------------------------------
local Connections = {}

local function ConnSet(key, conn)
    if Connections[key] then
        pcall(function() Connections[key]:Disconnect() end)
    end
    Connections[key] = conn
end

local function ConnClear(key)
    if Connections[key] then
        pcall(function() Connections[key]:Disconnect() end)
        Connections[key] = nil
    end
end

local function ConnClearAll()
    for k, c in pairs(Connections) do
        pcall(function() c:Disconnect() end)
        Connections[k] = nil
    end
end

---------------------------------------------------------
-- CHARACTER HELPERS
---------------------------------------------------------
local function GetCharacter() return player.Character end

local function GetHumanoid()
    local ch = GetCharacter()
    return ch and ch:FindFirstChildOfClass("Humanoid")
end

local function GetRoot()
    local ch = GetCharacter()
    return ch and ch:FindFirstChild("HumanoidRootPart")
end

-- Searches both Character and Backpack (original only searched Character)
local function IsMurderer(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Knife")
         or p.Character:FindFirstChild("Knife")) ~= nil
end

local function IsSheriff(p)
    if p == player or not p.Character then return false end
    return (p.Backpack:FindFirstChild("Gun")
         or p.Character:FindFirstChild("Gun")) ~= nil
end

local function GetMurdererCharPart(partName)
    for _, p in ipairs(Players:GetPlayers()) do
        if IsMurderer(p) and p.Character
           and p.Character:FindFirstChild(partName) then
            return p.Character:FindFirstChild(partName)
        end
    end
    return nil
end

-- Properly searches Backpack AND equipped tools
local function FindGunTool()
    local ch = GetCharacter()
    if not ch then return nil end
    local function isGun(name)
        name = name:lower()
        return name == "gun" or name:find("gun") or
               name:find("pistol") or name:find("revolver")
    end
    for _, v in ipairs(ch:GetChildren()) do
        if v:IsA("Tool") and isGun(v.Name) then return v end
    end
    for _, v in ipairs(player.Backpack:GetChildren()) do
        if v:IsA("Tool") and isGun(v.Name) then return v end
    end
    return nil
end

---------------------------------------------------------
-- TWEEN SHORTHAND
---------------------------------------------------------
local function Tween(obj, info, props)
    return TweenService:Create(obj, info, props)
end

local function QuickTween(obj, t, props, style, dir)
    return TweenService:Create(
        obj,
        TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
end

