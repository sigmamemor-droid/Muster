-- Сервисы Roblox
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Переменные состояния
local espConnection = nil
local espActive = false

-- Функция создания подсветки (Highlight)
local function createHighlight(player, color)
    if player.Character and not player.Character:FindFirstChild("SWILL_ESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "SWILL_ESP"
        highlight.FillColor = color
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Parent = player.Character
    end
end

-- Функция удаления подсветки
local function removeHighlight(player)
    if player.Character then
        local esp = player.Character:FindFirstChild("SWILL_ESP")
        if esp then
            esp:Destroy()
        end
    end
end

-- Логика ESP для Убийцы и Шерифа
local function toggleESP(state)
    espActive = state
    if espActive then
        espConnection = RunService.RenderStepped:Connect(function()
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    -- Проверка оружия в руках или инвентаре
                    local hasKnife = player.Character:FindFirstChild("Knife") or player.Backpack:FindFirstChild("Knife")
                    local hasGun = player.Character:FindFirstChild("Gun") or player.Backpack:FindFirstChild("Gun") or player.Character:FindFirstChild("Revolver") or player.Backpack:FindFirstChild("Revolver")

                    if hasKnife then
                        createHighlight(player, Color3.fromRGB(255, 0, 0)) -- Красный для Убийцы
                    elseif hasGun then
                        createHighlight(player, Color3.fromRGB(0, 0, 255)) -- Синий для Шерифа
                    else
                        removeHighlight(player)
                    end
                end
            end
        end)
    else
        if espConnection then
            espConnection:Disconnect()
        end
        for _, player in pairs(Players:GetPlayers()) do
            removeHighlight(player)
        end
    end
end

-- Кнопка и Тогл для ESP
MM2Tab:AddToggle({
