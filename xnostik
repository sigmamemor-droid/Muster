local OldNC
OldNC = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if State.SilentAim and method == "FireServer" then
        local name = tostring(self.Name)
        if name:lower():find("shoot") or name:lower():find("gun") or name:lower():find("fire") then
            local target = GetTarget()
            if target and target.Character and target.Character:FindFirstChild("Head") then
                local head = target.Character.Head
                local vel = head.AssemblyLinearVelocity
                local predicted = head.Position + (vel * State.Prediction)
                args[1] = predicted
                return OldNC(self, unpack(args))
            end
        end
    end

    return OldNC(self, ...)
end)

