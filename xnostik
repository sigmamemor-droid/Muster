local function MkToggle(parent, text, def, cb)
    local B = Instance.new("TextButton")
    B.Size = UDim2.new(1, 0, 0, 36) -- Увеличено для мобильных тачей
    B.BackgroundColor3 = C.surface
    B.Text = ""
    B.AutoButtonColor = false
    B.Parent = parent
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)

    local Lbl = Instance.new("TextLabel")
    Lbl.Size = UDim2.new(1, -60, 1, 0)
    Lbl.Position = UDim2.new(0, 12, 0, 0)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = text
    Lbl.TextColor3 = C.text
    Lbl.TextSize = 14
    Lbl.Font = Enum.Font.GothamMedium
    Lbl.TextXAlignment = Enum.TextXAlignment.Left
    Lbl.Parent = B

    local TBg = Instance.new("Frame")
    TBg.Size = UDim2.new(0, 40, 0, 22)
    TBg.Position = UDim2.new(1, -50, 0.5, -11)
    TBg.BackgroundColor3 = def and C.green or Color3.fromRGB(60, 60, 60)
    TBg.Parent = B
    Instance.new("UICorner", TBg).CornerRadius = UDim.new(1, 0)

    local TC = Instance.new("Frame")
    TC.Size = UDim2.new(0, 18, 0, 18)
    TC.Position = def and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
    TC.BackgroundColor3 = C.white
    TC.Parent = TBg
    Instance.new("UICorner", TC).CornerRadius = UDim.new(1, 0)

    local active = def
    local function UpdateUI()
        TweenService:Create(TBg, TweenInfo.new(0.2), {BackgroundColor3 = active and C.green or Color3.fromRGB(60, 60, 60)}):Play()
        TweenService:Create(TC, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Position = active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)}):Play()
    end

    B.MouseButton1Click:Connect(function()
        active = not active
        UpdateUI()
        cb(active)
    end)
    return B
end

local function MkSlider(parent, text, min, max, def, cb)
    local Ct = Instance.new("Frame")
    Ct.Size = UDim2.new(1, 0, 0, 46)
    Ct.BackgroundColor3 = C.surface
    Ct.Parent = parent
    Instance.new("UICorner", Ct).CornerRadius = UDim.new(0, 8)

    local Lb = Instance.new("TextLabel")
    Lb.Size = UDim2.new(1, -20, 0, 20)
    Lb.Position = UDim2.new(0, 10, 0, 4)
    Lb.BackgroundTransparency = 1
    Lb.Text = text
    Lb.TextColor3 = C.text
    Lb.TextSize = 13
    Lb.Font = Enum.Font.GothamMedium
    Lb.TextXAlignment = Enum.TextXAlignment.Left
    Lb.Parent = Ct

    local VL = Instance.new("TextLabel")
    VL.Size = UDim2.new(0, 50, 0, 20)
    VL.Position = UDim2.new(1, -60, 0, 4)
    VL.BackgroundTransparency = 1
    VL.Text = tostring(def)
    VL.TextColor3 = C.accent
    VL.TextSize = 13
    VL.Font = Enum.Font.GothamBold
    VL.TextXAlignment = Enum.TextXAlignment.Right
    VL.Parent = Ct

    local SBG = Instance.new("Frame")
    SBG.Size = UDim2.new(1, -20, 0, 6)
    SBG.Position = UDim2.new(0, 10, 0, 30)
    SBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    SBG.Parent = Ct
    Instance.new("UICorner", SBG).CornerRadius = UDim.new(1, 0)

    local SF = Instance.new("Frame")
    SF.Size = UDim2.new((def - min) / (max - min), 0, 1, 0)
    SF.BackgroundColor3 = C.accent
    SF.Parent = SBG
    Instance.new("UICorner", SF).CornerRadius = UDim.new(1, 0)

    local Kn = Instance.new("Frame")
    Kn.Size = UDim2.new(0, 16, 0, 16)
    Kn.Position = UDim2.new((def - min) / (max - min), -8, 0.5, -8)
    Kn.BackgroundColor3 = C.white
    Kn.Parent = SBG
    Instance.new("UICorner", Kn).CornerRadius = UDim.new(1, 0)

    local val = def
    local sliding = false
    
    local function UpdateSlider(x)
        local rel = math.clamp((x - SBG.AbsolutePosition.X) / SBG.AbsoluteSize.X, 0, 1)
        val = math.floor(min + (max - min) * rel)
        VL.Text = tostring(val)
        SF.Size = UDim2.new(rel, 0, 1, 0)
        Kn.Position = UDim2.new(rel, -8, 0.5, -8)
        cb(val)
    end

    SBG.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; UpdateSlider(i.Position.X) end end)
    UserInputService.InputChanged:Connect(function(i) if sliding and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then UpdateSlider(i.Position.X) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
    
    return function() return val end
end

