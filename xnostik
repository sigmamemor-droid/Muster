-- LOADING ANIMATION
-- Defined after all elements exist — no race condition
---------------------------------------------------------
local function AnimateLoading()
    -- Glows fade in
    QuickTween(GlowOuter, 0.8, {ImageTransparency = 0.6}):Play()
    QuickTween(GlowInner, 0.6, {ImageTransparency = 0.4}):Play()

    -- Particle drift (looped)
    for _, p in ipairs(particles) do
        QuickTween(p,
            3 + math.random()*4,
            {
                Position = UDim2.new(
                    p.Position.X.Scale + (math.random()-0.5)*0.1, 0,
                    p.Position.Y.Scale - 0.3 - math.random()*0.4,  0
                ),
                BackgroundTransparency = math.random(40,95)/100
            },
            Enum.EasingStyle.Linear,
            Enum.EasingDirection.InOut
        ):Play()
    end

    task.wait(0.3)

    -- Logo pop-in
    TweenService:Create(LogoFrame,
        TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Size = UDim2.new(0,100,0,100), Position = UDim2.new(0.5,-50,0,70) }
    ):Play()

    task.wait(0.5)

    -- Logo pulse loop (stopped when screen is destroyed)
    local pulseAlive = true
    task.spawn(function()
        while pulseAlive and LoadingScreen.Parent do
            QuickTween(LogoStroke,  1, {Transparency = 0.1}, Enum.EasingStyle.Sine):Play()
            QuickTween(GlowInner,   1, {
                ImageTransparency = 0.3,
                Size     = UDim2.new(0,200,0,200),
                Position = UDim2.new(0.5,-100,0,20)
            }, Enum.EasingStyle.Sine):Play()
            task.wait(1)
            if not (pulseAlive and LoadingScreen.Parent) then break end
            QuickTween(LogoStroke, 1, {Transparency = 0.6}, Enum.EasingStyle.Sine):Play()
            QuickTween(GlowInner,  1, {
                ImageTransparency = 0.6,
                Size     = UDim2.new(0,180,0,180),
                Position = UDim2.new(0.5,-90,0,30)
            }, Enum.EasingStyle.Sine):Play()
            task.wait(1)
        end
    end)

    -- Titles appear sequentially
    for _, lbl in ipairs({LoadTitle, LoadSubtitle, LoadStatus, LoadPercent}) do
        QuickTween(lbl, 0.35, {TextTransparency = 0}):Play()
        task.wait(0.12)
    end
    QuickTween(LoadFooter, 0.5, {TextTransparency = 0.4}):Play()

    task.wait(0.15)

    -- Progress stages
    local stages = {
        {p = 0.12, text = "Initializing core...",       t = 0.35},
        {p = 0.28, text = "Loading UI framework...",    t = 0.30},
        {p = 0.44, text = "Configuring ESP...",         t = 0.30},
        {p = 0.57, text = "Setting up combat...",       t = 0.25},
        {p = 0.70, text = "Loading boombox...",         t = 0.28},
        {p = 0.82, text = "Applying safety checks...", t = 0.35},
        {p = 0.92, text = "Connecting services...",     t = 0.28},
        {p = 1.00, text = "Ready!",                     t = 0.25},
    }

    for _, s in ipairs(stages) do
        QuickTween(ProgressFill, s.t, {Size = UDim2.new(s.p, 0, 1, 0)}):Play()
        LoadStatus.Text  = s.text
        LoadPercent.Text = math.floor(s.p * 100) .. "%"
        task.wait(s.t + 0.06)
    end

    LoadStatus.TextColor3  = C.green
    LoadPercent.TextColor3 = C.green
    task.wait(0.6)
    pulseAlive = false

    -- Fade-out everything together
    local fadeInfo = TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    QuickTween(LoadingScreen, 0.45, {BackgroundTransparency = 1},
        Enum.EasingStyle.Quad, Enum.EasingDirection.In):Play()

    for _, child in ipairs(LoadCenter:GetDescendants()) do
        if child:IsA("TextLabel") then
            Tween(child, fadeInfo, {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            Tween(child, fadeInfo, {BackgroundTransparency = 1}):Play()
        elseif child:IsA("ImageLabel") then
            Tween(child, fadeInfo, {ImageTransparency = 1}):Play()
        end
    end

    TweenService:Create(LogoFrame,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        {Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0,90)}
    ):Play()

    for _, p in ipairs(particles) do
        Tween(p, fadeInfo, {BackgroundTransparency = 1}):Play()
    end

    task.wait(0.5)
    LoadingScreen:Destroy()
end

