                -- Плавная интерполяция камеры вместо Snapping
                local targetCFrame = CFrame.new(camera.CFrame.Position, targetHead.Position)
                camera.CFrame = camera.CFrame:Lerp(targetCFrame, 0.2)
            end
        end)
