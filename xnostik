-- Загрузка VibeUI
local Vibe = loadstring(game:HttpGet("https://raw.githubusercontent.com/va1k/VibeUI/main/source"))()

-- Создание окна
local Window = Vibe:CreateWindow({
    Name = "MM2 RAGE | VibeUI",
    Theme = "Dark",
})

-- Основные переменные
local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local runService = game:GetService("RunService")
local replicatedStorage = game:GetService("ReplicatedStorage")

-- Флаги для функций
local espEnabled = false
local killAuraEnabled = false
local godModeEnabled = false
local autoCoinEnabled = false
local espBoxes = {}

-- Вкладка "Основное"
local Main = Window:CreateTab("Основное")

Main:CreateSlider({
    Name = "Скорость",
    Min = 16,
    Max = 150,
    Default = 16,
    Callback = function(v)
        char.Humanoid.WalkSpeed = v
    end
})

Main:CreateSlider({
    Name = "Прыжок",
    Min = 50,
    Max = 500,
    Default = 50,
    Callback = function(v)
        char.Humanoid.JumpPower = v
    end
})

Main:CreateToggle({
    Name = "Режим полёта",
    Default = false,
    Callback = function(v)
        char.Humanoid.PlatformStand = v
        if v then
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Flying, true)
            char.Humanoid:ChangeState(Enum.HumanoidStateType.Flying)
        else
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Flying, false)
        end
    end
})

Main:CreateToggle({
    Name = "God Mode (бессмертие)",
    Default = false,
    Callback = function(v)
        godModeEnabled = v
        if v then
            char.Humanoid.Health = char.Humanoid.MaxHealth
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        else
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        end
    end
})

-- Вкладка "Атака"
local Attack = Window:CreateTab("Атака")

Attack:CreateToggle({
    Name = "ESP всех игроков (с ролями)",
    Default = false,
    Callback = function(v)
        espEnabled = v
        if not v then
            for _, box in pairs(espBoxes) do
                box:Destroy()
            end
            espBoxes = {}
        end
    end
})

Attack:CreateToggle({
    Name = "Kill Aura (авто-убийство)",
    Default = false,
    Callback = function(v)
        killAuraEnabled = v
    end
})

Attack:CreateButton({
    Name = "Убить всех (разово)",
    Callback = function()
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                plr.Character.Humanoid.Health = 0
            end
        end
    end
})

Attack:CreateButton({
    Name = "Дать всё оружие",
    Callback = function()
        for _, v in pairs(player.Backpack:GetChildren()) do v:Destroy() end
        for _, v in pairs(replicatedStorage.Weapons:GetChildren()) do
            v:Clone().Parent = player.Backpack
        end
        for _, v in pairs(player.Character:GetChildren()) do
            if v:IsA("Tool") then v:Destroy() end
        end
    end
})

Attack:CreateButton({
    Name = "Бесконечные патроны (шериф)",
    Callback = function()
        local ammo = player:FindFirstChild("Ammo") or Instance.new("NumberValue", player)
        ammo.Name = "Ammo"
        ammo.Value = 999
        player.CharacterAdded:Connect(function()
            wait(1)
            local newAmmo = Instance.new("NumberValue", player)
            newAmmo.Name = "Ammo"
            newAmmo.Value = 999
        end)
    end
})

-- Вкладка "Фарм"
local Farm = Window:CreateTab("Фарм")

Farm:CreateToggle({
    Name = "Авто-сбор монет",
    Default = false,
    Callback = function(v)
        autoCoinEnabled = v
        if v then
            -- Бесконечный сбор монет
            spawn(function()
                while autoCoinEnabled do
                    for _, coin in pairs(game.Workspace:GetDescendants()) do
                        if coin:IsA("Part") and coin.Name == "Coin" and coin:FindFirstChild("TouchInterest") then
                            local dist = (coin.Position - char.HumanoidRootPart.Position).Magnitude
                            if dist < 50 then
                                char.HumanoidRootPart.CFrame = CFrame.new(coin.Position + Vector3.new(0, 2, 0))
                                firetouchinterest(char.HumanoidRootPart, coin, 0)
                                firetouchinterest(char.HumanoidRootPart, coin, 1)
                            end
                        end
                    end
                    wait(0.3)
                end
            end)
        end
    end
})

Farm:CreateButton({
    Name = "Телепорт к монетам (разово)",
    Callback = function()
        for _, coin in pairs(game.Workspace:GetDescendants()) do
            if coin:IsA("Part") and coin.Name == "Coin" then
                char.HumanoidRootPart.CFrame = CFrame.new(coin.Position + Vector3.new(0, 3, 0))
                break
            end
        end
    end
})

-- Обработчик ESP (обновляется каждый кадр)
runService.Heartbeat:Connect(function()
    if espEnabled then
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local root = plr.Character.HumanoidRootPart
                local box = Instance.new("BoxHandleAdornment")
                box.Adornee = plr.Character
                box.Size = Vector3.new(4, 6, 2)
                box.AlwaysOnTop = true
                box.ZIndex = 10
                
                -- Определяем роль по цвету
                local role = "Невинный"
                local color = Color3.fromRGB(0, 255, 0) -- зелёный
                
                if plr.Character:FindFirstChild("Knife") then
                    role = "Убийца"
                    color = Color3.fromRGB(255, 0, 0) -- красный
                elseif plr.Character:FindFirstChild("Gun") then
                    role = "Шериф"
                    color = Color3.fromRGB(0, 100, 255) -- синий
                end
                
                box.Color3 = color
                box.Parent = plr.Character
                table.insert(espBoxes, box)
            end
        end
    end
end)

-- Обработчик Kill Aura
runService.Heartbeat:Connect(function()
    if killAuraEnabled then
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                local dist = (plr.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < 20 then
                    plr.Character.Humanoid.Health = 0
                end
            end
        end
    end
end)

-- Защита от смерти (God Mode)
player.CharacterAdded:Connect(function(newChar)
    char = newChar
    if godModeEnabled then
        char.Humanoid.Health = char.Humanoid.MaxHealth
        char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    end
end)

-- Запуск интерфейса
Window:Activate()