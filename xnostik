-- Weapon Scaler Helper
local function applyWeaponScale(tool)
    if not tool or not tool:IsA("Tool") then return end
    local handle = tool:WaitForChild("Handle", 2)
    if handle then
        local mesh = handle:FindFirstChildOfClass("SpecialMesh") or handle:FindFirstChildOfClass("Mesh")
        if mesh then
            mesh.Scale = Vector3.new(Config.WeaponScale, Config.WeaponScale, Config.WeaponScale)
        elseif handle:IsA("MeshPart") then
            handle.Size = Vector3.new(Config.WeaponScale, Config.WeaponScale, Config.WeaponScale)
        end
        tool.Grip = CFrame.new(Vector3.new(Config.WeaponX, Config.WeaponY, Config.WeaponZ))
    end
end

-- Hitbox Expander
local function updateHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            if head and head:IsA("BasePart") then
                if Config.HeadHitbox > 1 then
                    head.Size = Vector3.new(Config.HeadHitbox, Config.HeadHitbox, Config.HeadHitbox)
                    head.CanCollide = false
                else
                    head.Size = Vector3.new(2, 1, 1)
                    head.CanCollide = true
                end
            end
        end
    end
end

