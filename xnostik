    Instance.new("UIStroke", ToggleFrame).Color = Theme.Border

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -50, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Theme.Text
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame

    local Outer = Instance.new("Frame")
    Outer.Size = UDim2.new(0, 32, 0, 16)
    Outer.Position = UDim2.new(1, -42, 0.5, -8)
    Outer.BackgroundColor3 = Theme.BG
    Outer.Parent = ToggleFrame
    Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", Outer).Color = Theme.Border

    local Dot = Instance.new("Frame")
    Dot.Size = UDim2.new(0, 12, 0, 12)
    Dot.Position = active and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
    Dot.BackgroundColor3 = active and Theme.AccentNeon or Theme.TextMuted
    Dot.Parent = Outer
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

    ToggleFrame.MouseButton1Click:Connect(function()
        active = not active
        TweenService:Create(Dot, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = active and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6),
            BackgroundColor3 = active and Theme.AccentNeon or Theme.TextMuted
        }):Play()
        TweenService:Create(Outer, TweenInfo.new(0.2), {
            BackgroundColor3 = active and Color3.fromRGB(0, 60, 80) or Theme.BG
