local AudioInput = AddTextInput("Audio ID (число)...", "")
local VolumeInput = AddTextInput("Гучність (0.1 — 10)", "2")

local currentSound = nil

local function SetupSound()
    local char, _, root = SafeGetCharacter()
    if not root then return nil end
    if currentSound then
        pcall(function()
            currentSound:Stop()
            currentSound:Destroy()
        end)
    end
    currentSound = Instance.new("Sound")
    currentSound.Name = "MM2Boombox"
    currentSound.Parent = root
    currentSound.Looped = true
    return currentSound
end

local function PlayAudio()
    local audioId = tonumber(AudioInput.Text)
    local vol = tonumber(VolumeInput.Text) or 2
    vol = math.clamp(vol, 0.1, 10)
    if not audioId then return false end
    
    local sound = SetupSound()
    if not sound then return false end
    
    sound.SoundId = "rbxassetid://" .. audioId
    sound.Volume = vol
    sound:Play()
    return true
end

local function StopAudio()
    if currentSound then
        pcall(function()
            currentSound:Stop()
            currentSound:Destroy()
        end)
        currentSound = nil
    end
end

