local function DoLoad()
    -- Logo pop animation
    Logo.Size = UDim2.new(0,0,0,0); Logo.Position = UDim2.new(0.5,0,0,110)
    TweenService:Create(Logo, TweenInfo.new(0.7, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
        Size = UDim2.new(0,80,0,80), Position = UDim2.new(0.5,-40,0,70)}):Play()
        
    -- Continuous glow pulse
    task.spawn(function()
        while LS.Parent do
            TweenService:Create(Glow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.4, Size = UDim2.new(0,260,0,260), Position = UDim2.new(0.5,-130,0,-20)}):Play()
            task.wait(1.2)
            TweenService:Create(Glow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.8, Size = UDim2.new(0,220,0,220), Position = UDim2.new(0.5,-110,0,0)}):Play()
            task.wait(1.2)
        end
    end)
    
    -- Continuous Logo rotation (spin inside)
    local spinTw = TweenService:Create(LTx, TweenInfo.new(4, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), {Rotation = 315})
    spinTw:Play()

    task.wait(0.5)
    TweenService:Create(LTi, TweenInfo.new(0.4), {TextTransparency = 0}):Play(); task.wait(0.1)
    TweenService:Create(LSu, TweenInfo.new(0.4), {TextTransparency = 0}):Play(); task.wait(0.1)
    TweenService:Create(LSta, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(LPc, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    
    local stages = {
        {0.15,"Initializing framework...",0.15},{0.30,"Building UI elements...",0.15},{0.45,"Connecting hooks...",0.15},
        {0.65,"Loading targeted fling...",0.15},{0.85,"Bypassing basic checks...",0.15},{1.00,"> System Online <",0.15},
    }
    for _,s in ipairs(stages) do
        TweenService:Create(PFl, TweenInfo.new(s[3], Enum.EasingStyle.Quad), {Size = UDim2.new(s[1],0,1,0)}):Play()
        LSta.Text = s[2]; LPc.Text = math.floor(s[1]*100).."%"; task.wait(s[3]+0.05)
    end
    
    LSta.TextColor3 = C.greenLight; LPc.TextColor3 = C.greenLight; task.wait(0.4)
    
    -- Fade out entire load screen smoothly
    spinTw:Cancel()
    TweenService:Create(LS, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1}):Play()
    for _,ch in ipairs(LC:GetDescendants()) do
        if ch:IsA("TextLabel") then TweenService:Create(ch, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        elseif ch:IsA("Frame") then TweenService:Create(ch, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
            local st = ch:FindFirstChildOfClass("UIStroke"); if st then TweenService:Create(st, TweenInfo.new(0.4), {Transparency = 1}):Play() end
        elseif ch:IsA("ImageLabel") then TweenService:Create(ch, TweenInfo.new(0.4), {ImageTransparency = 1}):Play() end
    end
    task.wait(0.6)
    LS:Destroy()
end
DoLoad()

