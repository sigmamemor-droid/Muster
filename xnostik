-- Тоггл (точно как на картинке)
local function Toggle(parent, text, default, callback)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -28, 0, 52)
    card.BackgroundColor3 = C.BG2
    card.BorderSizePixel = 0
    card.Parent = parent
    Corner(card, 10)
    Stroke(card, C.Divider, 1)

    local label = NewLabel(card, text, 13, C.Text, Enum.Font.GothamSemibold)
    label.Size = UDim2.new(1, -80, 1, 0)
    label.Position = UDim2.new(0, 18, 0, 0)

    -- Переключатель
    local switchBg = Instance.new("Frame")
    switchBg.Size = UDim2.new(0, 50, 0, 26)
    switchBg.Position = UDim2.new(1, -66, 0.5, -13)
    switchBg.BackgroundColor3 = default and C.Toggle_On or C.Toggle_Off
    switchBg.BorderSizePixel = 0
    switchBg.Parent = card
    Corner(switchBg, 13)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = default and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = switchBg
    Corner(knob, 10)

    local enabled = default or false
    local obj = {Value = enabled}

    local function Set(val, silent)
        enabled = val
        obj.Value = val
        Tw(switchBg, {BackgroundColor3 = val and C.Toggle_On or C.Toggle_Off}, 0.2)
        Tw(knob, {Position = val and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)}, 0.2)
        if not silent and callback then pcall(callback, val) end
    end

    Set(default, true)

    local click = Instance.new("TextButton")
    click.Size = UDim2.new(1, 0, 1, 0)
    click.BackgroundTransparency = 1
