-- MM2 CHEAT LOGIC & IMPLEMENTATION
---------------------------------------------------------
local Window = Library:CreateWindow("linbergz Vanguard")

local CombatTab = Window:MakeTab("🗡️ Combat")
local VisualTab = Window:MakeTab("👁️ Visuals")
local AutoTab   = Window:MakeTab("⚙️ Auto")
local LocalTab  = Window:MakeTab("🏃 Player")

-- Helpers
local function GetRole(p)
    if not p.Character then return "Innocent" end
    if p.Character:FindFirstChild("Knife") or p.Backpack:FindFirstChild("Knife") then return "Murderer" end
    if p.Character:FindFirstChild("Gun") or p.Backpack:FindFirstChild("Gun") then return "Sheriff" end
    return "Innocent"
end

local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and GetRole(p) == "Murderer" then return p end
    end
end

-- [ COMBAT ]
local SilentAim = false
CombatTab:AddToggle("Silent Aim (Gun/Knife)", function(state)
    SilentAim = state
end)

local KillAura = false
CombatTab:AddToggle("Kill Aura", function(state)
    KillAura = state
end)

local Hitbox = false
local HitboxSize = 5
CombatTab:AddToggle("Expand Murderer Hitbox", function(state)
    Hitbox = state
    if not state then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                p.Character.HumanoidRootPart.Transparency = 1
            end
        end
    end
end)
CombatTab:AddSlider("Hitbox Size", 5, 50, 5, function(val) HitboxSize = val end)

-- Combat Loop
RunService.Heartbeat:Connect(function()
    -- Hitbox
    if Hitbox then
        local m = GetMurderer()
        if m and m.Character and m.Character:FindFirstChild("HumanoidRootPart") then
            m.Character.HumanoidRootPart.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
            m.Character.HumanoidRootPart.Transparency = 0.8
            m.Character.HumanoidRootPart.BrickColor = BrickColor.new("Bright red")
            m.Character.HumanoidRootPart.CanCollide = false
        end
    end

    -- Kill Aura
    if KillAura and lp.Character then
        local knife = lp.Character:FindFirstChild("Knife")
        if knife then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    if dist <= 20 then
                        local re = knife:FindFirstChild("RemoteEvent") or knife:FindFirstChildOfClass("RemoteEvent")
                        if re then re:FireServer(p.Character.HumanoidRootPart.Position) end
                    end
                end
            end
        end
    end

    -- Silent Aim
    if SilentAim and lp.Character then
        local gun = lp.Character:FindFirstChild("Gun")
        local knife = lp.Character:FindFirstChild("Knife")
        
        if gun then
            local m = GetMurderer()
            if m and m.Character and m.Character:FindFirstChild("Head") then
                local re = gun:FindFirstChild("RemoteEvent") or gun:FindFirstChildOfClass("RemoteEvent")
                if re then re:FireServer(m.Character.Head.Position, m.Character.Head) end
            end
        elseif knife then
            -- Throw at nearest
            local nearest, dist = nil, 100
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
                    local d = (p.Character.Head.Position - lp.Character.Head.Position).Magnitude
                    if d < dist then dist = d; nearest = p end
                end
            end
            if nearest then
                local re = knife:FindFirstChild("RemoteEvent") or knife:FindFirstChildOfClass("RemoteEvent")
                if re then re:FireServer(nearest.Character.Head.Position) end
            end
        end
    end
end)

-- [ VISUALS ]
local EspState = false
VisualTab:AddToggle("Elite Role ESP", function(state)
    EspState = state
    if not state then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("MM2ESP_lz") then
                p.Character.MM2ESP_lz:Destroy()
            end
        end
    end
end)

VisualTab:AddButton("X-Ray (Fullbright)", function()
    game:GetService("Lighting").Brightness = 2
    game:GetService("Lighting").ClockTime = 14
    game:GetService("Lighting").FogEnd = 100000
    game:GetService("Lighting").GlobalShadows = false
    game:GetService("Lighting").OutdoorAmbient = Color3.fromRGB(128, 128, 128)
end)

-- ESP Loop
task.spawn(function()
    while task.wait(1) do
        if EspState then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character then
                    local role = GetRole(p)
                    local hl = p.Character:FindFirstChild("MM2ESP_lz")
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "MM2ESP_lz"
                        hl.Parent = p.Character
                        hl.OutlineTransparency = 0.2
                        hl.FillTransparency = 0.5
                    end
                    if role == "Murderer" then hl.FillColor = Color3.fromRGB(255, 50, 50)
                    elseif role == "Sheriff" then hl.FillColor = Color3.fromRGB(50, 150, 255)
                    else hl.FillColor = Color3.fromRGB(50, 255, 50) end
                end
            end
        end
    end
end)

-- [ AUTO ]
local AutoCoin = false
AutoTab:AddToggle("Auto Farm Coins (Teleport)", function(state)
    AutoCoin = state
end)

local GrabGun = false
AutoTab:AddToggle("Auto Grab Dropped Gun", function(state)
    GrabGun = state
end)

RunService.Stepped:Connect(function()
    if AutoCoin and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local normal = workspace:FindFirstChild("Normal")
        if normal then
            local coins = normal:FindFirstChild("CoinContainer")
            if coins then
                for _, coin in pairs(coins:GetChildren()) do
                    if coin:IsA("BasePart") then
                        lp.Character.HumanoidRootPart.CFrame = coin.CFrame
                        task.wait(0.1)
                        break
                    end
                end
            end
        end
    end
    
    if GrabGun and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        for _, v in pairs(workspace:GetDescendants()) do
            if (v.Name == "GunDrop" or v.Name == "Gun") and v:IsA("BasePart") then
                lp.Character.HumanoidRootPart.CFrame = v.CFrame
            end
        end
    end
end)

