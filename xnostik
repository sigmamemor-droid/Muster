-- IMPROVED Anti-Fling: also detects and removes foreign BodyMovers
MkToggle("Home", "antifling", false, function(active)
    ClearConn("ironclad_af")
    if active then
        Conn("ironclad_af", RunService.Heartbeat:Connect(function()
            local c = GetChar(); if not c then return end
            local r = c:FindFirstChild("HumanoidRootPart")
            -- Clamp own velocity
            if r then
                if r.AssemblyLinearVelocity.Magnitude > 80 or r.AssemblyAngularVelocity.Magnitude > 80 then
                    r.AssemblyLinearVelocity = Vector3.new(0, -1, 0)
                    r.AssemblyAngularVelocity = Vector3.zero
                end
                -- Remove foreign BodyMovers injected by exploiters
                for _, obj in ipairs(r:GetChildren()) do
                    if obj:IsA("BodyVelocity") or obj:IsA("BodyAngularVelocity") or obj:IsA("BodyForce") or obj:IsA("BodyThrust") then
                        if obj.Name ~= "lz_fly_bv" and obj.Name ~= "lz_fly_bg" then
                            pcall(function() obj:Destroy() end)
                        end
                    end
                end
            end
            -- Disable collision on other players' parts and clamp their velocity
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character then
                    for _, part in ipairs(p.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                            if part.AssemblyLinearVelocity.Magnitude > 100 or part.AssemblyAngularVelocity.Magnitude > 100 then
                                part.AssemblyLinearVelocity = Vector3.zero
                                part.AssemblyAngularVelocity = Vector3.zero
                            end
                        end
                    end
                end
            end
            -- Noclip own non-root parts
            for _, l in ipairs(c:GetChildren()) do
                if l:IsA("BasePart") and l.Name ~= "HumanoidRootPart" then l.CanCollide = false end
            end
        end))
        Notify("Anti-Fling", "Ironclad v2 Protection Active", C.green, 2.5)
