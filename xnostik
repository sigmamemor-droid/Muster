        WMText.Text = string.format("⚡ Gothbreach MM2 | FPS: %d | Ping: %dms", State.FPS, State.Ping)
        if infoValues.FPS then infoValues.FPS.Text = tostring(State.FPS) end
        if infoValues.Ping then infoValues.Ping.Text = State.Ping.."ms" end
    end
end)

