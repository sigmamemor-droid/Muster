-- ФУНКЦИЯ ПОИСКА И СТРЕЛЬБЫ (улучшенная)
local function FindGunTool()
    local char = GetCharacter()
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            local n = v.Name:lower()
            if n:find("gun") or n:find("pistol") or n:find("revolver") or n == "gun" then
                return v
            end
        end
    end
    return nil
end

local function AttemptShoot(targetHead)
    if not targetHead then return false end
    local tool = FindGunTool()
    if not tool then return false end

    local remotes = {}
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            table.insert(remotes, v)
        end
    end

    if #remotes == 0 then return false end

    local success = false
    for _, remote in ipairs(remotes) do
        local ok = pcall(function()
            remote:FireServer(targetHead.Position, targetHead)
        end)
        if ok then success = true end

        pcall(function()
            remote:FireServer(targetHead)
        end)

        pcall(function()
            remote:FireServer(targetHead.Position)
        end)
    end
    return success
end

