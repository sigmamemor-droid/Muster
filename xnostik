local SNOWFLAKE_CHARS = {"❄", "❅", "❆", "✦", "•", "◦", "✧"}

local function CreateSnowflake()
    local sf = Instance.new("TextLabel")
    sf.BackgroundTransparency = 1
    sf.Text       = SNOWFLAKE_CHARS[math.random(1, #SNOWFLAKE_CHARS)]
    sf.TextColor3 = C.snow
    sf.Font       = Enum.Font.GothamBold
    sf.ZIndex     = 101
    sf.Parent     = LoadingScreen

    local size = math.random(8, 22)
    sf.TextSize = size

    local startX = math.random(0, 100) / 100
    local alpha  = math.random(15, 70) / 100

    sf.Size             = UDim2.new(0, size + 10, 0, size + 10)
    sf.Position         = UDim2.new(startX, 0, -0.05, 0)
    sf.TextTransparency = alpha
    sf.Rotation         = math.random(0, 360)

    local fallDuration = math.random(30, 80) / 10  -- 3.0 - 8.0 seconds
    local drift        = (math.random() - 0.5) * 0.15  -- horizontal drift

    local tween = TweenService:Create(sf,
        TweenInfo.new(fallDuration, Enum.EasingStyle.Linear),
        {
            Position = UDim2.new(startX + drift, 0, 1.1, 0),
            Rotation = sf.Rotation + math.random(-180, 180),
            TextTransparency = math.clamp(alpha + 0.2, 0, 1),
        }
    )
    tween:Play()
    tween.Completed:Connect(function()
        sf:Destroy()
    end)

    return sf
end

-- Snowfall spawner loop
