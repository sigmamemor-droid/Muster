local function FindGun()
    local c = GetChar(); if not c then return nil end
    for _, v in ipairs(c:GetChildren()) do
        if v:IsA("Tool") then
            local n = v.Name:lower()
            if n:find("gun") or n:find("pistol") or n:find("revolver") then return v end
        end
    end
end

local function DoShoot(head)
    if not head then return false end
    local t = FindGun(); if not t then return false end
    local ok = false
    for _, v in ipairs(t:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            pcall(function() v:FireServer(head.Position, head) end)
            pcall(function() v:FireServer(head) end)
            pcall(function() v:FireServer(head.Position) end)
            ok = true
        end
    end
    return ok
end

