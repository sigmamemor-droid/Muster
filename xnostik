-- ==================== ГЛАВНЫЙ ЛУП ====================
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    if states.speed then hum.WalkSpeed = 45 end
    if states.antiFling and root.Velocity.Magnitude > 250 then
        root.Velocity = Vector3.new(0,0,0)
    end
    if states.aimMurderer then
        local head = GetMurdererHead()
        if head then camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position) end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if states.infJump and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState("Jumping") end
    end
end)

