local Tabs = {}

local function CreateTab(icon, name)
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(1, 0, 0, 38)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = "  " .. icon .. "  " .. name
    TabBtn.TextColor3 = Theme.TextMuted
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 12
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.Parent = Sidebar

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 3, 0, 0)
    Indicator.Position = UDim2.new(0, 0, 0.5, 0)
    Indicator.BackgroundColor3 = Theme.AccentNeon
    Indicator.BorderSizePixel = 0
    Indicator.Parent = TabBtn
    table.insert(IDK.ThemedElements.Accents, Indicator)

    local TabFrame = Instance.new("ScrollingFrame")
    TabFrame.Size = UDim2.new(1, -20, 1, -20)
    TabFrame.Position = UDim2.new(0, 10, 0, 10)
    TabFrame.BackgroundTransparency = 1
    TabFrame.ScrollBarThickness = 2
    TabFrame.ScrollBarImageColor3 = Theme.TextMuted
    TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabFrame.Visible = false
    TabFrame.Parent = ContentArea

    local Layout = Instance.new("UIListLayout", TabFrame)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    Layout.Padding = UDim.new(0, 8)

    TabBtn.MouseButton1Click:Connect(function()
        if IDK.CurrentTab == TabBtn then return end
        for btn, frame in pairs(Tabs) do
            TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = Theme.TextMuted}):Play()
            TweenService:Create(btn:FindFirstChild("Frame"), TweenInfo.new(0.2), {Size = UDim2.new(0, 3, 0, 0), Position = UDim2.new(0, 0, 0.5, 0)}):Play()
            frame.Visible = false
        end
        IDK.CurrentTab = TabBtn
        TweenService:Create(TabBtn, TweenInfo.new(0.2), {TextColor3 = Theme.Text}):Play()
        TweenService:Create(Indicator, TweenInfo.new(0.2), {Size = UDim2.new(0, 3, 1, -12), Position = UDim2.new(0, 0, 0, 6)}):Play()
        
        TabFrame.Position = UDim2.new(0, 40, 0, 10)
        TabFrame.Visible = true
        TweenService:Create(TabFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 10, 0, 10)}):Play()
    end)

    Tabs[TabBtn] = TabFrame
    return TabFrame
end

local function CreateToggle(parent, text, default, callback)
    local active = default
    local ToggleFrame = Instance.new("TextButton")
    ToggleFrame.Size = UDim2.new(1, -10, 0, 38)
    ToggleFrame.BackgroundColor3 = Theme.Card
    ToggleFrame.Text = ""
    ToggleFrame.AutoButtonColor = false
    ToggleFrame.Parent = parent
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", ToggleFrame).Color = Theme.Border

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Theme.Text
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame

    local Outer = Instance.new("Frame")
    Outer.Size = UDim2.new(0, 36, 0, 18)
    Outer.Position = UDim2.new(1, -48, 0.5, -9)
    Outer.BackgroundColor3 = Theme.BG
    Outer.Parent = ToggleFrame
    Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", Outer).Color = Theme.Border

    local Dot = Instance.new("Frame")
    Dot.Size = UDim2.new(0, 14, 0, 14)
    Dot.Position = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    Dot.BackgroundColor3 = active and Theme.AccentNeon or Theme.TextMuted
    Dot.Parent = Outer
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    
    if active then table.insert(IDK.ThemedElements.Accents, Dot) end

    ToggleFrame.MouseButton1Click:Connect(function()
        active = not active
        TweenService:Create(Dot, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        }):Play()
        
        if active then
            Dot.BackgroundColor3 = Theme.AccentNeon
            table.insert(IDK.ThemedElements.Accents, Dot)
        else
            Dot.BackgroundColor3 = Theme.TextMuted
            for i, v in ipairs(IDK.ThemedElements.Accents) do
                if v == Dot then table.remove(IDK.ThemedElements.Accents, i) break end
            end
        end
        callback(active)
    end)
    if default then task.spawn(callback, active) end
end

