    if jobId and jobId ~= "" then
        pcall(function()
            setclipboard("Roblox.GameLauncher.joinGameInstance(" .. game.PlaceId .. ", '" .. jobId .. "')")
        end)
        Notify("System", "Server link copied!", C.green, 2)
    else
        Notify("System", "Could not get server link", C.orange, 2)
    end
end)

