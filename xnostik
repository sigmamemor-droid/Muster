local espC = {}
local function ClearESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("MobileESP") then 
            p.Character.MobileESP:Destroy() 
        end
    end
    for k, c in pairs(espC) do 
        if typeof(c) == "RBXScriptConnection" then c:Disconnect() end 
    end
    espC = {}
end

local function ApplyHighlight(ch, col)
    if not ch then return end
    if ch:FindFirstChild("MobileESP") then 
        ch.MobileESP:Destroy() 
    end
    
    local h = Instance.new("Highlight")
    h.Name = "MobileESP"
    h.FillColor = col
    h.FillTransparency = 0.55
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.OutlineTransparency = 0.2
    h.Adornee = ch
    h.Parent = ch
end

local function PlayerESP(p, col)
    if p == player then return end
    if p.Character then ApplyHighlight(p.Character, col) end
    local k = "e_" .. p.UserId
    if espC[k] then espC[k]:Disconnect() end
    espC[k] = p.CharacterAdded:Connect(function(c) 
        task.wait(0.4)
        ApplyHighlight(c, col) 
    end)
end

