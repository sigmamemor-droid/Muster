-- Функция флинга
local function FlingPlayer(target, duration)
    if not target or not target.Character then
        Notify("Fling Error", "Target not found", C.red, 2)
        return
    end
    local r = GetRoot()
    local h = GetHum()
    local tR = target.Character:FindFirstChild("HumanoidRootPart")
    local tH = target.Character:FindFirstChildOfClass("Humanoid")
    if not r or not tR or not h or not tH or tH.Health <= 0 then
        Notify("Fling Error", "Invalid target state", C.red, 2)
        return
    end

    local savedPos = r.CFrame
    local stored = {}
    for _, p in ipairs(GetChar():GetDescendants()) do
        if p:IsA("BasePart") then
            stored[p] = {p.CanCollide, p.Massless}
            p.CanCollide = false
            p.Massless = true
        end
    end
    r.CanCollide = true
    local bav = Instance.new("BodyAngularVelocity")
    bav.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bav.AngularVelocity = Vector3.new(256, 256, 256)
    bav.Parent = r
    h:ChangeState(Enum.HumanoidStateType.Physics)

    local start = tick()
    local dur = duration or 3.2
    while tick() - start < dur do
        if not tR or not tR.Parent or tH.Health <= 0 then break end
        pcall(function()
            r.CFrame = tR.CFrame * CFrame.new(0, -1.3, 0)
            r.AssemblyLinearVelocity = tR.CFrame.LookVector * 256
        end)
        task.wait(0.01)
    end

    pcall(function()
        bav:Destroy()
        r.AssemblyLinearVelocity = Vector3.zero
        r.AssemblyAngularVelocity = Vector3.zero
        r.CFrame = savedPos
        h:ChangeState(Enum.HumanoidStateType.GettingUp)
    end)
    for p, d in pairs(stored) do
        if p.Parent then
            p.CanCollide = d[1]
            p.Massless = d[2]
        end
    end
    Notify("Fling Complete", target.DisplayName .. " sent flying!", C.green, 2)
end

