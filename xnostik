function AztupUI:NewWindow(options)
    local Window = {}
    Window.Name = options.Name or "Aztup Hub"
    Window.Size = options.Size or Vector2.new(500, 600)
    Window.Position = options.Position or UDim2.new(0.5, -250, 0.5, -300)
    Window.Theme = options.Theme or "CyberBlue"
    Window.Tabs = {}
    Window.ActiveTab = nil
    Window.Objects = {}
    Window.Draggable = options.Draggable ~= false
    Window.Closable = options.Closable ~= false
    Window.AutoShow = options.AutoShow ~= false
    
    --[=[ СОЗДАНИЕ GUI ]=]
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AztupHub_GUI"
    ScreenGui.Parent = CoreGui
    
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.fromOffset(Window.Size.X, Window.Size.Y)
    MainFrame.Position = Window.Position
    MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 25)
    MainFrame.BackgroundTransparency = 0.08
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = false
    MainFrame.Parent = ScreenGui
    
    -- Углы (скругление через UICorner)
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 12)
    UICorner.Parent = MainFrame
    
    -- Стекло (Glassmorphism)
    local Glass = Instance.new("Frame")
    Glass.Size = UDim2.fromScale(1, 1)
    Glass.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Glass.BackgroundTransparency = 0.95
    Glass.BorderSizePixel = 0
    Glass.Parent = MainFrame
    local GlassCorner = Instance.new("UICorner")
    GlassCorner.CornerRadius = UDim.new(0, 12)
    GlassCorner.Parent = Glass
    
    -- Обводка (неоновая)
    local Stroke = Instance.new("UIStroke")
    Stroke.Thickness = 2
    Stroke.Color = Color3.fromRGB(0, 200, 255)
    Stroke.Transparency = 0.5
    Stroke.Parent = MainFrame
    
    -- Заголовок
    local Title = Instance.new("TextLabel")
    Title.Name = "Title"
    Title.Size = UDim2.fromScale(1, 0.08)
    Title.Position = UDim2.fromScale(0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = "◈ AZTUP HUB ◈ v" .. AztupHub.Version
    Title.TextColor3 = Color3.fromRGB(0, 220, 255)
    Title.TextScaled = true
    Title.Font = Enum.Font.GothamBold
    Title.TextXAlignment = Enum.TextXAlignment.Center
    Title.TextYAlignment = Enum.TextYAlignment.Center
    Title.Parent = MainFrame
    
    -- Линия-разделитель под заголовком
    local Divider = Instance.new("Frame")
    Divider.Size = UDim2.fromScale(0.9, 0.005)
    Divider.Position = UDim2.fromScale(0.05, 0.09)
    Divider.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    Divider.BackgroundTransparency = 0.4
    Divider.BorderSizePixel = 0
    Divider.Parent = MainFrame
    
    -- Список вкладок (вертикальные слева)
    local TabList = Instance.new("ScrollingFrame")
    TabList.Name = "TabList"
    TabList.Size = UDim2.fromScale(0.2, 0.85)
    TabList.Position = UDim2.fromScale(0.02, 0.12)
    TabList.BackgroundTransparency = 1
    TabList.BorderSizePixel = 0
    TabList.ScrollBarThickness = 2
    TabList.CanvasSize = UDim2.fromScale(0, #Window.Tabs * 0.08)
    TabList.Parent = MainFrame
    
    local TabButtons = {}
    for i, tabName in ipairs(Window.Tabs) do
        local btn = Instance.new("TextButton")
        btn.Name = "Tab_" .. tabName
        btn.Size = UDim2.fromScale(0.95, 0.07)
        btn.Position = UDim2.fromScale(0.025, 0.03 + (i-1) * 0.085)
        btn.BackgroundColor3 = (i == 1) and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(20, 20, 40)
        btn.BackgroundTransparency = (i == 1) and 0.3 or 0.7
        btn.BorderSizePixel = 0
        btn.Text = tabName
        btn.TextColor3 = (i == 1) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 180)
        btn.TextScaled = true
        btn.Font = Enum.Font.GothamMedium
        btn.Parent = TabList
        btn.TabData = {Index = i, Name = tabName}
        
        btn.MouseButton1Click:Connect(function()
            for _, b in ipairs(TabList:GetChildren()) do
                if b:IsA("TextButton") then
                    b.BackgroundColor3 = Color3.fromRGB(20, 20, 40)
                    b.BackgroundTransparency = 0.7
                    b.TextColor3 = Color3.fromRGB(150, 150, 180)
                end
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            btn.BackgroundTransparency = 0.3
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            Window.ActiveTab = tabName
            -- Скрыть все контейнеры и показать нужный
            for _, child in ipairs(MainFrame:GetChildren()) do
                if child.Name == "Container_" .. tabName then
                    child.Visible = true
                elseif string.match(child.Name, "^Container_") then
                    child.Visible = false
                end
            end
        end)
        table.insert(TabButtons, btn)
        
        -- Контейнер для содержимого вкладки
        local container = Instance.new("ScrollingFrame")
        container.Name = "Container_" .. tabName
        container.Size = UDim2.fromScale(0.72, 0.82)
        container.Position = UDim2.fromScale(0.25, 0.14)
        container.BackgroundColor3 = Color3.fromRGB(15, 15, 35)
        container.BackgroundTransparency = 0.6
        container.BorderSizePixel = 0
        container.Visible = (i == 1)
        container.ScrollBarThickness = 3
        container.CanvasSize = UDim2.fromScale(1, 2)
        container.Parent = MainFrame
        Window["Container_" .. tabName] = container
        
        -- UIListLayout для автоматического расположения
        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0, 8)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Parent = container
    end
    
    -- Кнопка закрытия (крестик)
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Name = "CloseBtn"
    CloseBtn.Size = UDim2.fromOffset(30, 30)
    CloseBtn.Position = UDim2.fromScale(0.93, 0.01)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.Text = "✕"
    CloseBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    CloseBtn.TextScaled = true
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.Parent = MainFrame
    CloseBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
        AztupHub.State.UI_Visible = false
    end)
    
    -- Перетаскивание
    if Window.Draggable then
        local dragging = false
        local dragOffset = Vector2.new(0, 0)
        local dragStart = Vector2.new(0, 0)
        
        Title.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragOffset = Vector2.new(Mouse.X - MainFrame.AbsolutePosition.X, Mouse.Y - MainFrame.AbsolutePosition.Y)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        RunService.RenderStepped:Connect(function()
            if dragging then
                MainFrame.Position = UDim2.new(0, Mouse.X - dragOffset.X, 0, Mouse.Y - dragOffset.Y)
            end
        end)
    end
    
    Window.MainFrame = MainFrame
    Window.ScreenGui = ScreenGui
    Window.UI = AztupUI
    return Window
end

--[=[ МЕТОДЫ UI ДЛЯ СОЗДАНИЯ ЭЛЕМЕНТОВ ]=]
function AztupUI:CreateToggle(container, options)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.fromScale(0.9, 0.06)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 50)
    frame.BackgroundTransparency = 0.5
    frame.BorderSizePixel = 0
    frame.Parent = container
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.fromScale(0.6, 1)
    label.BackgroundTransparency = 1
    label.Text = options.Name or "Toggle"
    label.TextColor3 = Color3.fromRGB(200, 200, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextSize = 14
    label.Font = Enum.Font.GothamMedium
    label.Parent = frame
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.fromScale(0.25, 0.8)
    toggleBtn.Position = UDim2.fromScale(0.72, 0.1)
    toggleBtn.BackgroundColor3 = options.Default and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(50, 50, 80)
    toggleBtn.Text = options.Default and "ON" or "OFF"
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 12
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = frame
    toggleBtn.Value = options.Default or false
    
    toggleBtn.MouseButton1Click:Connect(function()
        toggleBtn.Value = not toggleBtn.Value
        toggleBtn.BackgroundColor3 = toggleBtn.Value and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(50, 50, 80)
        toggleBtn.Text = toggleBtn.Value and "ON" or "OFF"
        if options.Callback then
            options.Callback(toggleBtn.Value)
        end
    end)
    return toggleBtn
end

function AztupUI:CreateSlider(container, options)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.fromScale(0.9, 0.08)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 50)
    frame.BackgroundTransparency = 0.5
    frame.BorderSizePixel = 0
    frame.Parent = container
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.fromScale(0.5, 0.5)
    label.Position = UDim2.fromScale(0.05, 0)
    label.BackgroundTransparency = 1
    label.Text = options.Name or "Slider"
    label.TextColor3 = Color3.fromRGB(200, 200, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextSize = 14
    label.Font = Enum.Font.GothamMedium
    label.Parent = frame
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.fromScale(0.2, 0.5)
    valueLabel.Position = UDim2.fromScale(0.75, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(options.Default or 0)
    valueLabel.TextColor3 = Color3.fromRGB(0, 200, 255)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.TextSize = 14
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.Parent = frame
    
    local slider = Instance.new("Frame")
    slider.Size = UDim2.fromScale(0.7, 0.1)
    slider.Position = UDim2.fromScale(0.1, 0.7)
    slider.BackgroundColor3 = Color3.fromRGB(40, 40, 70)
    slider.BorderSizePixel = 0
    slider.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.fromScale((options.Default - (options.Min or 0)) / ((options.Max or 100) - (options.Min or 0)), 1)
    fill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    fill.BorderSizePixel = 0
    fill.Parent = slider
    
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.fromScale(0.07, 1.5)
    sliderBtn.Position = UDim2.fromScale((options.Default - (options.Min or 0)) / ((options.Max or 100) - (options.Min or 0)) - 0.035, -0.25)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.Text = ""
    sliderBtn.BorderSizePixel = 0
    sliderBtn.Parent = slider
    
    local function updateSlider(value)
        value = math.clamp(value, options.Min or 0, options.Max or 100)
        local percent = (value - (options.Min or 0)) / ((options.Max or 100) - (options.Min or 0))
        fill.Size = UDim2.fromScale(percent, 1)
        sliderBtn.Position = UDim2.fromScale(percent - 0.035, -0.25)
        valueLabel.Text = tostring(math.round(value))
        if options.Callback then
            options.Callback(math.round(value))
        end
    end
    
    sliderBtn.MouseButton1Down:Connect(function()
        while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            local pos = Mouse.X - slider.AbsolutePosition.X
            local width = slider.AbsoluteSize.X
            local value = (pos / width) * ((options.Max or 100) - (options.Min or 0)) + (options.Min or 0)
            updateSlider(value)
            task.wait()
        end
    end)
    
    updateSlider(options.Default or 50)
    return sliderBtn
end

