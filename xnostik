-- УТИЛИТЫ (MM2 Logic)
---------------------------------------------------------
local function GetCharacter() return player.Character end
local function GetRoot() local c = GetCharacter() return c and c:FindFirstChild("HumanoidRootPart") end
local function GetHumanoid() local c = GetCharacter() return c and c:FindFirstChildOfClass("Humanoid") end

local function GetRole(p)
    if not p.Character then return "Innocent" end
    -- Оптимизированный поиск роли (без жесткой привязки только к имени)
    local hasKnife = false
    local hasGun = false
    
    local function checkContainer(container)
        for _, v in ipairs(container:GetChildren()) do
            if v:IsA("Tool") then
                if v.Name:lower():find("knife") or v:FindFirstChild("KnifeServer") or v:FindFirstChild("KnifeScript") then hasKnife = true end
                if v.Name:lower():find("gun") or v.Name:lower():find("revolver") or v:FindFirstChild("GunScript") then hasGun = true end
            end
        end
    end
    
    checkContainer(p.Backpack)
    checkContainer(p.Character)
    
    if hasKnife then return "Murderer" end
    if hasGun then return "Sheriff" end
    return "Innocent"
end

