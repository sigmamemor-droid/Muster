local espMurdEnabled, espSherEnabled, espInnEnabled = false, false, false
local espGunEnabled, espTracersEnabled, espBoxesEnabled = false, false, false

MkSep("Home", "subtab_labels", Sub_Labels)

local function ClearRoles() 
    for _, p in ipairs(Players:GetPlayers()) do 
        if p.Character and p.Character:FindFirstChild("MobileESP") then 
            p.Character.MobileESP:Destroy() 
        end 
    end 
end

local function ApplyHighlight(ch, col) 
    if not ch then return end; 
    if ch:FindFirstChild("MobileESP") then ch.MobileESP:Destroy() end; 
    local h = Instance.new("Highlight"); 
    h.Name = "MobileESP"; 
    h.FillColor = col; 
    h.FillTransparency = 0.55; 
    h.OutlineColor = Color3.fromRGB(255,255,255); 
    h.OutlineTransparency = 0.2; 
    h.Adornee = ch; 
    h.Parent = ch 
end

-- Единая функция обновления ролей на основе раздельных тумблеров
local function UpdateTacticalESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local isM, isS = IsMurderer(p), IsSheriff(p)
            
            if isM and espMurdEnabled then
                ApplyHighlight(p.Character, Color3.fromRGB(255, 50, 50))
            elseif isS and espSherEnabled then
                ApplyHighlight(p.Character, Color3.fromRGB(50, 150, 255))
            elseif not isM and not isS and espInnEnabled then
                ApplyHighlight(p.Character, Color3.fromRGB(50, 255, 100))
            else
                -- Убираем подсветку, если роль выключена
                if p.Character:FindFirstChild("MobileESP") then
                    p.Character.MobileESP:Destroy()
                end
            end
        end
    end
end

-- Включение циклической проверки ролей при изменении настроек
local function ToggleRoleLoop()
    ClearConn("esp_roles_loop")
    if espMurdEnabled or espSherEnabled or espInnEnabled then
        local lastUpdate = 0
        Conn("esp_roles_loop", RunService.Heartbeat:Connect(function()
            if tick() - lastUpdate > 0.5 then
                lastUpdate = tick()
                UpdateTacticalESP()
            end
        end))
        UpdateTacticalESP()
    else
        ClearRoles()
    end
end

