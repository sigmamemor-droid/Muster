local function getRole(p)
    if not p.Character then return "Unknown" end
    local c, bp = p.Character, p:FindFirstChild("Backpack")
    local knife = c:FindFirstChild("Knife") or (bp and bp:FindFirstChild("Knife"))
    local gun = c:FindFirstChild("Gun") or (bp and bp:FindFirstChild("Gun")) or c:FindFirstChild("Revolver") or (bp and bp:FindFirstChild("Revolver"))
    if knife then return "Murderer" end
    if gun then return "Sheriff" end
    return "Innocent"
end
local function roleColor(r)
    if r=="Murderer" then return Color3.fromRGB(255,50,70) end
    if r=="Sheriff" then return Color3.fromRGB(60,130,255) end
    return Color3.fromRGB(60,220,150)
end

local function getClosestToMouse(maxDist)
    local mouse = UserInputService:GetMouseLocation()
    local closest, shortest = nil, maxDist or math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("Humanoid")
            local part = p.Character:FindFirstChild(State.AimPart) or p.Character:FindFirstChild("Head")
            if h and h.Health > 0 and part then
                if State.TeamCheck then
                    local myRole = getRole(LocalPlayer)
                    local tRole = getRole(p)
                    if myRole=="Murderer" and tRole=="Innocent" then continue end
                end
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local dist = (Vector2.new(sp.X, sp.Y) - mouse).Magnitude
                    if dist < shortest then shortest = dist closest = p end
                end
            end
        end
    end
    return closest
end

-- ESP object cache
local espObjects = {}

RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    -- FOV Circle follows mouse
    if State.ShowFOV then
        local m = UserInputService:GetMouseLocation()
        FOVCircle.Position = UDim2.new(0, m.X, 0, m.Y + 36)
    end

    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")

    -- AIMBOT
    if State.AimbotEnabled then
        local target = getClosestToMouse(State.AimbotFOV)
        if target and target.Character then
            local part = target.Character:FindFirstChild(State.AimPart) or target.Character:FindFirstChild("Head")
            if part then
                if State.AimSmoothing then
                    local goal = CFrame.new(Camera.CFrame.Position, part.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(goal, 1/State.AimSmoothAmount)
                else
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                end
            end
        end
    end

    -- FLY
    if State.FlyEnabled and State.FlyBodyVelocity and myRoot then
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end
        if dir.Magnitude > 0 then dir = dir.Unit end
        State.FlyBodyVelocity.Velocity = dir * State.FlySpeed
        if State.FlyBodyGyro then State.FlyBodyGyro.CFrame = Camera.CFrame end
    end

    -- SPEED
    if State.SpeedEnabled and myChar:FindFirstChild("Humanoid") then
        myChar.Humanoid.WalkSpeed = State.WalkSpeed
    end

    -- NOCLIP
    if State.NoclipEnabled and myChar then
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end

    -- VISUALS
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        local char = p.Character
        local h = char:FindFirstChild("Humanoid")
        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart")
        local alive = h and h.Health > 0
        local role = getRole(p)
        local col = roleColor(role)

        -- CHAMS
        if State.ChamsEnabled and alive then
            local hl = char:FindFirstChild("GBHL")
            if not hl then
                hl = Instance.new("Highlight") hl.Name="GBHL" hl.Parent=char
                hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                hl.OutlineTransparency=0.2
            end
            hl.FillColor=col hl.OutlineColor=col hl.FillTransparency=State.ChamsTransparency
        else
            local hl=char:FindFirstChild("GBHL") if hl then hl:Destroy() end
        end

        -- Cache ESP drawings
        if not espObjects[p] then
            espObjects[p] = {
                box = Drawing and Drawing.new("Square") or nil,
                tracer = Drawing and Drawing.new("Line") or nil,
            }
            if espObjects[p].box then espObjects[p].box.Thickness=1 espObjects[p].box.Filled=false end
            if espObjects[p].tracer then espObjects[p].tracer.Thickness=1 end
        end
        local eo = espObjects[p]

        -- BOX + TRACER (Drawing API)
        if alive and root and Drawing then
            local sp, on = Camera:WorldToViewportPoint(root.Position)
            if on and (State.BoxEsp or State.TracersEnabled) then
                local size = (Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0)).Y - Camera:WorldToViewportPoint(root.Position + Vector3.new(0,3,0)).Y)
                local w = size/2
                if State.BoxEsp and eo.box then
                    eo.box.Visible=true eo.box.Color=col
                    eo.box.Size=Vector2.new(w, size)
                    eo.box.Position=Vector2.new(sp.X - w/2, sp.Y - size/2)
                elseif eo.box then eo.box.Visible=false end
                if State.TracersEnabled and eo.tracer then
                    eo.tracer.Visible=true eo.tracer.Color=col
                    eo.tracer.From=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    eo.tracer.To=Vector2.new(sp.X, sp.Y + size/2)
                elseif eo.tracer then eo.tracer.Visible=false end
            else
                if eo.box then eo.box.Visible=false end
                if eo.tracer then eo.tracer.Visible=false end
            end
        else
            if eo.box then eo.box.Visible=false end
            if eo.tracer then eo.tracer.Visible=false end
        end

        -- NAME ESP + HEALTH BAR (Billboard)
        if (State.EspEnabled or State.HealthBar) and alive and head then
            local bill = head:FindFirstChild("GBESP")
            if not bill then
                bill=Instance.new("BillboardGui") bill.Name="GBESP" bill.Adornee=head
                bill.Size=UDim2.new(0,180,0,55) bill.StudsOffset=Vector3.new(0,2.8,0)
                bill.AlwaysOnTop=true bill.Parent=head
                local nm=Instance.new("TextLabel") nm.Name="Nm" nm.BackgroundTransparency=1 nm.Size=UDim2.new(1,0,0,16) nm.Font=Enum.Font.GothamBold nm.TextSize=13 nm.TextStrokeTransparency=0.5 nm.Parent=bill
                local rl=Instance.new("TextLabel") rl.Name="Rl" rl.BackgroundTransparency=1 rl.Position=UDim2.new(0,0,0,16) rl.Size=UDim2.new(1,0,0,14) rl.Font=Enum.Font.GothamSemibold rl.TextSize=11 rl.TextStrokeTransparency=0.5 rl.Parent=bill
                local dl=Instance.new("TextLabel") dl.Name="Dl" dl.BackgroundTransparency=1 dl.Position=UDim2.new(0,0,0,30) dl.Size=UDim2.new(1,0,0,12) dl.Font=Enum.Font.Gotham dl.TextSize=10 dl.TextColor3=Colors.TextMuted dl.TextStrokeTransparency=0.6 dl.Parent=bill
                local hbBg=Instance.new("Frame") hbBg.Name="HBBg" hbBg.BackgroundColor3=Color3.fromRGB(0,0,0) hbBg.BackgroundTransparency=0.4 hbBg.BorderSizePixel=0 hbBg.Position=UDim2.new(0.15,0,0,44) hbBg.Size=UDim2.new(0.7,0,0,4) corner(hbBg,2) hbBg.Parent=bill
                local hbFill=Instance.new("Frame") hbFill.Name="HBFill" hbFill.BackgroundColor3=Colors.Green hbFill.BorderSizePixel=0 hbFill.Size=UDim2.new(1,0,1,0) corner(hbFill,2) hbFill.Parent=hbBg
            end
            local nm,rl,dl=bill:FindFirstChild("Nm"),bill:FindFirstChild("Rl"),bill:FindFirstChild("Dl")
            local hbBg=bill:FindFirstChild("HBBg")
            if State.EspEnabled then
                nm.Visible=true rl.Visible=true dl.Visible=true
                nm.Text=p.DisplayName nm.TextColor3=col
                rl.Text=role rl.TextColor3=col
                if myRoot then dl.Text=math.floor((myRoot.Position-head.Position).Magnitude).." studs" end
            else nm.Visible=false rl.Visible=false dl.Visible=false end
            if State.HealthBar then
                hbBg.Visible=true
                local hbFill=hbBg:FindFirstChild("HBFill")
                local pct=h.Health/h.MaxHealth
                hbFill.Size=UDim2.new(pct,0,1,0)
                hbFill.BackgroundColor3=Color3.fromRGB(255*(1-pct), 220*pct, 100*pct)
            else hbBg.Visible=false end
        else
            if head then local b=head:FindFirstChild("GBESP") if b then b:Destroy() end end
        end
    end
end)

