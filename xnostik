    if not MainGui or not MainGui.Parent then return end
    
    for _, desc in ipairs(MainGui:GetDescendants()) do
        pcall(function()
            if desc:IsA("Frame") or desc:IsA("TextButton") then
                if desc.BackgroundColor3 == Color3.fromRGB(255, 50, 50) or desc.BackgroundColor3 == Color3.fromRGB(50, 150, 255) then
                    desc.BackgroundColor3 = CurrentAccent
