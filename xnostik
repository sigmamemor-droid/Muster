-- Рендер циклы для Трасеров и Коробок с учетом активных ролей
RunService.RenderStepped:Connect(function()
    if not espTracersEnabled and not espBoxesEnabled then return end
    
    for _, draw in ipairs(activeTracers) do pcall(function() draw:Destroy() end) end
    for _, draw in ipairs(activeBoxes) do pcall(function() draw:Destroy() end) end
    activeTracers = {}
    activeBoxes = {}
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            local isM, isS = IsMurderer(p), IsSheriff(p)
            
            -- Проверяем, разрешен ли показ этой роли настройками
            local isAllowed = (isM and espMurdEnabled) or (isS and espSherEnabled) or (not isM and not isS and espInnEnabled)
            
            if isAllowed then
                local root = p.Character.HumanoidRootPart
                local pos, onScreen = camera:WorldToViewportPoint(root.Position)
                
                if onScreen then
                    local col = Color3.fromRGB(50,255,100)
                    if isM then col = Color3.fromRGB(255,50,50)
                    elseif isS then col = Color3.fromRGB(50,150,255) end
                    
                    if espTracersEnabled then
                        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        DrawLine(screenCenter, Vector2.new(pos.X, pos.Y), col)
                    end
                    
                    if espBoxesEnabled then
                        local height = (camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0)).Y)
                        local width = height * 0.6
                        DrawBox(Vector2.new(pos.X, pos.Y), Vector2.new(width, height), col)
                    end
                end
            end
        end
    end
end)

