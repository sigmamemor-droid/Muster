local function GetChar() return LocalPlayer.Character end
local function GetHum() local c=GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c=GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function FindTool(name)
	-- Priority: Character (equipped) > Backpack
	local c = GetChar()
	return (c and c:FindFirstChild(name)) or (LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild(name))
end

local function EquipTool(name)
	local hum = GetHum(); local tool = FindTool(name)
	if hum and tool and tool.Parent == LocalPlayer.Backpack then
		hum:EquipTool(tool)
		task.wait(0.15) -- Replication delay
	end
	return GetChar() and GetChar():FindFirstChild(name)
end

-- Dynamic Remote Finder (MM2 obfuscates names often)
local function GetRemotes()
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	if not remotes then return {}, {} end
	
	local knifeRemote, gunRemote = nil, nil
	-- Common patterns
	for _, v in ipairs(remotes:GetDescendants()) do
		if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
			local n = v.Name:lower()
			if (n:find("throw") or n:find("knife")) and not knifeRemote then knifeRemote = v end
			if (n:find("shoot") or n:find("gun") or n:find("fire")) and not gunRemote then gunRemote = v end
		end
	end
	-- Fallback: Check inside tools when equipped
	return knifeRemote, gunRemote
end

-- Role Detection via Attributes (Most reliable in modern MM2)
local function GetRoles()
	local roles = { Murderer = nil, Sheriff = nil, Hero = nil }
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			local role = plr:GetAttribute("Role") or plr:GetAttribute("CurrentRole")
			if role == "Murderer" then roles.Murderer = plr
			elseif role == "Sheriff" then roles.Sheriff = plr
			elseif role == "Hero" then roles.Hero = plr end
		end
	end
	-- Fallback Tool Check (if attributes missing)
	if not roles.Murderer or not roles.Sheriff then
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer and plr.Character then
				if not roles.Murderer and (plr.Backpack:FindFirstChild("Knife") or plr.Character:FindFirstChild("Knife")) then roles.Murderer = plr end
				if not roles.Sheriff and (plr.Backpack:FindFirstChild("Gun") or plr.Character:FindFirstChild("Gun")) then roles.Sheriff = plr end
			end
		end
	end
	-- Hero Logic: Someone with Gun who isn't the original Sheriff
	if roles.Sheriff and not roles.Hero then
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer and plr ~= roles.Sheriff and plr.Character and plr.Character:FindFirstChild("Gun") then
				roles.Hero = plr; break
			end
		end
	end
	return roles
end

local function GetMurdererHead()
	local roles = GetRoles()
	if roles.Murderer and roles.Murderer.Character then return roles.Murderer.Character:FindFirstChild("Head") end
end

-- Prediction Math
local function PredictPos(targetPart, projSpeed)
	if not targetPart then return nil end
	local root = GetRoot(); if not root then return targetPart.Position end
	local dist = (targetPart.Position - root.Position).Magnitude
	local timeToHit = dist / projSpeed
	local vel = targetPart.AssemblyLinearVelocity
	local pred = targetPart.Position + (vel * timeToHit)
	-- Wall check
	local params = RaycastParams.new(); params.FilterDescendantsInstances = {GetChar()}; params.FilterType = Enum.RaycastFilterType.Exclude
	local ray = workspace:Raycast(root.Position, (pred - root.Position).Unit * dist, params)
	return ray and (ray.Position - (pred - root.Position).Unit * 2) or pred
end

-- Ownership Check for Gun ESP
local function IsPlayerOwned(obj)
	for _, plr in ipairs(Players:GetPlayers()) do
		if (plr.Character and obj:IsDescendantOf(plr.Character)) or (plr.Backpack and obj:IsDescendantOf(plr.Backpack)) then return true end
	end
	return false
end

