    if CurrentTab == id then return end
    CurrentTab = id

    for tid, btn in pairs(TabButtons) do
        btn.TextColor3 = (tid == id) and Theme.Accent or Theme.SubText
    end
    for pid, page in pairs(Pages) do
        page.Visible = (pid == id)
    end
