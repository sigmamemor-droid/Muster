-- CORE SERVICES & UTILS
---------------------------------------------------------
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local function GetChar() return player.Character end
local function GetHum() local c = GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end

local function IsMurderer(p) if p == player or not p.Character then return false end; return (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) ~= nil end
local function IsSheriff(p) if p == player or not p.Character then return false end; return (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) ~= nil end

local function GetMurdererRoot() for _, p in ipairs(Players:GetPlayers()) do if IsMurderer(p) and p.Character then return p.Character:FindFirstChild("HumanoidRootPart") end end; return nil end
local function GetMurdererHead() for _, p in ipairs(Players:GetPlayers()) do if IsMurderer(p) and p.Character then return p.Character:FindFirstChild("Head") end end; return nil end

local function FindGunInHand() local c = GetChar(); if not c then return nil end; for _, t in ipairs(c:GetChildren()) do if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver")) then return t end end; return nil end
local function FindKnifeInHand() local c = GetChar(); if not c then return nil end; for _, t in ipairs(c:GetChildren()) do if t:IsA("Tool") and t.Name:lower():find("knife") then return t end end; return nil end

local cachedGunRemote, cachedKnifeRemote
local function FireGunAtTarget(gun, target) if not gun or not target then return false end; if not cachedGunRemote then for _, r in ipairs(gun:GetDescendants()) do if r:IsA("RemoteEvent") then cachedGunRemote = r; break end end end; if cachedGunRemote then pcall(function() cachedGunRemote:FireServer(target.Position, target) end); return true end return false end
local function ThrowKnifeAtTarget(knife, targetPos) if not knife or not targetPos then return false end; if not cachedKnifeRemote then for _, r in ipairs(knife:GetDescendants()) do if r:IsA("RemoteEvent") then cachedKnifeRemote = r; break end end end; if cachedKnifeRemote then pcall(function() cachedKnifeRemote:FireServer(targetPos) end); return true end return false end

