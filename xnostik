---------------------------------------------------------
-- UI LIBRARY CORE (FLUENT/ORION STYLE)
---------------------------------------------------------
local Library = {}
local Colors = {
    Bg = Color3.fromRGB(20, 20, 25),
    TabBg = Color3.fromRGB(25, 25, 30),
    Accent = Color3.fromRGB(110, 80, 255),
    Text = Color3.fromRGB(240, 240, 240),
    TextDark = Color3.fromRGB(150, 150, 160),
    Element = Color3.fromRGB(30, 30, 35),
    Hover = Color3.fromRGB(40, 40, 45)
}

function Library:CreateWindow(title)
    local UI = Instance.new("ScreenGui")
    UI.Name = "LinbergzPopularUI"
    -- Защита от обнаружения, если запускаем в экзекуторе с поддержкой CoreGui
    local success = pcall(function() UI.Parent = CoreGui end)
    if not success then UI.Parent = lp.PlayerGui end

    -- Cleanup old
    for _, v in pairs(lp.PlayerGui:GetChildren()) do if v.Name == "LinbergzPopularUI" then v:Destroy() end end
    pcall(function() for _, v in pairs(CoreGui:GetChildren()) do if v.Name == "LinbergzPopularUI" then v:Destroy() end end end)

    -- Toggle Button (For Mobile)
    local OpenBtn = Instance.new("TextButton", UI)
    OpenBtn.Size = UDim2.new(0, 45, 0, 45)
    OpenBtn.Position = UDim2.new(0, 10, 0, 10)
    OpenBtn.BackgroundColor3 = Colors.Accent
    OpenBtn.Text = "lz"
    OpenBtn.TextColor3 = Colors.Text
    OpenBtn.Font = Enum.Font.GothamBlack
    OpenBtn.TextSize = 18
    Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1, 0)
    
    local Main = Instance.new("Frame", UI)
    Main.Size = UDim2.new(0, 500, 0, 320)
    Main.Position = UDim2.new(0.5, -250, 0.5, -160)
    Main.BackgroundColor3 = Colors.Bg
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
    
    -- Make Draggable
    local dragging, dragInput, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    Main.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

    -- Open/Close Logic
    local isOpen = true
    OpenBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        Main.Visible = isOpen
    end)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 140, 1, 0)
    Sidebar.BackgroundColor3 = Colors.TabBg
    Sidebar.BorderSizePixel = 0

    local Title = Instance.new("TextLabel", Sidebar)
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.BackgroundTransparency = 1
    Title.Text = "  " .. title
    Title.TextColor3 = Colors.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local TabContainer = Instance.new("ScrollingFrame", Sidebar)
    TabContainer.Size = UDim2.new(1, 0, 1, -40)
    TabContainer.Position = UDim2.new(0, 0, 0, 40)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    local TabList = Instance.new("UIListLayout", TabContainer)
    TabList.Padding = UDim.new(0, 5)
    TabList.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local ContentContainer = Instance.new("Frame", Main)
    ContentContainer.Size = UDim2.new(1, -140, 1, 0)
    ContentContainer.Position = UDim2.new(0, 140, 0, 0)
    ContentContainer.BackgroundTransparency = 1

    local Window = {CurrentTab = nil, Tabs = {}}

    function Window:MakeTab(name)
        local TabBtn = Instance.new("TextButton", TabContainer)
        TabBtn.Size = UDim2.new(0.9, 0, 0, 30)
        TabBtn.BackgroundColor3 = Colors.TabBg
        TabBtn.Text = name
        TabBtn.TextColor3 = Colors.TextDark
        TabBtn.Font = Enum.Font.GothamSemibold
        TabBtn.TextSize = 12
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local Page = Instance.new("ScrollingFrame", ContentContainer)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Colors.Accent
        Page.Visible = false
        local PageList = Instance.new("UIListLayout", Page)
        PageList.Padding = UDim.new(0, 8)
        PageList.HorizontalAlignment = Enum.HorizontalAlignment.Center
        local Pad = Instance.new("UIPadding", Page)
        Pad.PaddingTop = UDim.new(0, 15); Pad.PaddingBottom = UDim.new(0, 15)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Window.Tabs) do
                v.Page.Visible = false
                TweenService:Create(v.Btn, TweenInfo.new(0.3), {TextColor3 = Colors.TextDark, BackgroundColor3 = Colors.TabBg}):Play()
            end
            Page.Visible = true
            TweenService:Create(TabBtn, TweenInfo.new(0.3), {TextColor3 = Colors.Text, BackgroundColor3 = Colors.Accent}):Play()
        end)

        if not Window.CurrentTab then
            Window.CurrentTab = name
            Page.Visible = true
            TabBtn.TextColor3 = Colors.Text
            TabBtn.BackgroundColor3 = Colors.Accent
        end

        local Tab = {Page = Page, Btn = TabBtn}
        table.insert(Window.Tabs, Tab)

        function Tab:AddToggle(text, callback)
            local state = false
            local TglBg = Instance.new("Frame", Page)
            TglBg.Size = UDim2.new(0.95, 0, 0, 40)
            TglBg.BackgroundColor3 = Colors.Element
            Instance.new("UICorner", TglBg).CornerRadius = UDim.new(0, 6)

            local TglText = Instance.new("TextLabel", TglBg)
            TglText.Size = UDim2.new(1, -60, 1, 0)
            TglText.Position = UDim2.new(0, 15, 0, 0)
            TglText.BackgroundTransparency = 1
            TglText.Text = text
            TglText.TextColor3 = Colors.Text
            TglText.Font = Enum.Font.GothamSemibold
            TglText.TextSize = 13
            TglText.TextXAlignment = Enum.TextXAlignment.Left

            local SwitchBtn = Instance.new("TextButton", TglBg)
            SwitchBtn.Size = UDim2.new(1, 0, 1, 0)
            SwitchBtn.BackgroundTransparency = 1
            SwitchBtn.Text = ""

            local SwitchOuter = Instance.new("Frame", TglBg)
            SwitchOuter.Size = UDim2.new(0, 40, 0, 20)
            SwitchOuter.Position = UDim2.new(1, -55, 0.5, -10)
            SwitchOuter.BackgroundColor3 = Colors.Bg
            Instance.new("UICorner", SwitchOuter).CornerRadius = UDim.new(1, 0)
            Instance.new("UIStroke", SwitchOuter).Color = Colors.TextDark

            local SwitchInner = Instance.new("Frame", SwitchOuter)
            SwitchInner.Size = UDim2.new(0, 14, 0, 14)
            SwitchInner.Position = UDim2.new(0, 3, 0.5, -7)
            SwitchInner.BackgroundColor3 = Colors.TextDark
            Instance.new("UICorner", SwitchInner).CornerRadius = UDim.new(1, 0)

            SwitchBtn.MouseButton1Click:Connect(function()
                state = not state
                if state then
                    TweenService:Create(SwitchInner, TweenInfo.new(0.2), {Position = UDim2.new(1, -17, 0.5, -7), BackgroundColor3 = Colors.Bg}):Play()
                    TweenService:Create(SwitchOuter, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent}):Play()
                else
                    TweenService:Create(SwitchInner, TweenInfo.new(0.2), {Position = UDim2.new(0, 3, 0.5, -7), BackgroundColor3 = Colors.TextDark}):Play()
                    TweenService:Create(SwitchOuter, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Bg}):Play()
                end
                pcall(callback, state)
            end)
        end

        function Tab:AddButton(text, callback)
            local BtnBg = Instance.new("TextButton", Page)
            BtnBg.Size = UDim2.new(0.95, 0, 0, 35)
            BtnBg.BackgroundColor3 = Colors.Element
            BtnBg.Text = text
            BtnBg.TextColor3 = Colors.Text
            BtnBg.Font = Enum.Font.GothamSemibold
            BtnBg.TextSize = 13
            Instance.new("UICorner", BtnBg).CornerRadius = UDim.new(0, 6)

            BtnBg.MouseEnter:Connect(function() TweenService:Create(BtnBg, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Hover}):Play() end)
            BtnBg.MouseLeave:Connect(function() TweenService:Create(BtnBg, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Element}):Play() end)
            BtnBg.MouseButton1Click:Connect(function()
                local r = Instance.new("Frame", BtnBg)
                r.BackgroundColor3 = Colors.Accent
                r.Size = UDim2.new(0,0,0,0)
                r.Position = UDim2.new(0.5,0,0.5,0)
                Instance.new("UICorner", r).CornerRadius = UDim.new(1,0)
                TweenService:Create(r, TweenInfo.new(0.3), {Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1}):Play()
                task.delay(0.3, function() r:Destroy() end)
                pcall(callback)
            end)
        end

        function Tab:AddSlider(text, min, max, def, callback)
            local val = def
            local SldBg = Instance.new("Frame", Page)
            SldBg.Size = UDim2.new(0.95, 0, 0, 50)
            SldBg.BackgroundColor3 = Colors.Element
            Instance.new("UICorner", SldBg).CornerRadius = UDim.new(0, 6)

            local SldText = Instance.new("TextLabel", SldBg)
            SldText.Size = UDim2.new(1, -20, 0, 20)
            SldText.Position = UDim2.new(0, 15, 0, 5)
            SldText.BackgroundTransparency = 1
            SldText.Text = text .. ": " .. val
            SldText.TextColor3 = Colors.Text
            SldText.Font = Enum.Font.GothamSemibold
            SldText.TextSize = 12
            SldText.TextXAlignment = Enum.TextXAlignment.Left

            local Track = Instance.new("Frame", SldBg)
            Track.Size = UDim2.new(1, -30, 0, 6)
            Track.Position = UDim2.new(0, 15, 0, 32)
            Track.BackgroundColor3 = Colors.Bg
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame", Track)
            Fill.Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
            Fill.BackgroundColor3 = Colors.Accent
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local dragging = false
            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            RunService.RenderStepped:Connect(function()
                if dragging then
                    local mousePos = UserInputService:GetMouseLocation()
                    local relative = math.clamp((mousePos.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    val = math.floor(min + ((max - min) * relative))
                    SldText.Text = text .. ": " .. val
                    TweenService:Create(Fill, TweenInfo.new(0.1), {Size = UDim2.new(relative, 0, 1, 0)}):Play()
                    pcall(callback, val)
                end
            end)
        end
        return Tab
    end
    return Window
end

