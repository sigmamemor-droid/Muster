    local function createTab(name, icon, layoutOrder)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Parent = TabContainer
        btn.BackgroundColor3 = Colors.SurfaceLight
        btn.BackgroundTransparency = 1
        btn.BorderSizePixel = 0
        btn.Size = UDim2.new(1, 0, 0, 36)
        btn.Text = ""
        btn.LayoutOrder = layoutOrder
        btn.AutoButtonColor = false
        addCorner(btn, 8)

        -- Иконка
        local IconLabel = Instance.new("TextLabel")
        IconLabel.Parent = btn
        IconLabel.BackgroundTransparency = 1
        IconLabel.Position = UDim2.new(0, 10, 0, 0)
        IconLabel.Size = UDim2.new(0, 20, 1, 0)
        IconLabel.Text = icon
        IconLabel.TextSize = 14
        IconLabel.Font = Enum.Font.SourceSans
        IconLabel.TextColor3 = Colors.TextMuted

        -- Текст
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Parent = btn
        NameLabel.BackgroundTransparency = 1
        NameLabel.Position = UDim2.new(0, 34, 0, 0)
        NameLabel.Size = UDim2.new(1, -44, 1, 0)
        NameLabel.Text = name
        NameLabel.TextColor3 = Colors.TextSecondary
        NameLabel.Font = Enum.Font.GothamSemibold
        NameLabel.TextSize = 12
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left

        -- Индикатор активности (слева)
        local Indicator = Instance.new("Frame")
        Indicator.Parent = btn
        Indicator.BackgroundColor3 = Colors.Accent
        Indicator.BorderSizePixel = 0
        Indicator.Size = UDim2.new(0, 3, 0, 0) -- скрыт по умолчанию
        Indicator.Position = UDim2.new(0, 0, 0.5, 0)
        Indicator.AnchorPoint = Vector2.new(0, 0.5)
        addCorner(Indicator, 2)

        -- Hover
        btn.MouseEnter:Connect(function()
            if State.ActiveTab ~= name then
                tween(btn, {BackgroundTransparency = 0.5}, 0.15)
                tween(NameLabel, {TextColor3 = Colors.TextPrimary}, 0.15)
            end
        end)
        btn.MouseLeave:Connect(function()
            if State.ActiveTab ~= name then
                tween(btn, {BackgroundTransparency = 1}, 0.15)
                tween(NameLabel, {TextColor3 = Colors.TextSecondary}, 0.15)
            end
        end)

        TabButtons[name] = {Button = btn, Icon = IconLabel, Name = NameLabel, Indicator = Indicator}
        return btn
    end

    local function setActiveTab(name)
        State.ActiveTab = name
        for tabName, data in pairs(TabButtons) do
            if tabName == name then
                tween(data.Button, {BackgroundTransparency = 0.3}, 0.2)
                tween(data.Name, {TextColor3 = Colors.TextPrimary}, 0.2)
                tween(data.Icon, {TextColor3 = Colors.Accent}, 0.2)
                tween(data.Indicator, {Size = UDim2.new(0, 3, 0, 18)}, 0.25, Enum.EasingStyle.Back)
            else
                tween(data.Button, {BackgroundTransparency = 1}, 0.2)
                tween(data.Name, {TextColor3 = Colors.TextSecondary}, 0.2)
                tween(data.Icon, {TextColor3 = Colors.TextMuted}, 0.2)
                tween(data.Indicator, {Size = UDim2.new(0, 3, 0, 0)}, 0.15)
            end
        end
    end

