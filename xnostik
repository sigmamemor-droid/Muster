    Bar.BorderSizePixel = 0
    Bar.Parent = Card
    Instance.new("UICorner", Bar).CornerRadius = UDim.new(0, 2)

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -18, 0, 22)
