            SLine.Size = UDim2.new(0.7, -10, 0, 1)
            SLine.Position = UDim2.new(0.3, 10, 0.5, 0)
            SLine.BackgroundColor3 = C.Line
            SLine.BorderSizePixel = 0
        end

        function Tab:AddLabel(text)
            local Lbl = Instance.new("TextLabel", Page)
            Lbl.Size = UDim2.new(1, -15, 0, 18)
            Lbl.BackgroundTransparency = 1
            Lbl.Text = text
            Lbl.TextColor3 = C.TextGray
            Lbl.Font = Enum.Font.Gotham
            Lbl.TextSize = 11
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            return Lbl
        end

        function Tab:AddToggle(text, callback)
            local state = false
            local TglBg = Instance.new("TextButton", Page)
            TglBg.Size = UDim2.new(1, -15, 0, 40)
            TglBg.BackgroundColor3 = C.Element
            TglBg.Text = ""
            Instance.new("UICorner", TglBg).CornerRadius = UDim.new(0, 8)

            local TglText = Instance.new("TextLabel", TglBg)
            TglText.Size = UDim2.new(1, -60, 1, 0)
            TglText.Position = UDim2.new(0, 15, 0, 0)
            TglText.BackgroundTransparency = 1
            TglText.Text = text
            TglText.TextColor3 = C.TextWhite
            TglText.Font = Enum.Font.GothamSemibold
            TglText.TextSize = 12
            TglText.TextXAlignment = Enum.TextXAlignment.Left

            local SwitchOuter = Instance.new("Frame", TglBg)
            SwitchOuter.Size = UDim2.new(0, 36, 0, 20)
            SwitchOuter.Position = UDim2.new(1, -50, 0.5, -10)
            SwitchOuter.BackgroundColor3 = C.ToggleOff
            Instance.new("UICorner", SwitchOuter).CornerRadius = UDim.new(1, 0)

            local SwitchInner = Instance.new("Frame", SwitchOuter)
            SwitchInner.Size = UDim2.new(0, 16, 0, 16)
            SwitchInner.Position = UDim2.new(0, 2, 0.5, -8)
            SwitchInner.BackgroundColor3 = C.TextGray
            Instance.new("UICorner", SwitchInner).CornerRadius = UDim.new(1, 0)

            TglBg.MouseButton1Click:Connect(function()
                state = not state
                if state then
                    TweenService:Create(SwitchInner, TweenInfo.new(0.2), {Position = UDim2.new(1, -18, 0.5, -8), BackgroundColor3 = C.TextWhite}):Play()
                    TweenService:Create(SwitchOuter, TweenInfo.new(0.2), {BackgroundColor3 = C.ToggleTrackOn}):Play()
                else
                    TweenService:Create(SwitchInner, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -8), BackgroundColor3 = C.TextGray}):Play()
                    TweenService:Create(SwitchOuter, TweenInfo.new(0.2), {BackgroundColor3 = C.ToggleOff}):Play()
                end
                pcall(callback, state)
            end)
        end

        function Tab:AddButton(text, callback)
            local Btn = Instance.new("TextButton", Page)
            Btn.Size = UDim2.new(1, -15, 0, 40)
            Btn.BackgroundColor3 = C.Element
            Btn.Text = text
            Btn.TextColor3 = C.TextWhite
            Btn.Font = Enum.Font.GothamSemibold
            Btn.TextSize = 12
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
            
            Btn.MouseButton1Click:Connect(function() pcall(callback) end)
        end

        return Tab
    end
    return Window
end

