local function Toggle(parent, text, default, callback)
    local card = Card(parent, 52)

    local label = Text(card, text, 14, Theme.Text, false)
    label.Position = UDim2.new(0, 16, 0, 0)
    label.Size = UDim2.new(1, -80, 1, 0)

    local switch = Instance.new("Frame")
    switch.Size = UDim2.new(0, 48, 0, 24)
    switch.Position = UDim2.new(1, -64, 0.5, -12)
    switch.BackgroundColor3 = default and Theme.Accent or Theme.Divider
    switch.BorderSizePixel = 0
    switch.Parent = card
    Corner(switch, 12)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = default and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.Parent = switch
    Corner(knob, 10)

    local enabled = default

    local function Set(val)
        enabled = val
        Tw(switch, {BackgroundColor3 = val and Theme.Accent or Theme.Divider}, 0.15)
        Tw(knob, {Position = val and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)}, 0.15)
        if callback then callback(val) end
    end

    local click = ButtonText(card)
    click.Size = UDim2.new(1, 0, 1, 0)
    click.MouseButton1Click:Connect(function()
        Set(not enabled)
    end)

    return {Set = Set, Value = enabled}
end

local function Slider(parent, text, min, max, default, callback)
    local card = Card(parent, 72)

    local label = Text(card, text, 14, Theme.Text, false)
    label.Position = UDim2.new(0, 16, 0, 6)
    label.Size = UDim2.new(0.7, 0, 0, 24)

    local valLabel = Text(card, tostring(default), 14, Theme.Accent, true)
    valLabel.Position = UDim2.new(0.7, 0, 0, 6)
    valLabel.Size = UDim2.new(0.3, -16, 0, 24)
    valLabel.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -32, 0, 4)
    track.Position = UDim2.new(0, 16, 0, 46)
    track.BackgroundColor3 = Theme.Bg3
    track.BorderSizePixel = 0
    track.Parent = card
    Corner(track, 2)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    Corner(fill, 2)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new((default-min)/(max-min), 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.Parent = track
    Corner(knob, 8)

    local sliding = false
    local val = default

    local function Update(input)
        if track.AbsoluteSize.X < 1 then return end
        local rel = math.clamp(
            (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
            0, 1
        )
        val = math.floor(min + (max-min)*rel)
        valLabel.Text = tostring(val)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, 0.5, 0)
        if callback then callback(val) end
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            Update(i)
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
            Update(i)
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    return {Get = function() return val end}
end

